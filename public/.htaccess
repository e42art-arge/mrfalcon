RewriteEngine On
RewriteBase /

# Map subdirectories to their index.html before OLS auto-inserts trailing slash
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^(.+[^/])$ $1/index.html [L]

# Catch anything else that doesn't map to a real file (SPA fallback)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule . /index.html [L]
