RewriteEngine On
RewriteBase /

# Catch trailing-slash directory URLs first (before vhost rules redirect them)
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^(.+)/$ $1/index.html [L]

# Handle non-trailing-slash directory URLs
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^(.+[^/])$ $1/index.html [L]

# SPA fallback for unknown paths
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule . /index.html [L]
