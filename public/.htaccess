# Mr. Falcon Beauty — OpenLiteSpeed rules
# Form posts directly to /api/contact.php; no extension-less rewrite needed.
# This file only handles SPA-style fallback for client routes.

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Existing files & directories pass through untouched
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # SPA-style fallback to index.html for unknown client routes
    RewriteRule ^ index.html [L]
</IfModule>
