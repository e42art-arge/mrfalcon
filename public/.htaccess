# Minimal .htaccess for static Astro site on OpenLiteSpeed
# Only needed: PHP handler for /api/contact endpoint
# All static HTML files are served directly by OLS (no rewrites needed)

# Ensure PHP is processed for the contact API
<FilesMatch "contact\.php$">
    SetHandler application/x-httpd-php
</FilesMatch>

# Optional: deny direct access to .htaccess
<Files ".htaccess">
    Order allow,deny
    Deny from all
</Files>