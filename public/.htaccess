RewriteEngine On
RewriteBase /

# Remove trailing slash (preserve path) — only for non-file URLs
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^(.+)/$ /$1 [L,R=301]

# Serve subdirectory index.html for sub-page routes
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.+)$ /$1/index.html [L]
