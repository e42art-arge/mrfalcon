---
interface Props {
  name: string;
  address: string;
  phone: string;
  whatsapp: string;
  hours?: string;
  image?: string;
}

const { name, address, phone, whatsapp, hours, image = "/images/clinic/clinic1.jpg" } = Astro.props;
---

<article class="rounded-2xl overflow-hidden border border-black/5 shadow-lg bg-white">
  <div class="bg-sky-light overflow-hidden"><img src={image} alt={name} class="w-full" /></div>
  <div class="p-6">
    <h2 class="font-display text-2xl font-semibold text-primary">{name}</h2>
    <address class="mt-3 not-italic text-sm text-black/70">{address}</address>
    <div class="mt-4 space-y-2 text-sm">
      <a href={`tel:${phone}`} class="flex items-center gap-2 text-black/70 hover:text-primary transition-colors">📞 {phone}</a>
      <a href={whatsapp} target="_blank" rel="noopener" class="flex items-center gap-2 text-black/70 hover:text-primary transition-colors">💬 WhatsApp</a>
    </div>
    {hours && <p class="mt-4 text-xs text-black/50">{hours}</p>}
  </div>
</article>
