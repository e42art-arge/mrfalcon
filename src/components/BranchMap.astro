---
interface Branch {
  name: string;
  mapEmbed?: string;
}
interface Props {
  branch: Branch;
  class?: string;
}
const { branch, class: className = "" } = Astro.props;
---

<div class:list={["rounded-2xl overflow-hidden aspect-[4/3] shadow-md", className]}>
  <iframe
    src={branch.mapEmbed}
    class="w-full h-full border-0"
    allowfullscreen
    loading="lazy"
    referrerpolicy="no-referrer-when-downgrade"
    title={branch.name}
  ></iframe>
</div>
