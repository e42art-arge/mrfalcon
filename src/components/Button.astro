---
interface Props {
  variant?: 'primary' | 'secondary' | 'small' | 'ghost';
  href?: string;
  class?: string;
  target?: string;
  rel?: string;
  type?: 'button' | 'submit' | 'reset';
}

const { variant = 'primary', href, class: className = '', target, rel, type, ...rest } = Astro.props;

const baseClasses = 'inline-flex items-center justify-center gap-2 font-semibold transition-all duration-normal ease-out-expo focus:outline-none focus:ring-2 focus:ring-primary/50 focus:ring-offset-2';

const variants = {
  primary: 'bg-navy text-white rounded-full px-8 py-3 shadow-card hover:bg-primary hover:shadow-card-hover hover:-translate-y-0.5',
  secondary: 'border-2 border-navy/20 text-navy rounded-full px-8 py-3 hover:border-primary hover:text-primary hover:shadow-surface',
  small: 'bg-navy text-white rounded-full px-5 py-2.5 text-sm font-medium shadow-surface hover:bg-primary hover:shadow-card hover:-translate-y-0.5',
  ghost: 'text-primary hover:text-navy font-semibold group',
};

const Tag = href ? 'a' : 'button';
const attrs = href ? { href, target, rel } : { type };
---

<Tag
  class:list={[baseClasses, variants[variant], className]}
  {...attrs}
  {...rest}
>
  <slot />
  {variant === 'ghost' && (
    <span class="inline-block transition-transform duration-fast group-hover:translate-x-1">→</span>
  )}
</Tag>