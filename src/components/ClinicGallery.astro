---
interface Props {
  images: Array<{ src: string; alt: string }>;
  columns?: 2 | 3 | 4;
}

const { images, columns = 4 } = Astro.props;

const gridCols = {
  2: 'grid-cols-2',
  3: 'grid-cols-2 md:grid-cols-3',
  4: 'grid-cols-2 md:grid-cols-4',
}[columns];
---

<div class:list={['grid', gridCols, 'gap-4']}>
  {images.map((img) => (
    <div class="rounded-2xl overflow-hidden shadow-md"><img src={img.src} alt={img.alt} class="w-full" /></div>
  ))}
</div>
