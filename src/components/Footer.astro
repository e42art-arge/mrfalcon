---
interface Props {
  locale?: "tr" | "en";
}
const { locale = "tr" } = Astro.props;
const en = locale === "en";
---

<footer class="bg-ink text-mist/80">
  <div class="mx-auto grid max-w-6xl gap-10 px-5 py-14 md:grid-cols-3">
    <div>
      <div class="font-display text-xl font-semibold text-white">
        Mr. Falcon <span class="text-champagne">Beauty</span>
      </div>
      <p class="mt-3 max-w-xs text-sm leading-relaxed">
        {en
          ? "Painless laser hair removal with Falcon 4 Pro technology across Istanbul."
          : "Falcon 4 Pro teknolojisiyle ağrısız lazer epilasyon, İstanbul genelinde."}
      </p>
    </div>
    <div>
      <h3 class="text-sm font-semibold uppercase tracking-wide text-champagne">{en ? "Clinics" : "Merkezler"}</h3>
      <ul class="mt-3 space-y-2 text-sm">
        <li>Şişli — {en ? "Istanbul" : "İstanbul"}</li>
        <li>Halıkalı — {en ? "Istanbul" : "İstanbul"}</li>
        <li><a class="hover:text-champagne" href={en ? "/en/contact" : "/iletisim"}">{en ? "Contact" : "İletişim"}</a></li>
      </ul>
    </div>
    <div>
      <h3 class="text-sm font-semibold uppercase tracking-wide text-champagne">WhatsApp</h3>
      <p class="mt-3 text-sm">
        <a class="hover:text-champagne" href="https://wa.me/905000000000">+90 500 000 00 00</a>
      </p>
      <div class="mt-4 flex gap-4 text-sm">
        <a class="hover:text-champagne" href="/sss">{en ? "FAQ" : "SSS"}</a>
        <a class="hover:text-champagne" href="/yorumlar">{en ? "Reviews" : "Yorumlar"}</a>
      </div>
    </div>
  </div>
  <div class="border-t border-white/10 py-5 text-center text-xs text-mist/50">
    © {new Date().getFullYear()} Mr. Falcon Beauty. {en ? "All rights reserved." : "Tüm hakları saklıdır."}
  </div>
</footer>
