---
interface Props {
  locale?: "tr" | "en";
}
const { locale = "tr" } = Astro.props;
const en = locale === "en";
---

<footer class="bg-sky-light text-black/70">
  <div class="mx-auto grid max-w-6xl gap-10 px-5 py-14 md:grid-cols-3">
    <div>
      <a href={en ? "/en" : "/"} class="flex items-center gap-2" aria-label="Mr. Falcon Beauty Ana Sayfa">
        <img src="/images/logo.png" alt="Mr. Falcon Beauty Logo" class="h-10 w-auto" />
      </a>
      <p class="mt-3 max-w-xs text-sm leading-relaxed text-black/60">
        {en
          ? "Painless laser hair removal with Falcon 4 Pro technology across Istanbul."
          : "Falcon 4 Pro teknolojisiyle ağrısız lazer epilasyon, İstanbul genelinde."}
      </p>
    </div>
    <div>
      <h3 class="text-sm font-semibold uppercase tracking-wide text-primary">{en ? "Clinics" : "Merkezler"}</h3>
      <ul class="mt-3 space-y-2 text-sm text-black/70">
        <li>{en ? "Şişli — Istanbul" : "Şişli — İstanbul"}</li>
        <li>{en ? "Halkalı — Istanbul" : "Halkalı — İstanbul"}</li>
        <li><a class="hover:text-primary transition-colors" href={en ? "/en/contact" : "/iletisim"}>{en ? "Contact" : "İletişim"}</a></li>
      </ul>
      <div class="mt-4 space-y-1 text-sm">
        <ul class="space-y-1">
          <li><a class="hover:text-primary transition-colors text-black/70" href="tel:+905525939890">+90 552 593 98 90</a></li>
          <li><a class="hover:text-primary transition-colors text-black/70" href="tel:+905063717071">+90 506 371 70 71</a></li>
        </ul>
      </div>
    </div>
    <div>
      <h3 class="text-sm font-semibold uppercase tracking-wide text-primary">WhatsApp</h3>
      <p class="mt-3 text-sm">
        <a class="hover:text-primary transition-colors text-black/70" href="https://api.whatsapp.com/send?phone=905525939890&text=Merhaba web siteniz üzerinden size ulaşıyorum, Falcon Lazer Epilasyon hakkında bilgi alabilir miyim ?">+90 552 593 98 90</a>
      </p>
      <div class="mt-4 flex gap-4 text-sm">
        <a class="hover:text-primary transition-colors text-black/70" href={en ? "/en/faq" : "/sss"}>{en ? "FAQ" : "SSS"}</a>
        <a class="hover:text-primary transition-colors text-black/70" href={en ? "/en/reviews" : "/yorumlar"}>{en ? "Reviews" : "Yorumlar"}</a>
      </div>
    </div>
  </div>
  <div class="border-t border-black/10 py-5 text-center text-xs text-black/40">
    © {new Date().getFullYear()} Mr. Falcon Beauty. {en ? "All rights reserved." : "Tüm hakları saklıdır."}
  </div>
</footer>