---
interface Props {
  locale?: "tr" | "en";
}
const { locale = "tr" } = Astro.props;
const en = locale === "en";

const nav = en
  ? [
      { href: "/en/laser-hair-removal", label: "Laser Hair Removal" },
      { href: "/en/falcon-4-pro", label: "Falcon 4 Pro" },
      { href: "/en/our-clinics", label: "Clinics" },
      { href: "/en/reviews", label: "Reviews" },
      { href: "/en/faq", label: "FAQ" },
      { href: "/en/contact", label: "Contact" },
    ]
  : [
      { href: "/lazer-epilasyon", label: "Lazer Epilasyon" },
      { href: "/falcon-4-pro", label: "Falcon 4 Pro" },
      { href: "/merkezlerimiz", label: "Merkezlerimiz" },
      { href: "/yorumlar", label: "Yorumlar" },
      { href: "/sss", label: "SSS" },
      { href: "/iletisim", label: "İletişim" },
    ];

const homeHref = en ? "/en" : "/";
const langHref = en ? "/" : "/en";
const langLabel = en ? "TR" : "EN";
---

<header class="sticky top-0 z-50 bg-white/90 backdrop-blur border-b border-ink/5">
  <div class="mx-auto flex max-w-6xl items-center justify-between px-5 py-4">
    <a href={homeHref} class="flex items-center gap-2" aria-label="Mr. Falcon Beauty Ana Sayfa">
      <img src="/logo.png" alt="" class="h-10 w-auto" />
      <span class="font-display text-xl font-semibold tracking-tight text-ink hidden sm:block">
        Mr. Falcon <span class="text-champagne">Beauty</span>
      </span>
    </a>
    <nav class="hidden items-center gap-7 text-sm font-medium text-ink/80 md:flex">
      {nav.map((item) => (
        <a href={item.href} class="transition-colors hover:text-champagne">{item.label}</a>
      ))}
    </nav>
    <div class="flex items-center gap-3">
      <a
        href={langHref}
        class="rounded-full border border-ink/15 px-3 py-1 text-xs font-semibold tracking-wide text-ink/70 transition-colors hover:border-champagne hover:text-champagne"
      >
        {langLabel}
      </a>
      <a
        href={en ? "/en/contact" : "/iletisim"}
        class="hidden rounded-full bg-ink px-4 py-2 text-sm font-semibold text-white transition-colors hover:bg-champagne sm:inline-block"
      >
        {en ? "Book" : "Randevu"}
      </a>
    </div>
  </div>
</header>
