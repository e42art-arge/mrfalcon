---
import VideoGallery from "./VideoGallery.astro";

interface VideoItem {
  id: number;
  thumbnail: string;
  videoUrl: string;
  title: string;
  description: string;
}

interface Props {
  videos: VideoItem[];
  sectionId?: string;
  class?: string;
  locale?: "tr" | "en";
}

const { videos, sectionId = "info-videos", class: className = "", locale = "tr" } = Astro.props;
const en = locale === "en";
---

<VideoGallery
  videos={videos}
  sectionId={sectionId}
  class={className}
  locale={locale}
  label={en ? "Educational Videos" : "Bilgilendirici Videolar"}
  title={en ? "Everything About Falcon Laser Hair Removal" : "Falcon Lazer Epilasyon Hakkında Her Şey"}
  group="info-videos"
/>
