---
interface PressItem {
  id: number;
  thumbnail: string;
  videoUrl: string;
  channel: string;
}

interface Props {
  videos: PressItem[];
  locale?: "tr" | "en";
  sectionId?: string;
}

const { videos, locale = "tr", sectionId = "press-videos" } = Astro.props;
const en = locale === "en";
---

<section id={sectionId} class="py-20 bg-sky-light/30" data-animate="fadeUp">
  <div class="mx-auto max-w-6xl px-5">
    <div class="text-center max-w-3xl mx-auto mb-12">
      <p class="mb-2 text-sm font-semibold uppercase tracking-[0.2em] text-primary">
        {en ? "Press" : "Basın"}
      </p>
      <h2 class="font-display text-3xl font-semibold text-black md:text-4xl">
        {en ? "Mr. Falcon Beauty in the Press" : "Mr. Falcon Beauty Basında"}
      </h2>
      <p class="mt-3 text-black/60">
        {en
          ? "Our successful results with Falcon laser hair removal have been featured on national TV channels."
          : "Falcon Lazer Epilasyon ile elde edilen başarılı sonuçlar, ulusal televizyon kanallarında da yer buldu."}
      </p>
    </div>

    <!-- Slider container -->
    <div class="relative group/slider" data-animate="stagger">
      <!-- Scroll track -->
      <div
        id="press-track"
        class="flex gap-6 overflow-x-auto scroll-smooth snap-x snap-mandatory pb-4 -mx-5 px-5 scrollbar-hide"
        style="scrollbar-width: none; -ms-overflow-style: none;"
      >
        {videos.map((video) => (
          <article
            class="min-w-[280px] sm:min-w-[320px] lg:min-w-[360px] snap-start rounded-2xl overflow-hidden bg-white border border-black/5 shadow-surface hover:shadow-card-hover transition-all duration-normal group"
            data-hover="lift"
          >
            <a
              href={video.videoUrl}
              data-fancybox="press-videos"
              class="relative block aspect-video overflow-hidden bg-gray-100"
              aria-label={`${en ? "Watch" : "İzle"}: ${video.channel}`}
            >
              <img
                src={video.thumbnail}
                alt={video.channel}
                class="w-full h-full object-contain transition-transform duration-500 group-hover:scale-105"
                loading="lazy"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center">
                <div class="w-14 h-14 rounded-full bg-white/90 backdrop-blur flex items-center justify-center text-navy transform group-hover:scale-110 transition-transform">
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="5 3 19 12 5 21 5 3"></polygon></svg>
                </div>
              </div>
              <!-- Channel badge -->
              <div class="absolute top-3 left-3 rounded-full bg-black/60 backdrop-blur px-3 py-1 text-xs font-semibold text-white">
                {video.channel}
              </div>
            </a>
            <div class="p-5">
              <p class="text-xs font-semibold uppercase tracking-wider text-primary">
                {en ? "News" : "Haber"}
              </p>
              <h3 class="font-display text-base font-semibold text-black mt-1">{video.channel}</h3>
            </div>
          </article>
        ))}
      </div>

      <!-- Nav arrows -->
      <button
        id="press-prev"
        class="absolute left-0 top-1/2 -translate-y-1/2 -translate-x-3 w-10 h-10 rounded-full bg-white/90 backdrop-blur shadow-lg flex items-center justify-center text-navy opacity-0 group-hover/slider:opacity-100 transition-opacity hover:bg-white z-10"
        aria-label={en ? "Previous" : "Önceki"}
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
      </button>
      <button
        id="press-next"
        class="absolute right-0 top-1/2 -translate-y-1/2 translate-x-3 w-10 h-10 rounded-full bg-white/90 backdrop-blur shadow-lg flex items-center justify-center text-navy opacity-0 group-hover/slider:opacity-100 transition-opacity hover:bg-white z-10"
        aria-label={en ? "Next" : "Sonraki"}
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
      </button>
    </div>
  </div>
</section>

<style>
  #press-track::-webkit-scrollbar { display: none; }
</style>

<script>
  (function() {
    const track = document.getElementById('press-track');
    const prev = document.getElementById('press-prev');
    const next = document.getElementById('press-next');
    if (!track || !prev || !next) return;

    const scroll = (dir) => {
      const card = track.querySelector('.snap-start');
      if (!card) return;
      const w = card.offsetWidth + 24; // card + gap
      track.scrollBy({ left: dir * w, behavior: 'smooth' });
    };

    prev.addEventListener('click', () => scroll(-1));
    next.addEventListener('click', () => scroll(1));

    // Show/hide arrows based on scroll position
    const update = () => {
      prev.classList.toggle('hidden', track.scrollLeft <= 4);
      next.classList.toggle('hidden', track.scrollLeft >= track.scrollWidth - track.clientWidth - 4);
    };
    track.addEventListener('scroll', update);
    update();

    // Touch / mouse drag
    let isDown = false, startX, scrollLeft;
    track.addEventListener('mousedown', (e) => {
      isDown = true;
      track.classList.add('cursor-grabbing');
      startX = e.pageX - track.offsetLeft;
      scrollLeft = track.scrollLeft;
    });
    track.addEventListener('mouseleave', () => {
      isDown = false;
      track.classList.remove('cursor-grabbing');
    });
    track.addEventListener('mouseup', () => {
      isDown = false;
      track.classList.remove('cursor-grabbing');
    });
    track.addEventListener('mousemove', (e) => {
      if (!isDown) return;
      e.preventDefault();
      const x = e.pageX - track.offsetLeft;
      const walk = (x - startX) * 1.5;
      track.scrollLeft = scrollLeft - walk;
    });
  })();
</script>
