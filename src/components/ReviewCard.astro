---
import type { Review } from "../data/reviews";

interface Props {
  review: Review;
  variant?: "compact" | "full";
}
const { review, variant = "full" } = Astro.props;
const compact = variant === "compact";
const cardClass = compact
  ? "rounded-2xl border border-black/10 bg-white p-6 shadow-surface hover:shadow-card-hover transition-all duration-normal"
  : "rounded-2xl border border-black/10 p-6 hover:shadow-lg transition-shadow";
---

<article class={cardClass}>
  <div class="flex gap-1 text-primary text-sm mb-3">
    {Array.from({ length: review.rating }).map(() => <span>★</span>)}
    <span class="ml-2 text-xs text-black/50">(Google)</span>
  </div>
  <blockquote class:list={[compact ? "text-black/80 text-body-sm leading-relaxed" : "text-black/80 text-sm leading-relaxed mb-4"]}>"{review.text}"</blockquote>
  <footer class:list={["flex items-center justify-between", compact ? "mt-4 text-caption" : "text-xs"]}>
    <cite class="font-semibold text-primary not-italic">{review.name}</cite>
    <span class="text-black/50">Google</span>
  </footer>
</article>
