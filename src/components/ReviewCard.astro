---
import type { Review } from "../data/reviews";
import { initials, timeAgo } from "../data/reviews";

interface Props {
  review: Review;
  locale?: "tr" | "en";
  class?: string;
}
const { review, locale = "tr", class: className = "" } = Astro.props;
const googleLabel = locale === "en" ? "Google Review" : "Google Yorumu";
---

<article class:list={["relative mb-6 break-inside-avoid rounded-2xl border border-black/5 bg-white p-6 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-xl", className]}>
  <span class="pointer-events-none absolute right-5 top-3 select-none font-display text-6xl leading-none text-primary/10" aria-hidden="true">&rdquo;</span>
  <div class="flex items-center gap-3">
    <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-full bg-gradient-to-br from-sky to-primary text-sm font-semibold text-white">
      {initials(review.name)}
    </div>
    <div class="min-w-0">
      <p class="truncate font-semibold text-navy">{review.name}</p>
      <p class="text-xs text-navy/50">{timeAgo(review.date, locale)}</p>
    </div>
  </div>
  <div class="mt-3 flex gap-0.5" aria-label={`${review.rating} ${locale === "en" ? "stars" : "yıldız"}`}>
    {Array.from({ length: 5 }, (_, i) => (
      <svg class={`h-4 w-4 ${i < review.rating ? "text-primary" : "text-black/10"}`} fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
        <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path>
      </svg>
    ))}
  </div>
  <p class="mt-3 text-sm leading-relaxed text-navy/75">{review.text}</p>
  <div class="mt-4 flex items-center gap-2 border-t border-black/5 pt-3 text-xs text-navy/40">
    <svg viewBox="0 0 48 48" class="h-3.5 w-3.5" aria-hidden="true">
      <path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"></path>
      <path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6.01C43.98 37.95 46.98 31.5 46.98 24.55z"></path>
      <path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"></path>
      <path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6.01c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"></path>
    </svg>
    {googleLabel}
  </div>
</article>
