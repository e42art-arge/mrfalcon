---
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
  locale?: "tr" | "en";
  path?: string;
}

const { title, description, locale = "tr", path = "/" } = Astro.props;
const site = Astro.site?.href ?? "https://mrfalconbeauty.com/";
const canonical = new URL(path.replace(/^\/+/, ""), site).href;
const ogImage = new URL("/images/og-default.svg", site).href;

const altPath = locale === "tr" ? `/en${path === "/" ? "" : path}` : path.replace(/^\/en/, "") || "/";
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/images/favicon.png" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang="tr" href={locale === "tr" ? canonical : new URL(altPath.replace(/^\/+/, ""), site).href} />
    <link rel="alternate" hreflang="en" href={locale === "tr" ? new URL(altPath.replace(/^\/+/, ""), site).href : canonical} />
    <link rel="alternate" hreflang="x-default" href={new URL("/", site).href} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Mr. Falcon Beauty" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <slot />
    <!-- Floating WhatsApp Widget -->
    <a
      href="https://wa.me/905525939890"
      target="_blank"
      rel="noopener noreferrer"
      class="fixed bottom-6 right-6 z-50 flex items-center justify-center w-14 h-14 rounded-full bg-whatsapp text-white shadow-lg hover:shadow-xl hover:bg-[#46b85c] transition-all duration-300 animate-pulse"
      aria-label="WhatsApp ile iletişime geçin"
      title="WhatsApp ile yazın"
    >
      <svg viewBox="0 0 24 24" width="28" height="28" fill="currentColor"><path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946C.06 5.348 5.397.01 12.008.01c3.202.001 6.212 1.246 8.477 3.514 2.266 2.268 3.507 5.28 3.505 8.484-.004 6.657-5.34 11.997-11.953 11.997-2.005-.001-3.973-.504-5.714-1.465L0 24zm6.59-4.846c1.6.95 3.188 1.449 4.825 1.451 5.436 0 9.86-4.37 9.864-9.799.002-2.63-1.023-5.101-2.885-6.97C16.579 1.968 14.1 1.9 12.001 1.9 6.561 1.9 2.137 6.27 2.133 11.7c-.001 1.705.452 3.37 1.312 4.837l-.993 3.629 3.729-.977zm11.367-7.251c-.269-.135-1.593-.787-1.839-.877-.247-.09-.427-.135-.607.135-.18.27-.697.877-.854 1.057-.158.18-.315.202-.584.067-2.073-1.036-3.393-2.617-4.116-3.869-.18-.31-.03-.42.09-.54.12-.12.27-.315.405-.472.135-.158.18-.27.27-.45.09-.18.045-.337-.022-.472-.067-.135-.607-1.463-.831-2.003-.218-.526-.459-.453-.607-.461-.157-.008-.337-.008-.517-.008-.18 0-.472.067-.72.337-.247.27-.945.922-.945 2.247s.967 2.599 1.102 2.779c.135.18 1.902 2.904 4.609 4.07.644.278 1.148.443 1.54.568.647.206 1.237.177 1.702.107.519-.078 1.593-.651 1.819-1.281.225-.63.225-1.17.157-1.282-.067-.11-.247-.145-.517-.28z"/></svg>
    </a>
    <!-- GSAP Animations -->
    <script>
      import "../scripts/animations.js";
    </script>
  </body>
</html>
