---
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
  locale?: "tr" | "en";
  path?: string;
}

const { title, description, locale = "tr", path = "/" } = Astro.props;
const site = Astro.site?.href ?? "https://mrfalconbeauty.com/";
const canonical = new URL(path.replace(/^\/+/, ""), site).href;
const ogImage = new URL("/images/og-default.svg", site).href;

const altPath = locale === "tr" ? `/en${path === "/" ? "" : path}` : path.replace(/^\/en/, "") || "/";
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/images/favicon.png" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang="tr" href={locale === "tr" ? canonical : new URL(altPath.replace(/^\/+/, ""), site).href} />
    <link rel="alternate" hreflang="en" href={locale === "tr" ? new URL(altPath.replace(/^\/+/, ""), site).href : canonical} />
    <link rel="alternate" hreflang="x-default" href={new URL("/", site).href} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Mr. Falcon Beauty" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <slot />
    <!-- Floating WhatsApp Widget -->
    <a
      href="https://wa.me/905525939890"
      target="_blank"
      rel="noopener noreferrer"
      class="fixed bottom-6 right-6 z-50 flex items-center justify-center w-14 h-14 rounded-full bg-whatsapp text-white shadow-lg hover:shadow-xl hover:bg-[#46b85c] transition-all duration-300 animate-pulse"
      aria-label="WhatsApp ile iletişime geçin"
      title="WhatsApp ile yazın"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path></svg>
    </a>
    <!-- GSAP Animations -->
    <script type="module" src="/scripts/animations.js"></script>
  </body>
</html>
