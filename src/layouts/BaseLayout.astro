---
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
  locale?: "tr" | "en";
  path?: string;
}

const { title, description, locale = "tr", path = "/" } = Astro.props;
const site = Astro.site?.href ?? "https://mrfalconbeauty.com/";
const canonical = new URL(path.replace(/^\/+/, ""), site).href;
const ogImage = new URL("og-default.svg", site).href;

const altPath = locale === "tr" ? `/en${path === "/" ? "" : path}` : path.replace(/^\/en/, "") || "/";
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang="tr" href={locale === "tr" ? canonical : new URL(altPath.replace(/^\/+/, ""), site).href} />
    <link rel="alternate" hreflang="en" href={locale === "tr" ? new URL(altPath.replace(/^\/+/, ""), site).href : canonical} />
    <link rel="alternate" hreflang="x-default" href={new URL("/", site).href} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Mr. Falcon Beauty" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Instrument+Sans:wght@500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <slot />
  </body>
</html>
