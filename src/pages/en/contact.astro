---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import ClinicCard from "../../components/ClinicCard.astro";
import BranchMap from "../../components/BranchMap.astro";
import AppointmentForm from "../../components/AppointmentForm.astro";
import PageHero from "../../components/PageHero.astro";
import ClinicGallery from "../../components/ClinicGallery.astro";
import { getCollection } from "astro:content";

const branches = await getCollection("branches");
branches.sort((a, b) => a.data.slug.localeCompare(b.data.slug));
---

<BaseLayout title="Contact | Mr. Falcon Beauty" description="Mr. Falcon Beauty contact page. Book a free consultation for laser hair removal at Şişli or Halkalı." locale="en" path="/en/contact">
  <Header locale="en" />

  <PageHero title="Contact Us" description="Take the first step toward permanent smoothness. Fill in the form and let's create your personalized plan together." bgImage="/images/contactbg.jpg" />

  <section class="py-20">
    <div class="mx-auto max-w-6xl px-5">
      <div class="grid md:grid-cols-2 gap-12">
        <!-- FORM -->
        <AppointmentForm locale="en" branches={branches} />

        <!-- BRANCH INFO -->
        <div class="space-y-8">
          {branches.map((b) => <ClinicCard branch={b.data} />)}

          <BranchMap branch={branches[0].data} />
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 bg-sky-light/30">
    <div class="mx-auto max-w-6xl px-5">
      <ClinicGallery images={["/images/c1.jpg","/images/c2.jpg","/images/c3.jpg","/images/c4.jpg"].map(src => ({ src, alt: "Mr. Falcon Beauty" }))} columns={4} />
    </div>
  </section>

  <Footer locale="en" />
</BaseLayout>