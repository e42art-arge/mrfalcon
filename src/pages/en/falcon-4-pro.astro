---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import BookingCta from "../../components/BookingCta.astro";
import SectionHeader from "../../components/SectionHeader.astro";
import PageHero from "../../components/PageHero.astro";
import PressSlider from "../../components/PressSlider.astro";
import { features } from "../../data/features";
import { pressVideos } from "../../data/videos";

const wavelengths = [
  { nm: "755nm", t: "Alexandrite", desc: "Fair skin, fine hair" },
  { nm: "808nm", t: "Diode", desc: "All skin types, standard hair" },
  { nm: "940nm", t: "Diode", desc: "Dark skin, deep follicles" },
  { nm: "1064nm", t: "Nd:YAG", desc: "Tanned skin, safe" },
];
---

<BaseLayout title="Falcon 4 Pro | Mr. Falcon Beauty" description="FDA-cleared Falcon 4 Pro device: 4-wavelength hybrid laser, -20° cooling, SHR technology. Detailed review." locale="en" path="/en/falcon-4-pro">
  <Header locale="en" />

  <PageHero
    label="Device Review"
    title="Falcon 4 Pro<br /><span class=&quot;text-primary&quot;>Laser Hair Removal Device</span>"
    description="FDA 510(k) cleared, AI-powered 4-wavelength hybrid technology — at Mr. Falcon Beauty Şişli and Halkalı"
    primaryCta={{ href: "/en/contact", text: "Book Now" }}
    secondaryCta={{ href: "https://api.whatsapp.com/send?phone=905525939890", text: "WhatsApp" }}
  />

  <section class="py-16 bg-white"><div class="mx-auto max-w-4xl px-5 text-center"><img src="/images/falcons.png" alt="Falcon 4 Pro" class="mx-auto w-full max-w-md" /></div></section>

  <section class="py-20 bg-sky-light/30">
    <div class="mx-auto max-w-6xl px-5">
      <SectionHeader label="Technical Details" title="Falcon 4 Pro Specifications" margin="md" />
      <div class="grid md:grid-cols-2 gap-6">
        {features.en.map((f) => (<article class="rounded-2xl bg-white p-6 border border-black/5 shadow-sm hover:shadow-md transition-shadow"><h3 class="font-display text-xl font-semibold text-primary">{f.name}</h3><p class="mt-1 text-sm font-medium text-black/50">{f.wavelengths}</p><p class="mt-3 text-sm text-black/70 leading-relaxed">{f.desc}</p></article>))}
      </div>
    </div>
  </section>

  <PressSlider videos={pressVideos} locale="en" />

  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@fancyapps/ui@5.0/dist/fancybox/fancybox.css" />
  <script type="module">
    import { Fancybox } from "https://cdn.jsdelivr.net/npm/@fancyapps/ui@5.0/dist/fancybox/fancybox.esm.js";
    Fancybox.bind('[data-fancybox="press-videos"]', {
      type: "video",
      video: { autoStart: true },
      Toolbar: { display: ["close"] },
      mainClass: "fancybox-press"
    });
  </script>

  <section class="py-20">
    <div class="mx-auto max-w-6xl px-5">
      <SectionHeader title="4 Wavelengths — For Every Skin Type" description="Hybrid technology targeting different tissue depths and hair types in a single session" margin="md" />
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
        {wavelengths.map((w) => (<article class="rounded-2xl border border-black/5 p-6 text-center bg-sky-light/20"><div class="font-display text-3xl font-bold text-primary">{w.nm}</div><div class="mt-1 font-semibold">{w.t}</div><p class="mt-2 text-xs text-black/60">{w.desc}</p></article>))}
      </div>
    </div>
  </section>

  <BookingCta locale="en" />

  <Footer locale="en" />
</BaseLayout>
