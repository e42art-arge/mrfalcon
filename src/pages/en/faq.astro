---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import FaqAccordion from "../../components/FaqAccordion.astro";
import PageHero from "../../components/PageHero.astro";
import CtaSection from "../../components/CtaSection.astro";
import { getCollection } from "astro:content";

const faqEntries = (await getCollection("faq", ({ id }) => id.startsWith("en/"))).sort((a, b) => (a.data.order || 0) - (b.data.order || 0));
const faqs = faqEntries.map((e) => ({ q: e.data.question, a: e.data.answer }));
---

<BaseLayout title="FAQ | Mr. Falcon Beauty" description="Frequently asked questions about laser hair removal, Falcon 4 Pro, sessions, and more." locale="en" path="/en/faq">
  <Header locale="en" />

  <PageHero label="FAQ" title="Frequently Asked Questions" description="Everything you wonder about Falcon 4 Pro and laser hair removal." />

  <section class="py-20 bg-sky-light/30">
    <div class="mx-auto max-w-3xl px-5">
      <FaqAccordion items={faqs} tone="light" />
      <p class="mt-10 text-center text-sm text-black/60">
        Can't find your question? <a href="https://wa.me/905525939890" target="_blank" rel="noopener" class="text-primary hover:underline">Ask on WhatsApp</a>
      </p>
    </div>
  </section>

  <CtaSection title="Still have questions?" description="Book a free consultation and skin analysis." buttonText="Contact Us" buttonHref="/en/contact" />

  <Footer locale="en" />
</BaseLayout>
