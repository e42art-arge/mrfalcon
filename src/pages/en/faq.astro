---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import FaqAccordion from "../../components/FaqAccordion.astro";
import { getCollection } from "astro:content";

const faqEntries = (await getCollection("faq", ({ id }) => id.startsWith("en/"))).sort((a, b) => (a.data.order || 0) - (b.data.order || 0));
const faqs = faqEntries.map((e) => ({ q: e.data.question, a: e.data.answer }));
---

<BaseLayout title="FAQ | Mr. Falcon Beauty" description="Frequently asked questions about laser hair removal, Falcon 4 Pro, sessions, and more." locale="en" path="/en/faq">
  <Header locale="en" />

  <section class="py-20 md:py-28 bg-navy text-white">
    <div class="mx-auto max-w-6xl px-5 text-center">
      <p class="mb-4 text-sm font-semibold uppercase tracking-[0.2em] text-primary">FAQ</p>
      <h1 class="font-display text-4xl font-semibold md:text-6xl">Frequently Asked Questions</h1>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-white/80">Everything you wonder about Falcon 4 Pro and laser hair removal.</p>
    </div>
  </section>

  <section class="py-20 bg-sky-light/30">
    <div class="mx-auto max-w-3xl px-5">
      <FaqAccordion items={faqs} tone="light" />
      <p class="mt-10 text-center text-sm text-black/60">
        Can't find your question? <a href="https://wa.me/905525939890" target="_blank" rel="noopener" class="text-primary hover:underline">Ask on WhatsApp</a>
      </p>
    </div>
  </section>

  <section class="py-20 bg-sky-light/50">
    <div class="mx-auto max-w-3xl px-5 text-center">
      <h2 class="font-display text-3xl font-semibold md:text-4xl">Still have questions?</h2>
      <p class="mt-4 text-lg text-black/70">Book a free consultation and skin analysis.</p>
      <div class="mt-8"><a href="/en/contact" class="rounded-full bg-navy px-8 py-3 font-semibold text-white transition-colors hover:bg-primary">Contact Us</a></div>
    </div>
  </section>

  <Footer locale="en" />
</BaseLayout>
