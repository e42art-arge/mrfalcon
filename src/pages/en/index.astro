                        </a>
                        <a href={`https://api.whatsapp.com/send?phone=905063717071&text=Hello, I am reaching out from your website, can I get information about Falcon Laser Hair Removal?`} target="_blank" rel="noopener" class="flex items-center gap-2 text-black/70 hover:text-primary transition-colors">
