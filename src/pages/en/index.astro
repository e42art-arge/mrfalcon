  { name: "Elif K.", branch: "Şişli", quote: "Painless and very fast, results are great. 95% hair gone in 6 sessions.", rating: 5, source: "Google" },
  { name: "Merve A.", branch: "Halkalı", quote: "Staff is very caring, environment is very hygienic. Recommended to my friends.", rating: 5, source: "Google" },
  { name: "Zeynep D.", branch: "Şişli", quote: "Falcon 4 Pro difference is truly felt. Safe even on my tanned skin.", rating: 5, source: "Google" },
