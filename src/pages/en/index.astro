---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";

const features = [
  { title: "4 Wavelengths", text: "755nm, 810nm, 940nm and 1064nm in one device; suitable for all skin types." },
  { title: "AI Control", text: "Analyzes skin type and automatically optimizes energy." },
  { title: "Cooling", text: "Sapphire cooling for a nearly painless session." },
  { title: "UVC Hygiene", text: "UVC disinfection of the handpiece before every session." },
];

const reviews = [
  { name: "Elif K.", branch: "Şişli", quote: "Painless and very fast, the results are amazing." },
  { name: "Merve A.", branch: "Halıkalı", quote: "Staff is caring and the place is very hygienic." },
  { name: "Zeynep D.", branch: "Şişli", quote: "The Falcon 4 Pro difference is truly felt." },
];
---

<BaseLayout
  title="Mr. Falcon Beauty — Painless Laser Hair Removal | Falcon 4 Pro"
  description="Painless, fast and permanent laser hair removal with Falcon 4 Pro technology. Expert team serving in Şişli and Halıkalı, Istanbul."
  locale="en"
  path="/en"
>
  <Header locale="en" />

  <main>
    <section class="relative overflow-hidden bg-gradient-to-b from-beige to-white">
      <div class="mx-auto max-w-6xl px-5 py-24 text-center md:py-32">
        <p class="mb-4 text-sm font-semibold uppercase tracking-[0.2em] text-champagne">Falcon 4 Pro Technology</p>
        <h1 class="mx-auto max-w-3xl font-display text-4xl font-semibold leading-tight text-ink md:text-6xl">
          The New Standard in Painless Laser Hair Removal
        </h1>
        <p class="mx-auto mt-6 max-w-2xl text-lg leading-relaxed text-ink/70">
          Meet four wavelengths, AI-powered control and sapphire cooling. The Mr. Falcon Beauty difference across both sides of Istanbul.
        </p>
        <div class="mt-10 flex flex-wrap items-center justify-center gap-4">
          <a href="/en/contact" class="rounded-full bg-ink px-7 py-3 font-semibold text-white transition-colors hover:bg-champagne">
            Book Now
          </a>
          <a href="/en/falcon-4-pro" class="rounded-full border border-ink/15 px-7 py-3 font-semibold text-ink transition-colors hover:border-champagne hover:text-champagne">
            Explore Tech
          </a>
        </div>
      </div>
    </section>

    <section class="bg-ink py-20 text-white">
      <div class="mx-auto max-w-6xl px-5">
        <h2 class="text-center font-display text-3xl font-semibold md:text-4xl">Why Falcon 4 Pro?</h2>
        <div class="mt-12 grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
          {features.map((f) => (
            <div class="rounded-2xl bg-white/5 p-6">
              <h3 class="font-display text-xl font-semibold text-champagne">{f.title}</h3>
              <p class="mt-3 text-sm leading-relaxed text-mist/75">{f.text}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="py-20">
      <div class="mx-auto max-w-6xl px-5">
        <h2 class="text-center font-display text-3xl font-semibold text-ink md:text-4xl">What Our Clients Say</h2>
        <div class="mt-12 grid gap-8 md:grid-cols-3">
          {reviews.map((r) => (
            <figure class="rounded-2xl border border-ink/10 p-7">
              <blockquote class="text-ink/80">"{r.quote}"</blockquote>
              <figcaption class="mt-4 text-sm font-semibold text-champagne">{r.name} · {r.branch}</figcaption>
            </figure>
          ))}
        </div>
        <div class="mt-10 text-center">
          <a href="/en/reviews" class="font-semibold text-ink underline-offset-4 hover:text-champagne hover:underline">
            See all reviews →
          </a>
        </div>
      </div>
    </section>

    <section class="bg-beige py-20">
      <div class="mx-auto max-w-3xl px-5 text-center">
        <h2 class="font-display text-3xl font-semibold text-ink md:text-4xl">Book Your Appointment</h2>
        <p class="mt-4 text-ink/70">Your first consultation is free at our Şişli or Halıkalı clinic.</p>
        <a href="/en/contact" class="mt-8 inline-block rounded-full bg-ink px-8 py-3 font-semibold text-white transition-colors hover:bg-champagne">
          Get in Touch
        </a>
      </div>
    </section>
  </main>

  <Footer locale="en" />
</BaseLayout>
