  { label: "Pulse Duration", value: "5-400 ms (optimized for fine/thick hair)" },
  { label: "Hygiene", value: "UVC LED disinfection + single-use handpiece cap" },
  { label: "Screen", value: "15.6\" touch, AI skin analysis integrated" },
