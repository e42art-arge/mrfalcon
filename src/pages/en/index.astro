const galleryImages = [
  { src: "/images/clinic/clinic1.jpg", alt: "Şişli Branch Reception", location: "Şişli" },
  { src: "/images/clinic/clinic2.jpg", alt: "Şişli Branch Treatment Room", location: "Şişli" },
  { src: "/images/clinic/clinic3.jpg", alt: "Halkalı Branch Entrance", location: "Halkalı" },
  { src: "/images/clinic/clinic4.jpg", alt: "Halkalı Branch Waiting Area", location: "Halkalı" },
