  { icon: "⚡", text: "Falcon 4 Pro" },
];

const clinics = [
  { id: "sisli", name: "Şişli / Mecidiyeköy", address: "Mecidiyeköy Mah. Büyükdere Cad. No:123" },
  { id: "halkali", name: "Halkalı / Küçükçekmece", address: "Halkalı Merkez Mah. İstiklal Cad. No:45" },
];

const aboutMetrics = [
  { value: "15,000+", label: "Happy Clients" },
  { value: "4.9/5", label: "Google Rating" },
  { value: "2", label: "Istanbul Branches" },
  { value: "10+", label: "Years Experience" },
];

