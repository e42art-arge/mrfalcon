---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import VideoGallery from "../../components/VideoGallery.astro";
import PressSlider from "../../components/PressSlider.astro";
import FaqAccordion from "../../components/FaqAccordion.astro";
import ReviewCard from "../../components/ReviewCard.astro";
import ClinicCard from "../../components/ClinicCard.astro";
import BranchMap from "../../components/BranchMap.astro";
import StatGrid from "../../components/StatGrid.astro";
import BookingCta from "../../components/BookingCta.astro";
import Icon from "../../components/Icon.astro";
import SectionHeader from "../../components/SectionHeader.astro";
import InfoCard from "../../components/InfoCard.astro";
import StepCard from "../../components/StepCard.astro";
import AppointmentForm from "../../components/AppointmentForm.astro";
import { reviews } from "../../data/reviews";
import { getCollection } from "astro:content";
import { trustSignals } from "../../data/trustSignals";
import { siteMetrics } from "../../data/siteMetrics";
import { processSteps } from "../../data/processSteps";
import { falconTechSpecs } from "../../data/falconTechSpecs";
import { whyUsItems } from "../../data/whyUsItems";
import { clinicGallery } from "../../data/clinicGallery";
import { satisfactionVideos, pressVideos } from "../../data/videos";

const branches = (await getCollection("branches")).sort((a, b) => a.data.slug.localeCompare(b.data.slug));
const faqEntries = (await getCollection("faq", (e) => e.id.startsWith("en/"))).sort((a, b) => a.data.order - b.data.order);
const faqs = faqEntries.map((e) => ({ q: e.data.question, a: e.data.answer }));

const laserScience = [
  { icon: "target", title: "Selective Photothermolysis", desc: "Laser light is absorbed by melanocytes to heat the hair follicle, protecting surrounding tissues." },
  { icon: "microscope", title: "Targeting Anagen Phase", desc: "Since only hair in growth phase (anagen) is affected, multiple sessions are required." },
  { icon: "color-swatch", title: "4 Wavelength Advantage", desc: "755nm (fine/dark hair), 808nm (speed), 940nm (depth), 1064nm (tanned skin) - all in one." },
  { icon: "bot", title: "AI Energy Optimization", desc: "Device scans skin type (Fitzpatrick I-VI), measures hair thickness, auto-sets joule/ms/Hz." },
  { icon: "snowflake", title: "Sapphire Contact Cooling", desc: "-20°C tip temperature protects epidermis, targets dermis. Pain signals are blocked." },
  { icon: "shield", title: "Safety Protocols", desc: "Test shot mandatory, goggles mandatory, UVC disinfection, single-use cap, skin cooling gel." },
];
---

<BaseLayout
  title="Mr. Falcon Beauty | Laser Hair Removal Center Mecidiyeköy & Halkalı & Küçükçekmece"
  description="Painless, fast and permanent laser hair removal with Falcon 4 Pro technology. Expert team in Istanbul Şişli/Mecidiyeköy and Halkalı/Küçükçekmece branches. Free first consultation."
  locale="en"
  path="/en"
>
  <Header locale="en" />

  <main>
    <!-- HERO SECTION -->
    <section id="hero" class="relative overflow-hidden bg-gradient-to-b from-sky-light to-white" data-hero>
      <div class="pointer-events-none absolute inset-0 overflow-hidden" aria-hidden="true">
        <div class="absolute top-1/4 left-1/4 w-[300px] h-[300px] md:w-[600px] md:h-[600px] bg-primary/10 rounded-full blur-3xl animate-blob-slow" style="animation-duration: 20s;"></div>
        <div class="absolute bottom-1/4 right-1/4 w-[250px] h-[250px] md:w-[500px] md:h-[500px] bg-sky/10 rounded-full blur-3xl animate-blob-slow" style="animation-duration: 25s; animation-delay: -5s;"></div>
        <div id="hero-particles" class="absolute inset-0"></div>
      </div>

      <div class="border-b border-black/5 bg-white/50 backdrop-blur sticky top-16 z-40" data-animate="trust-bar" data-gsap-trigger="trust-bar">
        <div class="mx-auto flex max-w-7xl items-center justify-center gap-4 px-5 py-3 text-sm font-medium text-black/70 md:py-2">
          <div class="flex flex-wrap items-center justify-center gap-3 text-xs md:gap-6 md:text-sm" data-gsap="stagger" data-gsap-delay="0.1">
            {trustSignals.en.map((t) => (
              <span class="flex items-center gap-1.5 text-primary"><Icon name={t.icon} class="w-4 h-4" /> <strong>{t.text}</strong></span>
            ))}
          </div>
        </div>
      </div>

      <div class="mx-auto max-w-7xl px-5 py-20 md:py-28 lg:py-32 relative z-10">
        <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
          <div class="text-center lg:text-left" data-hero-content>
            <p class="mb-6 text-sm font-semibold uppercase tracking-[0.25em] text-primary" data-gsap="fadeUp" data-gsap-delay="0.1">
              Falcon 4 Pro Technology
            </p>

            <h1 class="mb-8 font-display text-4xl font-semibold leading-tight text-black md:text-6xl lg:text-7xl xl:text-8xl" data-gsap-split="lines" data-gsap="splitLines" data-gsap-delay="0.2">
              Laser Hair Removal's
              <br />
              <span class="text-primary relative">New Standard</span>
            </h1>

            <p class="mb-10 max-w-xl text-lg leading-relaxed text-black/70 mx-auto lg:mx-0" data-gsap="fadeUp" data-gsap-delay="0.4">
              Four wavelengths, AI-controlled precision and -20°C sapphire cooling.
              The Mr. Falcon Beauty difference across both sides of Istanbul.
            </p>

            <div class="flex flex-col sm:flex-row items-stretch sm:items-center justify-center gap-4 lg:justify-start mb-10" data-gsap="stagger" data-gsap-delay="0.5">
              <a
                href="#contacts"
                class="group relative text-center rounded-full bg-navy px-8 py-3.5 font-semibold text-white transition-all duration-300 hover:bg-primary hover:shadow-[0_20px_40px_-12px_rgba(14,116,144,0.4)]"
                data-hover="scale"
                data-gsap="fadeUp"
              >
                <span class="relative z-10">Free Analysis & Booking</span>
                <span class="absolute inset-0 rounded-full bg-primary/20 opacity-0 group-hover:opacity-100 transition-opacity duration-300 blur-xl" aria-hidden="true"></span>
              </a>
              <a
                href="#falcon-4-pro"
                class="group relative text-center rounded-full border-2 border-black/15 px-8 py-3.5 font-semibold text-black transition-all duration-300 hover:border-primary hover:text-primary hover:bg-primary/5"
                data-hover="scale"
                data-gsap="fadeUp"
              >
                <span class="relative z-10">Explore Technology</span>
                <svg class="absolute left-0 top-1/2 -translate-y-1/2 w-5 h-5 text-black/40 group-hover:translate-x-1 group-hover:text-primary transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
                </svg>
              </a>
            </div>

            <div class="flex flex-wrap items-center justify-center gap-3 md:gap-6 lg:justify-start" data-gsap="stagger" data-gsap-delay="0.6">
              <div class="flex items-center gap-2 text-sm text-black/60" data-gsap="fadeUp">
                <svg class="w-4 h-4 text-primary flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                <span>Free first consultation</span>
              </div>
              <div class="flex items-center gap-2 text-sm text-black/60" data-gsap="fadeUp">
                <svg class="w-4 h-4 text-primary flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                <span>Skin & hair analysis included</span>
              </div>
              <div class="flex items-center gap-2 text-sm text-black/60" data-gsap="fadeUp">
                <svg class="w-4 h-4 text-primary flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                <span>Test shot applied</span>
              </div>
            </div>

            <div class="mt-16 flex flex-col items-center lg:items-start" data-gsap="fadeUp" data-gsap-delay="0.8">
              <p class="mb-2 text-xs uppercase tracking-wider text-black/40">Scroll to explore</p>
              <div class="relative w-6 h-10 rounded-full border border-black/15 flex items-center justify-center">
                <div class="w-1.5 h-1.5 rounded-full bg-primary animate-bounce" style="animation-duration: 1.5s;"></div>
              </div>
            </div>
          </div>

          <div class="relative" data-hero-visual>
            <div class="relative rounded-3xl overflow-hidden shadow-2xl bg-navy/5" data-gsap="parallax" data-gsap-speed="0.3">
              <img
                src="/images/sliderdoctor.png"
                alt="Falcon 4 Pro device and Mr. Falcon Beauty clinic environment"
                class="w-full object-cover transition-transform duration-1000 ease-out"
                loading="eager"
                data-gsap="reveal"
              />

              <div class="absolute top-6 right-6 hidden md:flex flex-col gap-3" data-gsap="stagger" data-gsap-delay="0.3">
                {[
                  { icon: "target", text: "4 Wavelengths" },
                  { icon: "bot", text: "AI Control" },
                  { icon: "snowflake", text: "-20°C Cooling" },
                  { icon: "shield", text: "UVC Hygiene" },
                ].map((badge) => (
                  <div class="group relative px-4 py-3 bg-white/90 backdrop-blur rounded-xl shadow-lg border border-black/5 transition-all duration-300 hover:shadow-xl hover:-translate-x-1 hover:border-primary/30" data-gsap="fadeRight">
                    <div class="flex items-center gap-2">
                      <Icon name={badge.icon} class="w-5 h-5" />
                      <span class="font-semibold text-black text-sm">{badge.text}</span>
                    </div>
                    <div class="absolute bottom-0 left-0 right-0 h-0.5 bg-primary origin-left group-hover:origin-right scale-x-0 group-hover:scale-x-100 transition-transform duration-300" aria-hidden="true"></div>
                  </div>
                ))}
              </div>
            </div>

            <div class="absolute -top-12 -right-12 w-32 h-32 border-t-2 border-r-2 border-primary/20 rounded-tr-3xl opacity-50" aria-hidden="true"></div>
            <div class="absolute -bottom-12 -left-12 w-32 h-32 border-b-2 border-l-2 border-primary/20 rounded-bl-3xl opacity-50" aria-hidden="true"></div>

            <div class="mt-6 flex md:hidden flex-wrap justify-center gap-2" data-gsap="stagger" data-gsap-delay="0.3">
                {[
                  { icon: "target", text: "4 Wavelengths" },
                  { icon: "bot", text: "AI Control" },
                  { icon: "snowflake", text: "-20°C Cooling" },
                  { icon: "shield", text: "UVC Hygiene" },
                ].map((badge) => (
                  <span class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-white/90 backdrop-blur rounded-full text-xs font-medium text-black border border-black/10">
                    <Icon name={badge.icon} class="w-3.5 h-3.5 text-primary" />
                    {badge.text}
                  </span>
                ))}
              </div>

            <div class="absolute -bottom-6 left-1/2 -translate-x-1/2 md:left-auto md:-translate-x-0 md:-bottom-8 md:-left-8 p-4 md:p-8 bg-white/95 backdrop-blur rounded-2xl shadow-2xl max-w-[calc(100%-2rem)] md:max-w-xs border border-black/5 z-20" data-gsap="float" data-gsap-delay="0.5">
              <div class="flex items-center gap-3 text-primary text-2xl font-display font-bold">
                <span class="animate-pulse" style="animation-duration: 2s;">⭐</span>
                <span data-gsap="counter" data-target="5.0" data-decimals="1" data-suffix="" data-prefix="" data-duration="2">5.0</span>
              </div>
              <p class="mt-1 text-sm text-black/70">from 58+ Google reviews</p>
              <div class="mt-4 flex flex-wrap items-center gap-3 text-xs text-black/60">
                <span class="flex items-center gap-1 px-2 py-1 bg-green-50 text-green-700 rounded-full">✓ FDA/CE Cleared</span>
                <span class="flex items-center gap-1 px-2 py-1 bg-blue-50 text-blue-700 rounded-full">✓ 95%+ Success</span>
                <span class="flex items-center gap-1 px-2 py-1 bg-purple-50 text-purple-700 rounded-full">✓ Warranty Package</span>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="absolute bottom-0 left-0 right-0 overflow-hidden" aria-hidden="true">
        <svg class="w-full h-16 md:h-24" viewBox="0 0 1440 120" preserveAspectRatio="none">
          <path
            fill="url(#heroWaveGradient)"
            fill-opacity="0.1"
            d="M0,64 C300,120 600,0 900,64 C1200,128 1440,64 1440,64 L1440,120 L0,120 Z"
          />
          <defs>
            <linearGradient id="heroWaveGradient" x1="0%" y1="0%" x2="100%" y2="100%">
              <stop offset="0%" stop-color="#17468A" />
              <stop offset="100%" stop-color="#17468A" stop-opacity="0" />
            </linearGradient>
          </defs>
        </svg>
      </div>
    </section>

    <!-- ABOUT US -->
    <section id="about-us" class="py-20 bg-white">
      <div class="mx-auto max-w-6xl px-5">
        <div class="grid lg:grid-cols-2 gap-12 items-center">
          <div>
            <p class="mb-2 text-sm font-semibold uppercase tracking-[0.2em] text-primary">Mr. Falcon Beauty</p>
            <h2 class="mb-6 font-display text-3xl font-semibold text-black md:text-4xl lg:text-5xl">
              Istanbul's Trusted Laser Hair Removal Clinic
            </h2>
            <p class="mb-6 text-lg leading-relaxed text-black/70">
              Since 2014, we've served 15,000+ clients across our Şişli/Mecidiyeköy and Halkalı/Küçükçekmece branches
              with safe, effective and hygienic laser hair removal. With Falcon 4 Pro technology we set a new standard:
              AI-controlled, 4-wavelength, cooled.
            </p>
            <div class="mb-8">
              <StatGrid items={siteMetrics.en} class="grid-cols-2 lg:grid-cols-2 gap-6" />
            </div>
            <a href="#falcon-4-pro" class="inline-flex items-center gap-2 font-semibold text-primary hover:text-black transition-colors">
              Falcon 4 Pro Technology →
            </a>
          </div>

          <div class="relative rounded-3xl overflow-hidden">
            <img
              src="/images/homeabout.png"
              alt="Interior view of Mr. Falcon Beauty Şişli branch"
              class="w-full"
            />
            <div class="absolute bottom-0 left-0 right-0 p-6 md:p-8 bg-gradient-to-t from-navy/90 to-transparent text-white">
              <div class="flex items-center gap-3 text-primary text-xl font-display font-bold"><Icon name="award" class="w-7 h-7" /></div>
              <p class="mt-2 text-lg font-medium">First Falcon 4 Pro Clinic in Turkey</p>
              <p class="mt-1 text-sm text-white/80">Leading in Istanbul since 2024</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- LASER HAIR REMOVAL INFO -->
    <section id="lazer-epilasyon" class="py-20 bg-sky-light/30">
      <div class="mx-auto max-w-6xl px-5">
        <SectionHeader label="What is Laser Hair Removal?" title="The Science of Permanent Hair Reduction &amp; Falcon 4 Pro" />

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          {laserScience.map((item) => (
            <InfoCard icon={item.icon} title={item.title} description={item.desc} />
          ))}
        </div>
      </div>
    </section>

    <!-- SATISFACTION VIDEOS -->
    <VideoGallery videos={satisfactionVideos.en} sectionId="satisfaction-videos" class="bg-sky-light/30" locale="en" />

    <!-- PRESS -->
    <PressSlider videos={pressVideos} locale="en" />

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@fancyapps/ui@5.0/dist/fancybox/fancybox.css" />
    <script type="module">
      import { Fancybox } from "https://cdn.jsdelivr.net/npm/@fancyapps/ui@5.0/dist/fancybox/fancybox.esm.js";
      Fancybox.bind('[data-fancybox="press-videos"]', {
        type: "video",
        video: { autoStart: true },
        Toolbar: { display: ["close"] },
        mainClass: "fancybox-press"
      });
    </script>

    <!-- FALCON 4 PRO TECH -->
    <section id="falcon-4-pro" class="py-20 bg-navy text-white">
      <div class="mx-auto max-w-6xl px-5">
        <SectionHeader label="Technology" title="Falcon 4 Pro — 4 Wavelengths, 1 Device" variant="dark" margin="md" />

        <div class="grid lg:grid-cols-2 gap-12 items-start">
          <div class="relative rounded-2xl overflow-hidden aspect-[4/3] bg-white/5 flex items-center justify-center">
            <img
              src="/images/falcons.png"
              alt="Falcon 4 Pro device front view"
              class="w-full h-full object-contain"
            />
          </div>

          <div>
            <h3 class="font-display text-2xl font-semibold text-primary mb-6">Technical Details</h3>
            <dl class="space-y-4 text-sm">
              {falconTechSpecs.en.map((s) => (
                <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between py-3 border-b border-white/10">
                  <dt class="font-medium text-white">{s.label}</dt>
                  <dd class="mt-1 sm:mt-0 text-white font-mono text-xs sm:text-sm">{s.value}</dd>
                </div>
              ))}
            </dl>

            <div class="mt-8 grid sm:grid-cols-2 gap-4">
              {[
                { icon: "target", title: "Alexandrite 755nm", desc: "Gold standard for fine, dark hair. High melanin absorption." },
                { icon: "zap", title: "Diode 808nm", desc: "Balance of speed and depth. Efficient on large body areas." },
                { icon: "microscope", title: "Diode 940nm", desc: "Reaching deep follicles, long wavelength protecting vessels." },
                { icon: "sun", title: "Nd:YAG 1064nm", desc: "Safe standard for tanned/dark skin (Fitzpatrick IV-VI)." },
              ].map((w) => (
                <InfoCard icon={w.icon} title={w.title} description={w.desc} variant="dark-navy" />
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- WHY US -->
    <section id="why-us" class="py-20 bg-white">
      <div class="mx-auto max-w-6xl px-5">
        <SectionHeader label="Why Us?" title="Mr. Falcon Beauty Difference" />

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          {whyUsItems.en.map((item) => (
            <InfoCard icon={item.icon} title={item.title} description={item.desc} variant="hover-border" />
          ))}
        </div>
      </div>
    </section>

    <!-- 7-STEP PROCESS -->
    <section id="process" class="py-20 bg-sky-light/30">
      <div class="mx-auto max-w-6xl px-5">
        <SectionHeader label="Process" title="Safe Laser Hair Removal in 7 Steps" />

        <div class="space-y-6">
          {processSteps.home.en.map((step) => (
            <StepCard step={step.step} title={step.title} description={step.desc} />
          ))}
        </div>

        <div class="mt-12 grid md:grid-cols-3 gap-6 text-center">
          {[
            { value: "6-8", label: "Average Sessions" },
            { value: "15-20min", label: "Body Session Time" },
            { value: "95%+", label: "Hair Reduction Target" },
          ].map((m) => (
            <div class="rounded-2xl bg-white p-6 border border-black/5">
              <div class="font-display text-3xl font-bold text-black md:text-4xl">{m.value}</div>
              <div class="text-sm text-black/60">{m.label}</div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- VERIFIED REVIEWS (9) -->
    <section id="comments" class="py-20 bg-white">
      <div class="mx-auto max-w-6xl px-5">
        <SectionHeader label="Real Clients" title="What Our Clients Say" description="All reviews are from verified real clients via Google Maps." margin="md" />

        <div class="columns-1 gap-6 sm:columns-2 lg:columns-3">
          {reviews.slice(0, 9).map((r) => (
            <ReviewCard review={r} locale="en" />
          ))}
        </div>

        <div class="mt-10 text-center">
          <a href="/en/reviews" class="font-semibold text-black underline-offset-4 hover:text-primary hover:underline">
            See all Google reviews (58+) →
          </a>
        </div>
      </div>
    </section>

    <!-- GALLERY -->
    <section id="gallery" class="py-20 bg-sky-light/30">
      <div class="mx-auto max-w-6xl px-5">
        <SectionHeader label="Our Clinics" title="Mr. Falcon Beauty Branches" margin="md" />

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
          {clinicGallery.slice(0, 6).map((img, i) => (
            <article class="relative rounded-2xl overflow-hidden group cursor-pointer aspect-[4/3]" data-gallery-item>
              <img
                src={img.src}
                alt={img.alt}
                class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105 group-[.is-active]:scale-105"
                loading={i < 3 ? "eager" : "lazy"}
              />
              <div class="absolute inset-0 bg-gradient-to-t from-navy/80 to-transparent opacity-0 group-hover:opacity-100 group-[.is-active]:opacity-100 transition-opacity duration-300 flex items-end p-4">
                <div>
                  <p class="text-white font-semibold">{img.alt}</p>
                  <p class="text-xs text-primary">{img.location}</p>
                </div>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <script>
      document.querySelectorAll("[data-gallery-item]").forEach((el) => {
        el.addEventListener("click", () => {
          document.querySelectorAll("[data-gallery-item].is-active").forEach((a) => {
            if (a !== el) a.classList.remove("is-active");
          });
          el.classList.toggle("is-active");
        });
        document.addEventListener("click", (e) => {
          if (!el.contains(e.target)) el.classList.remove("is-active");
        });
      });
    </script>

    <!-- CONTACT / APPOINTMENT FORM -->
    <section id="contacts" class="py-20 bg-white">
      <div class="mx-auto max-w-6xl px-5">
        <div class="grid lg:grid-cols-2 gap-12">
          <AppointmentForm locale="en" branches={branches} turnstileEnabled={true} siteKey="0x4AAAAAAAe3UYEAyXZ5Iqy4vEMqCLYzNB8" />

          <div class="space-y-8">
            <BranchMap branch={branches[1].data} />
            <div class="grid sm:grid-cols-2 gap-6">
              {branches.map((b) => <ClinicCard branch={b.data} />)}
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ ACCORDION -->
    <section id="faq" class="py-20 bg-navy text-white">
      <div class="mx-auto max-w-3xl px-5">
        <SectionHeader label="Frequently Asked Questions" title="FAQ — Everything About Laser Hair Removal" variant="dark" margin="md" />

        <FaqAccordion items={faqs} tone="dark" />

        <p class="mt-10 text-center text-sm text-white/60">
          Not in the list? <a href="https://wa.me/905525939890" target="_blank" rel="noopener" class="text-primary hover:underline">Ask on WhatsApp</a>
        </p>
      </div>
    </section>

    <BookingCta locale="en" />
  </main>

  <Footer locale="en" />
</BaseLayout>
