      <Footer locale="en" />

      <script is:inline>
        // FAQ Accordion
        document.querySelectorAll('#faq-accordion button').forEach(btn => {
          btn.addEventListener('click', () => {
            const dd = btn.nextElementSibling;
            const isOpen = !dd.hidden;
            dd.hidden = isOpen;
            dd.classList.toggle('hidden', isOpen);
            btn.setAttribute('aria-expanded', !isOpen);
            btn.querySelector('svg')?.classList.toggle('rotate-180', !isOpen);
          });
        });

        // Form submit via fetch
        document.getElementById('appointment-form')?.addEventListener('submit', async (e) => {
          e.preventDefault();
          const form = e.target;
          const msgEl = document.getElementById('form-message');
          const btn = form.querySelector('button[type="submit"]');
          const originalText = btn.textContent;
          btn.disabled = true;
          btn.textContent = 'Sending...';
          msgEl.classList.add('hidden');

          try {
            const formData = new FormData(form);
            const res = await fetch('/api/contact', {
              method: 'POST',
              body: formData,
            });
            const data = await res.json();
            if (res.ok && data.success) {
              msgEl.textContent = '✅ Appointment request received! We will get back to you within 15 min.';
              msgEl.className = 'text-green-700';
              form.reset();
            } else {
              throw new Error(data.message || 'An error occurred');
            }
          } catch (err) {
            msgEl.textContent = '❌ ' + (err.message || 'Submission failed, please message on WhatsApp.');
            msgEl.className = 'text-red-700';
          } finally {
            msgEl.classList.remove('hidden');
            btn.disabled = false;
            btn.textContent = originalText;
          }
        });

        // Clinic selector from URL
        const urlParams = new URLSearchParams(window.location.search);
        const clinicParam = urlParams.get('clinic');
        if (clinicParam) {
          const select = document.getElementById('clinic');
          if (select) select.value = clinicParam;
          const heroSelect = document.getElementById('hero-clinic-select');
          if (heroSelect) heroSelect.value = `/en/#contacts?clinic=${clinicParam}`;
        }
      </script>
    </BaseLayout>