  { name: "Ceren K.", branch: "Şişli", quote: "Appointment reminders, follow-up messages... Customer focus is felt.", rating: 5, source: "Google" },
  { name: "Derya M.", branch: "Halkalı", quote: "Value for money is very good. Got a package, per session price is very affordable.", rating: 5, source: "Google" },
  { name: "Gizem S.", branch: "Şişli", quote: "Separate areas for men and women, privacy is great. Highly recommend.", rating: 5, source: "Google" },
