  { id: 9, thumbnail: "/images/shorts/shorts9.jpg", videoUrl: "/videos/shorts/shorts9.mp4", title: "Frequently Asked Questions", description: "Falcon 4 Pro & Laser Hair Removal" },
  { id: 10, thumbnail: "/images/shorts/shorts10.jpg", videoUrl: "/videos/shorts/shorts10.mp4", title: "Frequently Asked Questions", description: "Falcon 4 Pro & Laser Hair Removal" },
  { id: 11, thumbnail: "/images/shorts/shorts11.jpg", videoUrl: "/videos/shorts/shorts11.mp4", title: "Frequently Asked Questions", description: "Falcon 4 Pro & Laser Hair Removal" },
  { id: 12, thumbnail: "/images/shorts/shorts12.jpg", videoUrl: "/videos/shorts/shorts12.mp4", title: "Frequently Asked Questions", description: "Falcon 4 Pro & Laser Hair Removal" },
];

const whyUsItems = [
  { icon: "🎓", title: "Expert Staff", desc: "Applied by certified laser technicians under supervision of dermatology and medical aesthetic doctors." },
  { icon: "🔬", title: "FDA/CE Approved", desc: "Falcon 4 Pro device is FDA and CE certified, medical grade (Class IIb)." },
  { icon: "📊", title: "Transparent Process", desc: "Photo tracking before/after, hair count report and energy parameters shared every session." },
  { icon: "🛡️", title: "Warranty Package", desc: "Free control session until year end if you get a package. Money back guarantee if no results." },
  { icon: "📍", title: "Two Easy Locations", desc: "Mecidiyeköy (Şişli) and Halkalı (Küçükçekmece) - Easy access by Metro, Metrobus, Bus." },
  { icon: "💬", title: "24/7 Support", desc: "Instant response via WhatsApp for post-session follow-up, booking changes and questions." },
];

---

<BaseLayout
  title="Mr. Falcon Beauty | Laser Hair Removal Center Mecidiyeköy & Halkalı & Küçükçekmece"
  description="Painless, fast and permanent laser hair removal with Falcon 4 Pro technology. Expert team in Istanbul Şişli/Mecidiyeköy and Halkalı/Küçükçekmece branches. Free first consultation."
  locale="en"
  path="/en"
>
  <Header locale="en" />

  <main>
    <!-- HERO / SLIDER -->
    <section id="slider" class="relative overflow-hidden bg-gradient-to-b from-beige to-white">
      <!-- Trust Signals Bar -->
      <div class="border-b border-black/5 bg-white/50 backdrop-blur sticky top-16 z-40">
        <div class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-5 py-3 text-sm font-medium text-black/70 md:py-2">
          <div class="flex flex-wrap items-center gap-6 text-center md:justify-start">
            {trustSignals.map((t) => (
              <span class="flex items-center gap-1.5 text-primary">{t.icon} <strong>{t.text}</strong></span>
            ))}
          </div>
          <div class="flex items-center gap-2 text-xs text-black/50">
            <span>📍 Select Branch:</span>
            <select id="hero-clinic-select" class="rounded border border-black/15 bg-white px-2 py-1 text-sm text-black focus:border-primary focus:outline-none">
              <option value="/en/#contacts" selected>Choose Branch</option>
              {clinics.map((c) => (
                <option value={`/en/#contacts?clinic=${c.id}`}>{c.name}</option>
              ))}
            </select>
          </div>
        </div>
      </div>

      <div class="mx-auto max-w-6xl px-5 py-24 md:py-32">
        <div class="grid lg:grid-cols-2 gap-12 items-center">
          <div class="text-center lg:text-left">
            <p class="mb-4 text-sm font-semibold uppercase tracking-[0.2em] text-primary">Falcon 4 Pro Technology</p>
            <h1 class="mb-6 font-display text-4xl font-semibold leading-tight text-black md:text-6xl lg:text-7xl">
              The New Standard in
              <br />
              <span class="text-primary">Painless Laser Removal</span>
            </h1>
            <p class="mb-8 max-w-xl text-lg leading-relaxed text-black/70 mx-auto lg:mx-0">
              Meet four wavelengths, AI-powered control and -10°C sapphire cooling.
              The Mr. Falcon Beauty difference across both sides of Istanbul.
            </p>
            <div class="flex flex-wrap items-center justify-center gap-4 lg:justify-start">
              <a href="#contacts" class="rounded-full bg-navy px-8 py-3 font-semibold text-white transition-colors hover:bg-primary">
                Free Analysis & Booking
              </a>
              <a href="#falcon-4-pro" class="rounded-full border-2 border-black/15 px-8 py-3 font-semibold text-black transition-colors hover:border-primary hover:text-primary">
                Explore Technology
              </a>
            </div>
            <p class="mt-6 flex items-center justify-center gap-4 text-sm text-black/60 lg:justify-start">
              <span class="flex items-center gap-1.5">✓ Free first consultation</span>
              <span class="flex items-center gap-1.5">✓ Skin & hair analysis included</span>
              <span class="flex items-center gap-1.5">✓ Test shot performed</span>
            </p>
          </div>

          <div class="relative">
            <div class="relative rounded-3xl overflow-hidden shadow-2xl bg-navy/5">
              <img
                src="/images/sliderdoctor.png"
                alt="Falcon 4 Pro device and Mr. Falcon Beauty clinic environment"
                class="w-full"
                loading="eager"
              />
              <div class="absolute -bottom-6 -left-6 md:-bottom-8 md:-left-8 p-6 md:p-8 bg-white rounded-2xl shadow-xl max-w-xs">
                <div class="flex items-center gap-3 text-primary text-2xl font-display font-bold">⭐ 4.9</div>
                <p class="mt-1 text-sm text-black/70">On Google with 200+ reviews</p>
                <div class="mt-4 flex items-center gap-4 text-xs text-black/60">
                  <span class="flex items-center gap-1">✓ FDA/CE Approved</span>
                  <span class="flex items-center gap-1">✓ 95%+ Success</span>
                  <span class="flex items-center gap-1">✓ Warranty Package</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ABOUT US / MR FALCON BEAUTY -->
    <section id="about-us" class="py-20 bg-white">
      <div class="mx-auto max-w-6xl px-5">
        <div class="grid lg:grid-cols-2 gap-12 items-center">
          <div>
            <p class="mb-2 text-sm font-semibold uppercase tracking-[0.2em] text-primary">Mr. Falcon Beauty</p>
            <h2 class="mb-6 font-display text-3xl font-semibold text-black md:text-4xl lg:text-5xl">
              Istanbul's Trusted Laser Hair Removal Center
            </h2>
            <p class="mb-6 text-lg leading-relaxed text-black/70">
              Since 2014, we have served over 15,000 clients in our Şişli/Mecidiyeköy and Halkalı/Küçükçekmece branches with 
              safe, effective and hygienic laser hair removal. With Falcon 4 Pro technology, we removed pain, side effects 
              and uncertainty by setting the new standard: "AI controlled, 4 wavelengths, cooled".
            </p>
            <div class="grid grid-cols-2 gap-6 mb-8">
              {aboutMetrics.map((m) => (
                <div class="p-4 rounded-2xl bg-sky-light/50">
                  <div class="font-display text-3xl font-bold text-black md:text-4xl">{m.value}</div>
                  <div class="text-sm text-black/60">{m.label}</div>
                </div>
              ))}
            </div>
            <a href="#falcon-4-pro" class="inline-flex items-center gap-2 font-semibold text-primary hover:text-black transition-colors">
              Falcon 4 Pro Technology →
            </a>
          </div>

          <div class="relative rounded-3xl overflow-hidden">
            <img
              src="/images/homeabout.png"
              alt="Interior view of Mr. Falcon Beauty Şişli branch"
              class="w-full"
            />
            <div class="absolute bottom-0 left-0 right-0 p-6 md:p-8 bg-gradient-to-t from-ink/90 to-transparent text-white">
              <div class="flex items-center gap-3 text-primary text-xl font-display font-bold">🏆</div>
              <p class="mt-2 text-lg font-medium">First Falcon 4 Pro Clinic in Turkey</p>
              <p class="mt-1 text-sm text-white/80">Leading in Istanbul since 2024</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- LASER HAIR REMOVAL INFO -->
    <section id="lazer-epilasyon" class="py-20 bg-sky-light/30">
      <div class="mx-auto max-w-6xl px-5">
        <div class="text-center max-w-3xl mx-auto mb-16">
          <p class="mb-2 text-sm font-semibold uppercase tracking-[0.2em] text-primary">What is Laser Hair Removal?</p>
          <h2 class="font-display text-3xl font-semibold text-black md:text-4xl">
            The Science of Permanent Hair Reduction & Falcon 4 Pro
          </h2>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          {[
            { icon: "🎯", title: "Selective Photothermolysis", desc: "Laser light is absorbed by melanocytes to heat the hair follicle, protecting surrounding tissues." },
            { icon: "🔬", title: "Targeting Anagen Phase", desc: "Since only hair in growth phase (anagen) is affected, multiple sessions are required." },
            { icon: "🌈", title: "4 Wavelength Advantage", desc: "755nm (fine/dark hair), 810nm (speed), 940nm (depth), 1064nm (tanned skin) - all in one." },
            { icon: "🤖", title: "AI Energy Optimization", desc: "Device scans skin type (Fitzpatrick I-VI), measures hair thickness, auto-sets joule/ms/Hz." },
            { icon: "❄️", title: "Sapphire Contact Cooling", desc: "-10°C tip temperature protects epidermis, targets dermis. Pain signals are blocked." },
            { icon: "🛡️", title: "Safety Protocols", desc: "Test shot mandatory, goggles mandatory, UVC disinfection, single-use cap, skin cooling gel." },
          ].map((item) => (
            <div class="rounded-2xl bg-white p-6 shadow-sm border border-black/5 hover:shadow-md transition-shadow">
              <div class="text-3xl">{item.icon}</div>
              <h3 class="mt-4 font-display text-xl font-semibold text-black">{item.title}</h3>
              <p class="mt-2 text-sm leading-relaxed text-black/70">{item.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- VIDEO GALLERY / TESTIMONIALS → replaced with static testimonial cards -->
    <section id="video-gallery" class="py-20 bg-white">
      <div class="mx-auto max-w-6xl px-5">
        <div class="text-center max-w-3xl mx-auto mb-12">
          <p class="mb-2 text-sm font-semibold uppercase tracking-[0.2em] text-primary">Real Clients</p>
          <h2 class="font-display text-3xl font-semibold text-black md:text-4xl">What Our Clients Say</h2>
        </div>

        <div class="grid md:grid-cols-3 gap-8">
          {videoTestimonials.map((v) => (
            <article class="rounded-2xl border border-black/10 bg-white p-6 shadow-sm hover:shadow-md transition-shadow">
              <div class="flex gap-1 text-primary text-sm mb-3">★★★★★</div>
              <blockquote class="text-black/80 text-sm leading-relaxed">"{v.quote}"</blockquote>
              <footer class="mt-4 flex items-center justify-between text-sm">
                <cite class="font-semibold text-primary">{v.name}</cite>
                <span class="text-black/50">{v.branch}</span>
              </footer>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- SATISFACTION VIDEOS (Client Videos) -->
    <VideoGallery videos={satisfactionVideos} sectionId="satisfaction-videos" class="bg-sky-light/30" />

    <!-- PRESS (News Videos Slider) -->
    <PressSlider videos={pressVideos} locale="en" />

    <!-- VIDEO GALLERY (FAQ Videos) -->
    <VideoGallery videos={faqVideos} sectionId="video-gallery" />

    <!-- FALCON 4 PRO TECH DEEP DIVE -->
    <section id="falcon-4-pro" class="py-20 bg-navy text-white">
      <div class="mx-auto max-w-6xl px-5">
        <div class="text-center max-w-3xl mx-auto mb-12">
          <p class="mb-2 text-sm font-semibold uppercase tracking-[0.2em] text-primary">Technology</p>
          <h2 class="font-display text-3xl font-semibold md:text-4xl">Falcon 4 Pro — 4 Wavelengths, 1 Device</h2>
        </div>

        <div class="grid lg:grid-cols-2 gap-12 items-start">
          <div class="relative rounded-2xl overflow-hidden aspect-[4/3] bg-white/5">
            <img
              src="/images/falcons.png"
              alt="Falcon 4 Pro device front view"
              class="w-full"
            />
          </div>

          <div>
            <h3 class="font-display text-2xl font-semibold text-primary mb-6">Technical Details</h3>
            <dl class="space-y-4 text-sm">
              {falconTechSpecs.map((s) => (
                <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between py-3 border-b border-white/10">
                  <dt class="font-medium text-white">{s.label}</dt>
                  <dd class="mt-1 sm:mt-0 text-white font-mono text-xs sm:text-sm">{s.value}</dd>
                </div>
              ))}
            </dl>

            <div class="mt-8 grid sm:grid-cols-2 gap-4">
              {[
                { icon: "🎯", title: "Alexandrite 755nm", desc: "Gold standard for fine, dark hair. High melanin absorption." },
                { icon: "⚡", title: "Diode 810nm", desc: "Balance of speed and depth. Efficient on large body areas." },
                { icon: "🔬", title: "Nd:YAG 940nm", desc: "Reaching deep follicles, long wavelength protecting vessels." },
                { icon: "☀️", title: "Nd:YAG 1064nm", desc: "Safe standard for tanned/dark skin (Fitzpatrick IV-VI)." },
              ].map((w) => (
                <div class="rounded-xl bg-white/5 p-4">
                  <div class="text-2xl">{w.icon}</div>
                  <h4 class="mt-2 font-semibold text-primary">{w.title}</h4>
                  <p class="mt-1 text-xs text-white/80">{w.desc}</p>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- WHY US / ADVANTAGES -->
    <section id="why-us" class="py-20 bg-white">
      <div class="mx-auto max-w-6xl px-5">
        <div class="text-center max-w-3xl mx-auto mb-16">
          <p class="mb-2 text-sm font-semibold uppercase tracking-[0.2em] text-primary">Why Us?</p>
