---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { getCollection } from "astro:content";
import { clinicGallery } from "../../data/clinicGallery";
import SectionHeader from "../../components/SectionHeader.astro";
import PageHero from "../../components/PageHero.astro";
import BranchDetailCard from "../../components/BranchDetailCard.astro";
import ClinicGallery from "../../components/ClinicGallery.astro";

const branches = (await getCollection("branches")).sort((a, b) => a.data.slug.localeCompare(b.data.slug));
---

<BaseLayout title="Our Clinics | Mr. Falcon Beauty" description="Mr. Falcon Beauty Şişli and Halkalı clinics. Address, phone, hours, and directions." locale="en" path="/en/our-clinics">
  <Header locale="en" />

  <PageHero label="Clinics" title="Our Clinics" description="Mr. Falcon Beauty serves you at two central Istanbul locations." />

  <section class="py-20">
    <div class="mx-auto max-w-6xl px-5">
      <div class="grid md:grid-cols-2 gap-10">
        {branches.map((b) => (
          <BranchDetailCard
            name={b.data.name}
            address={b.data.address}
            phone={b.data.phone}
            whatsapp={b.data.whatsapp}
            hours={b.data.hours}
            image={b.data.image}
          />
        ))}
      </div>
    </div>
  </section>

  <section class="py-20 bg-sky-light/30">
    <div class="mx-auto max-w-6xl px-5">
      <SectionHeader title="Clinic Gallery" margin="md" />
      <ClinicGallery images={clinicGallery.slice(0, 8)} columns={4} />
    </div>
  </section>

  <Footer locale="en" />
</BaseLayout>
