---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import BookingCta from "../components/BookingCta.astro";
import SectionHeader from "../components/SectionHeader.astro";
import InfoCard from "../components/InfoCard.astro";
import PageHero from "../components/PageHero.astro";
import Icon from "../components/Icon.astro";
import { features } from "../data/features";
import { mediaNews } from "../data/mediaNews";

const wavelengths = [
  { nm: "755nm", t: "Alexandrite", desc: "Açık ten ve ince kıllar" },
  { nm: "808nm", t: "Diode", desc: "Tüm cilt tipleri" },
  { nm: "940nm", t: "Diode", desc: "Koyu ten ve derin kökler" },
  { nm: "1064nm", t: "Nd:YAG", desc: "Bronz ten, güvenli" },
];
---

<BaseLayout title="Falcon 4 Pro | Mr. Falcon Beauty" description="FDA onaylı Falcon 4 Pro cihazı: 4 dalga boylu hibrit lazer, -20° soğutma, SHR teknolojisi. Detaylı inceleme." locale="tr" path="/falcon-4-pro">
  <Header locale="tr" />

  <PageHero
    label="Falcon 4 Pro — Cihaz İncelemesi"
    title="Falcon 4 Pro<br /><span class=&quot;text-primary&quot;>Lazer Epilasyon Cihazı</span>"
    description="FDA 510(k) klinik onaylı, yapay zeka destekli 4 dalga boylu hibrit teknoloji — Mr. Falcon Beauty Şişli ve Halkalı şubelerinde"
    primaryCta={{ href: "/iletisim", text: "Randevu Al" }}
    secondaryCta={{ href: "https://api.whatsapp.com/send?phone=905525939890", text: "WhatsApp" }}
  />

  <section class="py-16 bg-white">
    <div class="mx-auto max-w-4xl px-5 text-center"><img src="/images/falcons.png" alt="Falcon 4 Pro" class="mx-auto w-full max-w-md" /></div>
  </section>

  <section class="py-20 bg-sky-light/30">
    <div class="mx-auto max-w-6xl px-5">
      <SectionHeader label="Teknik Detaylar" title="Falcon 4 Pro Teknik Özellikleri" margin="md" />
      <div class="grid md:grid-cols-2 gap-6">
        {features.tr.map((f) => (
          <InfoCard title={f.name} subtitle={f.wavelengths} description={f.desc} variant="light" titleClass="text-primary" />
        ))}
      </div>
    </div>
  </section>

  <section class="py-20 bg-navy text-white">
    <div class="mx-auto max-w-6xl px-5">
      <SectionHeader label="Basında Biz" title="Ulusal Televizyonlarda Falcon 4 Pro" description="Başarılı sonuçlar ulusal kanallarda yer buldu." variant="dark" margin="md" />
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
        {mediaNews.tr.map((m) => (
          <InfoCard icon="tv" title={m.name} description={m.desc} variant="dark-media" />
        ))}
      </div>
    </div>
  </section>

  <section class="py-20">
    <div class="mx-auto max-w-6xl px-5">
      <SectionHeader title="4 Dalga Boyu — Her Cilt Tipine Uygun" description="Farklı doku derinlikleri ve kıl tiplerini tek seansta hedefleyen hibrit teknoloji" margin="md" />
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
        {wavelengths.map((w) => (
          <InfoCard title={w.t} description={w.desc} displayValue={w.nm} variant="center-wavelength" />
        ))}
      </div>
    </div>
  </section>

  <BookingCta locale="tr" />

  <Footer locale="tr" />
</BaseLayout>
