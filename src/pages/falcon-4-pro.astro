---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const features = [
  { name: "4 Dalga Boylu Hibrit Teknoloji", wavelengths: "755nm + 808nm + 940nm + 1064nm", desc: "Dört farklı lazer dalga boyunu tek aplikatörde birleştirir. Açık tenden bronz tene, ince kıldan kalın kıla kadar her danışana en etkili deneyimi sunar." },
  { name: "Ağrısız & Konforlu Uygulama", wavelengths: "-20°C Soğutma", desc: "4 cm² geniş spot başlığı seans sürelerini kısaltır, 5 farklı soğutma sistemi ve -20° buz başlık teknolojisi ağrısız bir deneyim sağlar." },
  { name: "SHR Teknolojisi", wavelengths: "20 atış/sn", desc: "In-Motion SHR sistemi ile saniyede 20 atış yapılabilir. Hızlı ve etkili epilasyonun garantisidir." },
  { name: "Hijyen & Sterilizasyon", wavelengths: "UVC + Steril Box", desc: "Steril Box ve UVC sterilizasyon teknolojisi, her danışan için maksimum hijyeni güvence altına alır." },
  { name: "Yapay Zeka Destekli Analiz", wavelengths: "Mobil Uygulama", desc: "Seans öncesinde cilt ve kıl tipiniz bilimsel olarak analiz edilir, en uygun dalga boyu otomatik belirlenir." },
  { name: "Yüksek Güç & Garanti", wavelengths: "2400W / 100M", desc: "2400W yüksek çıkış gücü ve 100 milyon atış garantisiyle dört mevsim güvenle kullanılabilir." },
];

const mediaNews = [
  { name: "Beyaz TV", desc: "Falcon 4 Pro teknolojisi ulusal kanalda tanıtıldı" },
  { name: "CNN Türk", desc: "Lazer epilasyonda yeni standart: Falcon 4 Pro" },
  { name: "TLC", desc: "Ağrısız epilasyon deneyimi mercek altında" },
  { name: "CNN Türk", desc: "4 dalga boylu hibrit cihaz Türkiye'de" },
];
---

<BaseLayout title="Falcon 4 Pro | Mr. Falcon Beauty" description="FDA onaylı Falcon 4 Pro cihazı: 4 dalga boylu hibrit lazer, -20° soğutma, SHR teknolojisi. Detaylı inceleme." locale="tr" path="/falcon-4-pro">
  <Header locale="tr" />

  <section class="py-20 md:py-28 bg-navy text-white">
    <div class="mx-auto max-w-6xl px-5 text-center">
      <p class="mb-4 text-sm font-semibold uppercase tracking-[0.2em] text-primary">Falcon 4 Pro — Cihaz İncelemesi</p>
      <h1 class="font-display text-4xl font-semibold leading-tight md:text-6xl lg:text-7xl">Falcon 4 Pro<br /><span class="text-primary">Lazer Epilasyon Cihazı</span></h1>
      <p class="mx-auto mb-8 mt-4 max-w-2xl text-lg leading-relaxed text-white/80">FDA 510(k) klinik onaylı, yapay zeka destekli 4 dalga boylu hibrit teknoloji — Mr. Falcon Beauty Şişli ve Halkalı şubelerinde</p>
      <div class="flex flex-wrap items-center justify-center gap-4">
        <a href="/iletisim" class="rounded-full bg-white px-8 py-3 font-semibold text-navy transition-colors hover:bg-primary hover:text-white">Randevu Al</a>
        <a href="https://api.whatsapp.com/send?phone=905525939890" target="_blank" rel="noopener" class="rounded-full border-2 border-white/30 px-8 py-3 font-semibold text-white transition-colors hover:border-primary">WhatsApp</a>
      </div>
    </div>
  </section>

  <section class="py-16 bg-white">
    <div class="mx-auto max-w-4xl px-5 text-center"><img src="/images/falcons.png" alt="Falcon 4 Pro" class="mx-auto w-full max-w-md" /></div>
  </section>

  <section class="py-20 bg-sky-light/30">
    <div class="mx-auto max-w-6xl px-5">
      <div class="text-center max-w-3xl mx-auto mb-12">
        <p class="mb-2 text-sm font-semibold uppercase tracking-[0.2em] text-primary">Teknik Detaylar</p>
        <h2 class="font-display text-3xl font-semibold md:text-4xl">Falcon 4 Pro Teknik Özellikleri</h2>
      </div>
      <div class="grid md:grid-cols-2 gap-6">
        {features.map((f) => (
          <article class="rounded-2xl bg-white p-6 border border-black/5 shadow-sm hover:shadow-md transition-shadow">
            <h3 class="font-display text-xl font-semibold text-primary">{f.name}</h3>
            <p class="mt-1 text-sm font-medium text-black/50">{f.wavelengths}</p>
            <p class="mt-3 text-sm text-black/70 leading-relaxed">{f.desc}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="py-20 bg-navy text-white">
    <div class="mx-auto max-w-6xl px-5">
      <div class="text-center max-w-3xl mx-auto mb-12">
        <p class="mb-2 text-sm font-semibold uppercase tracking-[0.2em] text-primary">Basında Biz</p>
        <h2 class="font-display text-3xl font-semibold md:text-4xl">Ulusal Televizyonlarda Falcon 4 Pro</h2>
        <p class="mt-3 text-white/60">Başarılı sonuçlar ulusal kanallarda yer buldu.</p>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
        {mediaNews.map((m) => (
          <div class="rounded-2xl bg-white/10 p-6 border border-white/10 hover:bg-white/20 transition-colors">
            <div class="text-2xl mb-2">📺</div>
            <h3 class="font-semibold text-primary">{m.name}</h3>
            <p class="mt-2 text-sm text-white/70">{m.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-20">
    <div class="mx-auto max-w-6xl px-5">
      <div class="text-center max-w-3xl mx-auto mb-12">
        <h2 class="font-display text-3xl font-semibold md:text-4xl">4 Dalga Boyu — Her Cilt Tipine Uygun</h2>
        <p class="mt-3 text-black/60">Farklı doku derinlikleri ve kıl tiplerini tek seansta hedefleyen hibrit teknoloji</p>
      </div>
      <div class="grid md:grid-cols-4 gap-6">
        {[{nm:"755nm", t:"Alexandrite", desc:"Açık ten ve ince kıllar"},{nm:"808nm", t:"Diode", desc:"Tüm cilt tipleri"},{nm:"940nm", t:"Nd:YAG", desc:"Koyu ten ve derin kökler"},{nm:"1064nm", t:"Nd:YAG", desc:"Bronz ten, güvenli"}].map((w) => (
          <article class="rounded-2xl border border-black/5 p-6 text-center bg-sky-light/20"><div class="font-display text-3xl font-bold text-primary">{w.nm}</div><div class="mt-1 font-semibold">{w.t}</div><p class="mt-2 text-xs text-black/60">{w.desc}</p></article>
        ))}
      </div>
    </div>
  </section>

  <section class="py-20 bg-sky-light/50">
    <div class="mx-auto max-w-3xl px-5 text-center">
      <h2 class="font-display text-3xl font-semibold md:text-4xl">Falcon 4 Pro Deneyimini Yaşayın</h2>
      <p class="mt-4 text-lg text-black/70">Şişli veya Halkalı şubemizde ücretsiz danışmanlık ve cilt analizi için randevu alın.</p>
      <div class="mt-8"><a href="/iletisim" class="rounded-full bg-navy px-8 py-3 font-semibold text-white transition-colors hover:bg-primary">Randevu Al</a></div>
    </div>
  </section>

  <Footer locale="tr" />
</BaseLayout>