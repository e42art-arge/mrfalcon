---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import ClinicCard from "../components/ClinicCard.astro";
import BranchMap from "../components/BranchMap.astro";
import AppointmentForm from "../components/AppointmentForm.astro";
import PageHero from "../components/PageHero.astro";
import ClinicGallery from "../components/ClinicGallery.astro";
import { getCollection } from "astro:content";

const branches = await getCollection("branches");
branches.sort((a, b) => a.data.slug.localeCompare(b.data.slug));
---

<BaseLayout title="İletişim | Mr. Falcon Beauty" description="Mr. Falcon Beauty iletişim bilgileri. Şişli ve Halkalı şubelerimiz için randevu alın." locale="tr" path="/iletisim">
  <Header locale="tr" />

  <PageHero title="İletişim" description="Kalıcı pürüzsüzlüğe ilk adımı şimdi atın. Formu doldurun, size özel planı birlikte oluşturalım." bgImage="/images/contactbg.jpg" />

  <section class="py-20">
    <div class="mx-auto max-w-6xl px-5">
      <div class="grid md:grid-cols-2 gap-12">
        <!-- FORM -->
        <AppointmentForm locale="tr" branches={branches} turnstileEnabled={true} />

        <!-- BRANCH BILGILERI -->
        <div class="space-y-8">
          {branches.map((b) => <ClinicCard branch={b.data} />)}

          <div class="grid md:grid-cols-2 gap-4">
            {branches.map((b) => <BranchMap branch={b.data} />)}
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 bg-sky-light/30">
    <div class="mx-auto max-w-6xl px-5">
      <ClinicGallery images={["/images/c1.jpg","/images/c2.jpg","/images/c3.jpg","/images/c4.jpg"].map(src => ({ src, alt: "Mr. Falcon Beauty" }))} columns={4} />
    </div>
  </section>

  <Footer locale="tr" />
</BaseLayout>

