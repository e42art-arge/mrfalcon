---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { getCollection } from "astro:content";

const branches = await getCollection("branches");
branches.sort((a, b) => a.data.slug.localeCompare(b.data.slug));

const TURNSTILE_ENABLED = false;
---

<BaseLayout title="İletişim | Mr. Falcon Beauty" description="Mr. Falcon Beauty iletişim bilgileri. Şişli ve Halkalı şubelerimiz için randevu alın." locale="tr" path="/iletisim">
  <Header locale="tr" />

  <section class="py-20 md:py-28 bg-navy text-white relative" style="background-image: url('/images/contactbg.jpg'); background-size: cover; background-position: center;">
    <div class="absolute inset-0 bg-navy/70"></div>
    <div class="mx-auto max-w-6xl px-5 text-center relative z-10">
      <h1 class="font-display text-4xl font-semibold md:text-6xl">İletişim</h1>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-white/80">Kalıcı pürüzsüzlüğe ilk adımı şimdi atın. Formu doldurun, size özel planı birlikte oluşturalım.</p>
    </div>
  </section>

  <section class="py-20">
    <div class="mx-auto max-w-6xl px-5">
      <div class="grid md:grid-cols-2 gap-12">
        <!-- FORM -->
        <div>
          <h2 class="font-display text-3xl font-semibold mb-2">Ücretsiz Cilt & Kıl Analizi</h2>
          <p class="text-black/70 mb-8">Formu doldurun, 15 dakika içinde size dönelim. Şube tercihinizi belirtin.</p>

          <form id="appointment-form" class="space-y-5" action="/api/contact.php" method="POST">
            <input type="hidden" name="form_type" value="appointment" />
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div>
                <label for="name" class="block text-sm font-medium text-black/70 mb-1">Ad Soyad *</label>
                <input type="text" id="name" name="name" required class="w-full rounded-lg border border-black/15 bg-white px-4 py-3 text-sm text-black focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary" placeholder="Adınız Soyadınız" />
              </div>
              <div>
                <label for="phone" class="block text-sm font-medium text-black/70 mb-1">Telefon *</label>
                <input type="tel" id="phone" name="phone" required class="w-full rounded-lg border border-black/15 bg-white px-4 py-3 text-sm text-black focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary" placeholder="05XX XXX XX XX" />
              </div>
            </div>
            <div>
              <label for="email" class="block text-sm font-medium text-black/70 mb-1">E-posta</label>
              <input type="email" id="email" name="email" class="w-full rounded-lg border border-black/15 bg-white px-4 py-3 text-sm text-black focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary" placeholder="ornek@email.com" />
            </div>
            <div>
              <label for="clinic" class="block text-sm font-medium text-black/70 mb-1">Şube Tercihi *</label>
              <select id="clinic" name="clinic" required class="w-full rounded-lg border border-black/15 bg-white px-4 py-3 text-sm text-black focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary">
                <option value="">Şube Seçiniz</option>
                {branches.map((b) => <option value={b.data.slug}>{b.data.name}</option>)}
              </select>
            </div>
            <div>
              <label for="concern" class="block text-sm font-medium text-black/70 mb-1">İlgi Alanı / Bölge</label>
              <select id="concern" name="concern" class="w-full rounded-lg border border-black/15 bg-white px-4 py-3 text-sm text-black focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary">
                <option value="">Seçiniz</option>
                <option value="full-body">Tüm Vücut</option>
                <option value="face-neck">Yüz & Boyun</option>
                <option value="underarm">Koltuk Altı</option>
                <option value="arm-leg">Kol & Bacak</option>
                <option value="back-chest">Sırt & Göğüs</option>
                <option value="bikini">Bölgesel / Bikini</option>
              </select>
            </div>
            <div>
              <label for="message" class="block text-sm font-medium text-black/70 mb-1">Not / Mesaj</label>
              <textarea id="message" name="message" rows="3" class="w-full rounded-lg border border-black/15 bg-white px-4 py-3 text-sm text-black focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary" placeholder="Özel durum, hormon tedavisi, önceki lazer geçmişi vb."></textarea>
            </div>
            <div class="flex items-start gap-2 text-sm text-black/60">
              <input type="checkbox" id="kvkk" name="kvkk" required class="mt-1 w-4 h-4 rounded border-black/30 text-primary focus:ring-primary" />
              <label for="kvkk"><a href='/kvkk-aydinlatma-metni' class='text-primary hover:underline' target='_blank'>KVKK aydınlatma metnini</a> okudum, onaylıyorum. Verilerim randevu için işlensin.</label>
            </div>
            {TURNSTILE_ENABLED && <div class="cf-turnstile" data-sitekey="0x4AAAAAAAe3UYEAyXZ5Iqy4vEMqCLYzNB8" data-theme="light" data-callback="onTurnstileCallback"></div>}
            <button type="submit" class="w-full sm:w-auto rounded-full bg-navy px-8 py-3 font-semibold text-white transition-colors hover:bg-primary">
              Ücretsiz Analiz İste & Randevu Al
            </button>
            <div id="form-status" class="text-sm font-medium hidden"></div>
          </form>
        </div>

        <!-- BRANCH BILGILERI -->
        <div class="space-y-8">
          {branches.map((b) => (
            <article class="rounded-2xl bg-sky-light/30 p-6 border border-black/5">
              <h3 class="font-display text-lg font-semibold flex items-center gap-2">🏥 {b.data.name}</h3>
              <address class="mt-3 not-italic text-sm text-black/70 leading-relaxed">{b.data.address}</address>
              <div class="mt-4 space-y-2 text-sm">
                <a href={`tel:${b.data.phone}`} class="flex items-center gap-2 text-black/70 hover:text-primary transition-colors"><span>📞</span> {b.data.phone}</a>
                <a href={b.data.whatsapp} target="_blank" rel="noopener" class="flex items-center gap-2 text-black/70 hover:text-primary transition-colors"><span>💬</span> WhatsApp</a>
              </div>
            </article>
          ))}

          <div class="grid md:grid-cols-2 gap-4">
            {branches.map((b) => (
              <div class="rounded-2xl overflow-hidden aspect-[4/3] shadow-md">
                <iframe src={b.data.mapEmbed} class="w-full h-full border-0" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade" title={b.data.name}></iframe>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 bg-sky-light/30">
    <div class="mx-auto max-w-6xl px-5">
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
        {["/images/c1.jpg","/images/c2.jpg","/images/c3.jpg","/images/c4.jpg"].map((img) => (
          <div class="rounded-2xl overflow-hidden shadow-md"><img src={img} alt="Mr. Falcon Beauty" class="w-full" /></div>
        ))}
      </div>
    </div>
  </section>

  <Footer locale="tr" />

  {TURNSTILE_ENABLED && <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>}
  <script>
    // Form submit via fetch
    document.getElementById('appointment-form')?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const form = e.target;
      const msgEl = document.getElementById('form-status');
      const btn = form.querySelector('button[type="submit"]');
      const originalText = btn.textContent;
      btn.disabled = true;
      btn.textContent = 'Gönderiliyor...';
      msgEl.classList.add('hidden');

      try {
        const formData = new FormData(form);
        const res = await fetch('/api/contact.php', {
          method: 'POST',
          body: formData,
        });
        const data = await res.json();
        if (res.ok && data.success) {
          msgEl.textContent = '✅ Randevu talebiniz alındı! 15 dk içinde size dönüş yapacağız.';
          msgEl.className = 'text-green-700';
          form.reset();
          {TURNSTILE_ENABLED && <fragment>if (typeof turnstile !== 'undefined') turnstile.reset();</fragment>}
        } else {
          throw new Error(data.message || 'Bir hata oluştu');
        }
      } catch (err) {
        msgEl.textContent = '❌ ' + (err.message || 'Gönderim başarısız, lütfen WhatsApp\'tan yazın.');
        msgEl.className = 'text-red-700';
        {TURNSTILE_ENABLED && <fragment>if (typeof turnstile !== 'undefined') turnstile.reset();</fragment>}
      } finally {
        msgEl.classList.remove('hidden');
        btn.disabled = false;
        btn.textContent = originalText;
      }
    });
  </script>
</BaseLayout>