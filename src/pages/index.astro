  { id: 25, thumbnail: "/images/shorts/shorts25.jpg", videoUrl: "/videos/shorts/shorts25.mp4", title: "Memnuniyet Videoları", description: "Lazer Epilasyon", category: "satisfaction" },
  { id: 26, thumbnail: "/images/shorts/shorts26.jpg", videoUrl: "/videos/shorts/shorts26.mp4", title: "Memnuniyet Videoları", description: "Lazer Epilasyon", category: "satisfaction" },
