---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const features = [
  { title: "4 Dalga Boyu", text: "755nm, 810nm, 940nm ve 1064nm tek cihazda; tüm cilt tiplerine uygun." },
  { title: "AI Kontrol", text: "Cilt tipini analiz eder, enerjiyi otomatik optimize eder." },
  { title: "Soğutma", text: "Sapphire soğutma ile neredeyse ağrısız seans." },
  { title: "UVC Hijyen", text: "Her seans öncesi UVC ile başlık dezenfeksiyonu." },
];

const reviews = [
  { name: "Elif K.", branch: "Şişli", quote: "Ağrısız ve çok hızlı, sonuçlar harika." },
  { name: "Merve A.", branch: "Halıkalı", quote: "Personel çok ilgili, ortam çok hijyenik." },
  { name: "Zeynep D.", branch: "Şişli", quote: "Falcon 4 Pro farkı gerçekten hissediliyor." },
];
---

<BaseLayout
  title="Mr. Falcon Beauty — Ağrısız Lazer Epilasyon | Falcon 4 Pro"
  description="Falcon 4 Pro teknolojisiyle ağrısız, hızlı ve kalıcı lazer epilasyon. İstanbul Şişli ve Halıkalı'da uzman kadro ile hizmetinizde."
  locale="tr"
  path="/"
>
  <Header locale="tr" />

  <main>
    <section class="relative overflow-hidden bg-gradient-to-b from-beige to-white">
      <div class="mx-auto max-w-6xl px-5 py-24 text-center md:py-32">
        <p class="mb-4 text-sm font-semibold uppercase tracking-[0.2em] text-champagne">Falcon 4 Pro Technology</p>
        <h1 class="mx-auto max-w-3xl font-display text-4xl font-semibold leading-tight text-ink md:text-6xl">
          Ağrısız Lazer Epilasyonun Yeni Standardı
        </h1>
        <p class="mx-auto mt-6 max-w-2xl text-lg leading-relaxed text-ink/70">
          Dört dalga boyu, yapay zeka destekli kontrol ve safir soğutma ile tanışın. İstanbul'un iki yakasında Mr. Falcon Beauty farkı.
        </p>
        <div class="mt-10 flex flex-wrap items-center justify-center gap-4">
          <a href="/iletisim" class="rounded-full bg-ink px-7 py-3 font-semibold text-white transition-colors hover:bg-champagne">
            Randevu Al
          </a>
          <a href="/falcon-4-pro" class="rounded-full border border-ink/15 px-7 py-3 font-semibold text-ink transition-colors hover:border-champagne hover:text-champagne">
            Teknolojiyi Keşfet
          </a>
        </div>
      </div>
    </section>

    <section class="bg-ink py-20 text-white">
      <div class="mx-auto max-w-6xl px-5">
        <h2 class="text-center font-display text-3xl font-semibold md:text-4xl">Neden Falcon 4 Pro?</h2>
        <div class="mt-12 grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
          {features.map((f) => (
            <div class="rounded-2xl bg-white/5 p-6">
              <h3 class="font-display text-xl font-semibold text-champagne">{f.title}</h3>
              <p class="mt-3 text-sm leading-relaxed text-mist/75">{f.text}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="py-20">
      <div class="mx-auto max-w-6xl px-5">
        <h2 class="text-center font-display text-3xl font-semibold text-ink md:text-4xl">Müşterilerimiz Ne Diyor?</h2>
        <div class="mt-12 grid gap-8 md:grid-cols-3">
          {reviews.map((r) => (
            <figure class="rounded-2xl border border-ink/10 p-7">
              <blockquote class="text-ink/80">"{r.quote}"</blockquote>
              <figcaption class="mt-4 text-sm font-semibold text-champagne">{r.name} · {r.branch}</figcaption>
            </figure>
          ))}
        </div>
        <div class="mt-10 text-center">
          <a href="/yorumlar" class="font-semibold text-ink underline-offset-4 hover:text-champagne hover:underline">
            Tüm yorumları gör →
          </a>
        </div>
      </div>
    </section>

    <section class="bg-beige py-20">
      <div class="mx-auto max-w-3xl px-5 text-center">
        <h2 class="font-display text-3xl font-semibold text-ink md:text-4xl">Hemen Randevu Alın</h2>
        <p class="mt-4 text-ink/70">Şişli veya Halıkalı şubemizde ilk değerlendirmeniz ücretsiz.</p>
        <a href="/iletisim" class="mt-8 inline-block rounded-full bg-ink px-8 py-3 font-semibold text-white transition-colors hover:bg-champagne">
          İletişime Geç
        </a>
      </div>
    </section>
  </main>

  <Footer locale="tr" />
</BaseLayout>
