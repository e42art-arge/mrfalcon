  </main>

  <Footer locale="tr" />

  <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
  <script>
    // FAQ Accordion
    document.querySelectorAll('#faq-accordion button').forEach(btn => {
      btn.addEventListener('click', () => {
        const dd = btn.nextElementSibling;
        const isOpen = !dd.hidden;
        dd.hidden = isOpen;
        btn.setAttribute('aria-expanded', !isOpen);
        btn.querySelector('svg')?.classList.toggle('rotate-180', !isOpen);
      });
    });

    // Form submit via fetch
    document.getElementById('appointment-form')?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const form = e.target;
      const msgEl = document.getElementById('form-message');
      const btn = form.querySelector('button[type="submit"]');
      const originalText = btn.textContent;
      btn.disabled = true;
      btn.textContent = 'Gönderiliyor...';
      msgEl.classList.add('hidden');

      try {
        const formData = new FormData(form);
        const res = await fetch('/api/contact', {
          method: 'POST',
          body: formData,
        });
        const data = await res.json();
        if (res.ok && data.success) {
          msgEl.textContent = '✅ ' + (data.message || 'Randevu talebiniz alındı! 15 dk içinde size dönüş yapacağız.');
          msgEl.className = 'text-green-700';
          form.reset();
          if (typeof turnstile !== 'undefined') turnstile.reset();
        } else {
          throw new Error(data.message || 'Bir hata oluştu');
        }
      } catch (err) {
        msgEl.textContent = '❌ ' + (err.message || 'Gönderim başarısız, lütfen WhatsApp\'tan yazın.');
        msgEl.className = 'text-red-700';
        if (typeof turnstile !== 'undefined') turnstile.reset();
      } finally {
        msgEl.classList.remove('hidden');
        btn.disabled = false;
        btn.textContent = originalText;
      }
    });

    // Clinic selector from URL
    const heroClinicSelect = document.getElementById('hero-clinic-select');
    heroClinicSelect?.addEventListener('change', (e) => {
      window.location.href = e.target.value;
    });

    const urlParams = new URLSearchParams(window.location.search);
    const clinicParam = urlParams.get('clinic');
    if (clinicParam) {
      const select = document.getElementById('clinic');
      if (select) select.value = clinicParam;
      const heroSelect = document.getElementById('hero-clinic-select');
      if (heroSelect) heroSelect.value = `#contacts?clinic=${clinicParam}`;
    }
  </script>
</BaseLayout>