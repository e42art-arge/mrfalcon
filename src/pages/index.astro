---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import VideoGallery from "../components/VideoGallery.astro";
import PressSlider from "../components/PressSlider.astro";
import InfoVideos from "../components/InfoVideos.astro";
import FaqAccordion from "../components/FaqAccordion.astro";
import ReviewCard from "../components/ReviewCard.astro";
import ClinicCard from "../components/ClinicCard.astro";
import BranchMap from "../components/BranchMap.astro";
import StatGrid from "../components/StatGrid.astro";
import BookingCta from "../components/BookingCta.astro";
import Icon from "../components/Icon.astro";
import SectionHeader from "../components/SectionHeader.astro";
import InfoCard from "../components/InfoCard.astro";
import StepCard from "../components/StepCard.astro";
import AppointmentForm from "../components/AppointmentForm.astro";
import { reviews } from "../data/reviews";
import { getCollection } from "astro:content";
import { trustSignals } from "../data/trustSignals";
import { siteMetrics } from "../data/siteMetrics";
import { processSteps } from "../data/processSteps";
import { falconTechSpecs } from "../data/falconTechSpecs";
import { whyUs as whyUsItems } from "../data/whyUs";
import { clinicGallery } from "../data/clinicGallery";
import { satisfactionVideos, pressVideos, faqVideos } from "../data/videos";

const branches = (await getCollection("branches")).sort((a, b) => a.data.slug.localeCompare(b.data.slug));
const faqEntries = (await getCollection("faq", (e) => e.id.startsWith("tr/"))).sort((a, b) => a.data.order - b.data.order);
const faqs = faqEntries.map((e) => ({ q: e.data.question, a: e.data.answer }));

const laserScience = [
  { icon: "target", title: "Seçici Fototermoliz", desc: "Lazer ışığı melanozitler tarafından emilerek kıl kökünü ısıtır, çevre dokuları korur." },
  { icon: "microscope", title: "Anagen Fazı Hedefleme", desc: "Sadece büyüme aşamasındaki (anagen) kıllar etkilendiği için birden fazla seans gerekir." },
  { icon: "color-swatch", title: "4 Dalga Boyu Avantajı", desc: "755nm (ince/koyu kıl), 808nm (hız), 940nm (derinlik), 1064nm (bronz cilt) - hepsi bir arada." },
  { icon: "bot", title: "AI Enerji Optimizasyonu", desc: "Cihaz cilt tipini (Fitzpatrick I-VI) tarar, kıl kalınlığını ölçer, joule/ms/Hz'yi otomatik set eder." },
  { icon: "snowflake", title: "Safir Kontak Soğutma", desc: "-20°C başlık sıcaklığı ile epiderme korunur, dermis hedeflenir. Ağrı sinyali bloke edilir." },
  { icon: "shield", title: "Güvenlik Protokolleri", desc: "Test atışı zorunlu, gözlük zorunlu, UVC dezenfeksiyon, tek kullanımlık kapak, cilt soğutma jeli." },
];
---

<BaseLayout
  title="Mr. Falcon Beauty | Lazer Epilasyon Merkezi Mecidiyeköy & Halkalı & Küçükçekmece"
  description="Falcon 4 Pro teknolojisiyle ağrısız, hızlı ve kalıcı lazer epilasyon. İstanbul Şişli/Mecidiyeköy ve Halkalı/Küçükçekmece şubelerinde uzman kadro. İlk danışmanlık ücretsiz."
  locale="tr"
  path="/"
>
  <Header locale="tr" />

  <main>
    <!-- HERO SECTION - GSAP + Lenis Enhanced -->
    <section id="hero" class="relative overflow-hidden bg-gradient-to-b from-sky-light to-white" data-hero>
      <div class="pointer-events-none absolute inset-0 overflow-hidden" aria-hidden="true">
        <div class="absolute top-1/4 left-1/4 w-[300px] h-[300px] md:w-[600px] md:h-[600px] bg-primary/10 rounded-full blur-3xl animate-blob-slow" style="animation-duration: 20s;"></div>
        <div class="absolute bottom-1/4 right-1/4 w-[250px] h-[250px] md:w-[500px] md:h-[500px] bg-sky/10 rounded-full blur-3xl animate-blob-slow" style="animation-duration: 25s; animation-delay: -5s;"></div>
        <div id="hero-particles" class="absolute inset-0"></div>
      </div>

      <div class="border-b border-black/5 bg-white/50 backdrop-blur sticky top-16 z-40" data-animate="trust-bar" data-gsap-trigger="trust-bar">
        <div class="mx-auto flex max-w-7xl items-center justify-center gap-4 px-5 py-3 text-sm font-medium text-black/70 md:py-2">
          <div class="flex flex-wrap items-center justify-center gap-3 text-xs md:gap-6 md:text-sm" data-gsap="stagger" data-gsap-delay="0.1">
            {trustSignals.tr.map((t) => (
              <span class="flex items-center gap-1.5 text-primary"><Icon name={t.icon} class="w-4 h-4" /> <strong>{t.text}</strong></span>
            ))}
          </div>
        </div>
      </div>

      <div class="mx-auto max-w-7xl px-5 py-20 md:py-28 lg:py-32 relative z-10">
        <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
          <div class="text-center lg:text-left" data-hero-content>
            <p class="mb-6 text-sm font-semibold uppercase tracking-[0.25em] text-primary" data-gsap="fadeUp" data-gsap-delay="0.1">
              Falcon 4 Pro Technology
            </p>

            <h1 class="mb-8 font-display text-4xl font-semibold leading-tight text-black md:text-6xl lg:text-7xl xl:text-8xl" data-gsap-split="lines" data-gsap="splitLines" data-gsap-delay="0.2">
              Ağrısız Lazer Epilasyonun
              <br />
              <span class="text-primary relative">Yeni Standardı</span>
            </h1>

            <p class="mb-10 max-w-xl text-lg leading-relaxed text-black/70 mx-auto lg:mx-0" data-gsap="fadeUp" data-gsap-delay="0.4">
              Dört dalga boyu, yapay zeka destekli kontrol ve -20°C safir soğutma ile tanışın.
              Şişli ve Halkalı'da Mr. Falcon Beauty farkı.
            </p>

            <div class="flex flex-col sm:flex-row items-stretch sm:items-center justify-center gap-4 lg:justify-start mb-10" data-gsap="stagger" data-gsap-delay="0.5">
              <a
                href="#contacts"
                class="group relative text-center rounded-full bg-navy px-8 py-3.5 font-semibold text-white transition-all duration-300 hover:bg-primary hover:shadow-[0_20px_40px_-12px_rgba(14,116,144,0.4)]"
                data-hover="scale"
                data-gsap="fadeUp"
              >
                <span class="relative z-10">Ücretsiz Analiz & Randevu</span>
                <span class="absolute inset-0 rounded-full bg-primary/20 opacity-0 group-hover:opacity-100 transition-opacity duration-300 blur-xl" aria-hidden="true"></span>
              </a>
              <a
                href="#falcon-4-pro"
                class="group relative text-center rounded-full border-2 border-black/15 px-8 py-3.5 font-semibold text-black transition-all duration-300 hover:border-primary hover:text-primary hover:bg-primary/5"
                data-hover="scale"
                data-gsap="fadeUp"
              >
                <span class="relative z-10">Teknolojiyi Keşfet</span>
                <svg class="absolute left-0 top-1/2 -translate-y-1/2 w-5 h-5 text-black/40 group-hover:translate-x-1 group-hover:text-primary transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
                </svg>
              </a>
            </div>

            <div class="flex flex-wrap items-center justify-center gap-3 md:gap-6 lg:justify-start" data-gsap="stagger" data-gsap-delay="0.6">
              <div class="flex items-center gap-2 text-sm text-black/60" data-gsap="fadeUp">
                <Icon name="check" class="w-4 h-4 text-primary flex-shrink-0" />
                <span>İlk danışmanlık ücretsiz</span>
              </div>
              <div class="flex items-center gap-2 text-sm text-black/60" data-gsap="fadeUp">
                <Icon name="check" class="w-4 h-4 text-primary flex-shrink-0" />
                <span>Cilt & kıl analizi dahil</span>
              </div>
              <div class="flex items-center gap-2 text-sm text-black/60" data-gsap="fadeUp">
                <Icon name="check" class="w-4 h-4 text-primary flex-shrink-0" />
                <span>Test atışı yapılır</span>
              </div>
            </div>

          </div>

          <div class="relative" data-hero-visual>
            <div class="relative rounded-3xl overflow-hidden shadow-2xl bg-navy/5" data-gsap="parallax" data-gsap-speed="0.3">
              <img
                src="/images/sliderdoctor.png"
                alt="Falcon 4 Pro cihazı ve Mr. Falcon Beauty klinik ortamı"
                class="w-full object-cover transition-transform duration-1000 ease-out"
                loading="eager"
                data-gsap="reveal"
              />

              <div class="absolute top-6 right-6 hidden md:flex flex-col gap-3" data-gsap="stagger" data-gsap-delay="0.3">
                {[
                  { icon: "target", text: "4 Dalga Boyu" },
                  { icon: "bot", text: "AI Kontrol" },
                  { icon: "snowflake", text: "-20°C Soğutma" },
                  { icon: "shield", text: "UVC Hijyen" },
                ].map((badge) => (
                  <div class="group relative px-4 py-3 bg-white/90 backdrop-blur rounded-xl shadow-lg border border-black/5 transition-all duration-300 hover:shadow-xl hover:-translate-x-1 hover:border-primary/30" data-gsap="fadeRight">
                    <div class="flex items-center gap-2">
                      <Icon name={badge.icon} class="w-5 h-5 text-primary" />
                      <span class="font-semibold text-black text-sm">{badge.text}</span>
                    </div>
                    <div class="absolute bottom-0 left-0 right-0 h-0.5 bg-primary origin-left group-hover:origin-right scale-x-0 group-hover:scale-x-100 transition-transform duration-300" aria-hidden="true"></div>
                  </div>
                ))}
              </div>
            </div>

            <div class="mt-6 flex md:hidden flex-wrap justify-center gap-2" data-gsap="stagger" data-gsap-delay="0.3">
                {[
                  { icon: "target", text: "4 Dalga Boyu" },
                  { icon: "bot", text: "AI Kontrol" },
                  { icon: "snowflake", text: "-20°C Soğutma" },
                  { icon: "shield", text: "UVC Hijyen" },
                ].map((badge) => (
                  <span class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-white/90 backdrop-blur rounded-full text-xs font-medium text-black border border-black/10">
                    <Icon name={badge.icon} class="w-3.5 h-3.5 text-primary" />
                    {badge.text}
                  </span>
                ))}
              </div>

              <div class="absolute -bottom-6 left-1/2 -translate-x-1/2 md:left-auto md:-translate-x-0 md:-bottom-8 md:-left-8 p-4 md:p-8 bg-white/95 backdrop-blur rounded-2xl shadow-2xl max-w-[calc(100%-2rem)] md:max-w-xs border border-black/5 z-20" data-gsap="float" data-gsap-delay="0.5">
              <div class="flex items-center gap-3 text-primary text-2xl font-display font-bold">
                <svg class="w-7 h-7 animate-pulse text-primary" style="animation-duration: 2s;" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                <span data-gsap="counter" data-target="5.0" data-decimals="1" data-suffix="" data-prefix="" data-duration="2">5.0</span>
              </div>
              <p class="mt-1 text-sm text-black/70">Google'de 58+ değerlendirmede</p>
              <div class="mt-4 flex flex-wrap items-center gap-3 text-xs text-black/60">
                <span class="flex items-center gap-1 px-2 py-1 bg-green-50 text-green-700 rounded-full">✓ FDA/CE Onaylı</span>
                <span class="flex items-center gap-1 px-2 py-1 bg-blue-50 text-blue-700 rounded-full">✓ %95+ Başarı</span>
                <span class="flex items-center gap-1 px-2 py-1 bg-purple-50 text-purple-700 rounded-full">✓ Garanti Paket</span>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="absolute bottom-0 left-0 right-0 overflow-hidden" aria-hidden="true">
        <svg class="w-full h-16 md:h-24" viewBox="0 0 1440 120" preserveAspectRatio="none">
          <path
            fill="url(#heroWaveGradient)"
            fill-opacity="0.1"
            d="M0,64 C300,120 600,0 900,64 C1200,128 1440,64 1440,64 L1440,120 L0,120 Z"
          />
          <defs>
            <linearGradient id="heroWaveGradient" x1="0%" y1="0%" x2="100%" y2="100%">
              <stop offset="0%" stop-color="#17468A" />
              <stop offset="100%" stop-color="#17468A" stop-opacity="0" />
            </linearGradient>
          </defs>
        </svg>
      </div>
    </section>

    <!-- ABOUT US / MR FALCON BEAUTY -->
    <section id="about-us" class="py-24 bg-white">
      <div class="mx-auto max-w-6xl px-5">
        <div class="grid lg:grid-cols-2 gap-12 items-center">
          <div>
            <p class="mb-2 text-sm font-semibold uppercase tracking-[0.2em] text-primary">Mr. Falcon Beauty</p>
            <h2 class="mb-6 font-display text-3xl font-semibold text-black md:text-4xl lg:text-5xl">
              İstanbul'un Güvendiği Lazer Epilasyon Merkezi
            </h2>
            <p class="mb-6 text-lg leading-relaxed text-black/70">
              2014'ten bu yana Şişli/Mecidiyeköy ve Halkalı/Küçükçekmece şubelerimizde 15.000'den fazla müşterimize
              güvenli, etkili ve hijyenik lazer epilasyon hizmeti verdik. Falcon 4 Pro teknolojisiyle ağrıyı, yan etkileri
              ve belirsizliği ortadan kaldırarak "yapay zeka kontrollü, 4 dalga boyulu, soğutmalı" yeni standartı koyduk.
            </p>
            <div class="mb-8">
              <StatGrid items={siteMetrics.tr} class="grid-cols-2 lg:grid-cols-2 gap-6" />
            </div>
            <a href="#falcon-4-pro" class="inline-flex items-center gap-2 font-semibold text-primary hover:text-black transition-colors">
              Falcon 4 Pro Teknolojisi →
            </a>
          </div>

          <div class="relative rounded-3xl overflow-hidden">
            <img
              src="/images/homeabout.png"
              alt="Mr. Falcon Beauty Şişli şubesi iç görünümü"
              class="w-full"
            />
            <div class="absolute bottom-0 left-0 right-0 p-6 md:p-8 bg-gradient-to-t from-navy/90 to-transparent text-white">
              <div class="flex items-center gap-3 text-primary text-xl font-display font-bold"><Icon name="award" class="w-7 h-7" /></div>
              <p class="mt-2 text-lg font-medium">Türkiye'nin İlk Falcon 4 Pro Kliniği</p>
              <p class="mt-1 text-sm text-white/80">2024'ten beri İstanbul'da önderlik ediyoruz</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- LASER HAIR REMOVAL INFO -->
    <section id="lazer-epilasyon" class="py-16 bg-sky-light/30">
      <div class="mx-auto max-w-6xl px-5">
        <SectionHeader label="Lazer Epilasyon Nedir?" title="Kalıcı Kıl Azaltma Bilimi ve Falcon 4 Pro Farkı" />

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          {laserScience.map((item) => (
            <InfoCard icon={item.icon} title={item.title} description={item.desc} />
          ))}
        </div>
      </div>
    </section>

    <!-- MEMNUNİYET VİDEOLARI (Danışan Videoları) -->
    <VideoGallery videos={satisfactionVideos.tr} sectionId="satisfaction-videos" class="bg-sky-light/30" />

    <!-- BASINDA HABERLER (Press Videos Slider) -->
    <PressSlider videos={pressVideos} locale="tr" />

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@fancyapps/ui@5.0/dist/fancybox/fancybox.css" />
    <script type="module">
      import { Fancybox } from "https://cdn.jsdelivr.net/npm/@fancyapps/ui@5.0/dist/fancybox/fancybox.esm.js";
      Fancybox.bind('[data-fancybox="press-videos"]', {
        type: "video",
        video: { autoStart: true },
        Toolbar: { display: ["close"] },
        mainClass: "fancybox-press"
      });
    </script>

    <!-- BİLGİLENDİRİCİ VİDEOLAR (SSS / Falcon 4 Pro) -->
    <InfoVideos videos={faqVideos.tr} sectionId="info-videos" class="bg-white" />

    <!-- FALCON 4 PRO TECH DEEP DIVE -->
    <section id="falcon-4-pro" class="relative py-24 bg-gradient-to-br from-slate-950 via-[#0A1128] to-slate-950 text-white overflow-hidden">
      <!-- Glow ambient shapes -->
      <div class="absolute top-1/4 left-0 w-96 h-96 bg-primary/10 rounded-full blur-[130px] pointer-events-none" aria-hidden="true"></div>
      <div class="absolute bottom-1/4 right-0 w-96 h-96 bg-cyan-500/10 rounded-full blur-[130px] pointer-events-none" aria-hidden="true"></div>
      
      <div class="relative z-10 mx-auto max-w-6xl px-5">
        <SectionHeader label="Teknoloji" title="Falcon 4 Pro — 4 Dalga Boyu, 1 Cihaz" variant="dark" margin="lg" />

        <div class="grid lg:grid-cols-12 gap-8 lg:gap-12 items-stretch mt-12">
          <!-- Left Visual Block -->
          <div class="lg:col-span-5 flex flex-col">
            <div class="relative group flex-1 rounded-3xl overflow-hidden bg-gradient-to-tr from-white/5 to-white/10 border border-white/10 backdrop-blur-xl p-8 flex flex-col justify-between items-center shadow-2xl transition-all duration-500 hover:border-cyan-500/30 hover:shadow-[0_20px_50px_rgba(6,182,212,0.15)] min-h-[350px]">
              <div class="absolute inset-0 bg-gradient-to-t from-cyan-950/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none"></div>
              
              <!-- Device Floating Image -->
              <div class="relative w-full h-full flex items-center justify-center py-6">
                <!-- Glowing backing light -->
                <div class="absolute w-44 h-44 bg-cyan-500/20 rounded-full blur-3xl animate-pulse"></div>
                <img
                  src="/images/falcons.png"
                  alt="Falcon 4 Pro cihazı ön görünüm"
                  class="w-full h-[280px] object-contain relative z-10 filter drop-shadow-[0_15px_30px_rgba(6,182,212,0.3)] transform group-hover:scale-105 transition-transform duration-500"
                />
              </div>
              
              <!-- Dynamic Status Indicator -->
              <div class="w-full bg-slate-950/80 backdrop-blur-md rounded-2xl p-4 border border-white/10 flex items-center justify-between mt-auto">
                <div class="flex items-center gap-3">
                  <div class="relative flex h-3 w-3">
                    <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-cyan-400 opacity-75"></span>
                    <span class="relative inline-flex rounded-full h-3 w-3 bg-cyan-500"></span>
                  </div>
                  <div class="text-[10px] uppercase tracking-[0.2em] text-cyan-300 font-bold">Safir Kristal Soğutma</div>
                </div>
                <div class="text-right">
                  <span class="text-2xl font-mono font-bold text-cyan-400">-20°C</span>
                  <span class="text-[10px] text-white/50 block font-medium">Başlık Sıcaklığı</span>
                </div>
              </div>
            </div>
          </div>

          <!-- Right Details Block -->
          <div class="lg:col-span-7 flex flex-col justify-between">
            <div class="bg-gradient-to-tr from-white/5 to-white/10 border border-white/10 backdrop-blur-xl rounded-3xl p-6 md:p-8 shadow-2xl flex-1 flex flex-col justify-between">
              <div>
                <div class="flex items-center justify-between mb-8">
                  <h3 class="font-display text-2xl font-semibold text-transparent bg-clip-text bg-gradient-to-r from-white to-white/70">Teknoloji Detayları</h3>
                  <span class="px-3 py-1 text-[10px] rounded-full bg-primary/20 text-cyan-300 border border-primary/30 font-semibold tracking-wider uppercase">AI Optimizasyonlu</span>
                </div>
                
                <dl class="grid sm:grid-cols-2 gap-x-8 gap-y-4">
                  {falconTechSpecs.tr.map((s) => (
                    <div class="group/item flex flex-col py-3 border-b border-white/5 hover:border-cyan-500/20 transition-all duration-300">
                      <dt class="flex items-center gap-2 text-xs font-semibold text-white/60 group-hover/item:text-white transition-colors duration-300">
                        <span class="w-1.5 h-1.5 rounded-full bg-cyan-500/40 group-hover/item:bg-cyan-400 group-hover/item:scale-125 transition-all duration-300"></span>
                        {s.label}
                      </dt>
                      <dd class="mt-1 text-white font-mono text-sm group-hover/item:text-cyan-300 transition-colors duration-300 pl-3.5">
                        {s.value}
                      </dd>
                    </div>
                  ))}
                </dl>
              </div>
            </div>
          </div>
        </div>

        <!-- 4 Wavelength Spectrum Grid -->
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mt-12 w-full">
          {[
            { 
              title: "Alexandrite 755nm", 
              desc: "İnce, koyu kıllar için altın standart. Yüksek melanin emilimi ile kıl kökünü anında devre dışı bırakır.",
              target: "İnce & Koyu Kıllar",
              color: "from-purple-500/10 to-pink-500/5 hover:border-purple-500/40 hover:shadow-purple-500/5",
              glow: "bg-purple-500/10",
              badge: "bg-purple-500/20 text-purple-300 border-purple-500/30",
              iconColor: "text-purple-400",
              laserGradient: "from-purple-500 to-pink-500"
            },
            { 
              title: "Diode 808nm", 
              desc: "Hız ve derinlik dengesi. Büyük vücut alanlarında maksimum verim ve konfor sağlayan klasik dalga boyu.",
              target: "Tüm Kıl Tipleri",
              color: "from-red-500/10 to-orange-500/5 hover:border-red-500/40 hover:shadow-red-500/5",
              glow: "bg-red-500/10",
              badge: "bg-red-500/20 text-red-300 border-red-500/30",
              iconColor: "text-red-400",
              laserGradient: "from-red-500 to-orange-500"
            },
            { 
              title: "Diode 940nm", 
              desc: "Derin kıl köklerine ulaşım. Mikro damarları besleyen kökleri bloke eden ileri teknoloji dalga boyu.",
              target: "Derin Kıl Kökleri",
              color: "from-amber-500/10 to-yellow-500/5 hover:border-amber-500/40 hover:shadow-amber-500/5",
              glow: "bg-amber-500/10",
              badge: "bg-amber-500/20 text-amber-300 border-amber-500/30",
              iconColor: "text-amber-400",
              laserGradient: "from-amber-500 to-yellow-500"
            },
            { 
              title: "Nd:YAG 1064nm", 
              desc: "Bronz ve koyu ciltler (Fitzpatrick IV-VI) için dünyanın en güvenli ve acısız lazer standardı.",
              target: "Bronz & Koyu Ten",
              color: "from-cyan-500/10 to-blue-500/5 hover:border-cyan-500/40 hover:shadow-cyan-500/5",
              glow: "bg-cyan-500/10",
              badge: "bg-cyan-500/20 text-cyan-300 border-cyan-500/30",
              iconColor: "text-cyan-400",
              laserGradient: "from-cyan-500 to-blue-500"
            }
          ].map((w) => (
            <div class={`relative group overflow-hidden rounded-3xl border border-white/10 bg-gradient-to-b ${w.color} backdrop-blur-md p-6 shadow-xl transition-all duration-500 hover:-translate-y-1 hover:shadow-2xl`}>
              <!-- Glow background -->
              <div class={`absolute top-0 right-0 w-24 h-24 rounded-full blur-2xl transition-opacity duration-500 opacity-20 group-hover:opacity-80 ${w.glow}`} aria-hidden="true"></div>
              
              <div class="relative z-10 flex flex-col h-full justify-between">
                <div>
                  <div class="flex items-center justify-between mb-4">
                    <span class={`px-2.5 py-0.5 text-[10px] rounded-full border font-semibold tracking-wider ${w.badge}`}>
                      {w.target}
                    </span>
                    <svg xmlns="http://www.w3.org/2000/svg" class={`w-5 h-5 ${w.iconColor} group-hover:animate-pulse`} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" />
                    </svg>
                  </div>
                  
                  <h4 class="font-display text-lg font-bold text-white group-hover:text-cyan-300 transition-colors duration-300 mb-2">
                    {w.title}
                  </h4>
                  
                  <p class="text-xs text-white/70 leading-relaxed group-hover:text-white/90 transition-colors duration-300">
                    {w.desc}
                  </p>
                </div>
                
                <!-- Hover indicator line -->
                <div class="w-full h-1 mt-6 rounded-full bg-white/10 overflow-hidden">
                  <div class={`h-full w-0 group-hover:w-full transition-all duration-700 bg-gradient-to-r ${w.laserGradient}`}></div>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- WHY US / ADVANTAGES -->
    <section id="why-us" class="py-24 bg-white">
      <div class="mx-auto max-w-6xl px-5">
        <SectionHeader label="Neden Biz?" title="Mr. Falcon Beauty Farkı" />

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          {whyUsItems.tr.map((item) => (
            <InfoCard icon={item.icon} title={item.title} description={item.desc} variant="hover-border" />
          ))}
        </div>
      </div>
    </section>

    <!-- 7-STEP PROCESS -->
    <section id="process" class="py-16 bg-sky-light/30">
      <div class="mx-auto max-w-6xl px-5">
        <SectionHeader label="Süreç" title="7 Adımda Güvenli Lazer Epilasyon" />

        <div class="space-y-6">
          {processSteps.home.tr.map((step) => (
            <StepCard step={step.step} title={step.title} description={step.desc} />
          ))}
        </div>

        <div class="mt-12 grid md:grid-cols-3 gap-6 text-center">
          {[
            { value: "6-8", label: "Ortalama Seans" },
            { value: "15-20dk", label: "Vücut Seans Süresi" },
            { value: "%95+", label: "Kıl Azalma Hedefi" },
          ].map((m) => (
            <div class="rounded-2xl bg-white p-6 border border-black/5">
              <div class="font-display text-3xl font-bold text-black md:text-4xl">{m.value}</div>
              <div class="text-sm text-black/60">{m.label}</div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- MÜŞTERİ YORUMLARI -->
    <section id="comments" class="py-24 bg-white">
      <div class="mx-auto max-w-6xl px-5">
        <SectionHeader label="Gerçek Müşteriler" title="Müşterilerimiz Ne Diyor?" description="Tüm yorumlar Google Haritalar'dan doğrulanmış gerçek müşterilerimize aittir." margin="md" />

        <div class="columns-1 gap-6 sm:columns-2 lg:columns-3">
          {reviews.slice(0, 9).map((r) => (
            <ReviewCard review={r} locale="tr" />
          ))}
        </div>

        <div class="mt-10 text-center">
          <a href="/yorumlar" class="font-semibold text-black underline-offset-4 hover:text-primary hover:underline">
            Tüm Google yorumlarını gör (58+) →
          </a>
        </div>
      </div>
    </section>

    <!-- GALLERY / CLINIC PHOTOS -->
    <section id="gallery" class="py-20 bg-sky-light/30">
      <div class="mx-auto max-w-6xl px-5">
        <SectionHeader label="Merkezlerimiz" title="Mr. Falcon Beauty Şubeler" margin="md" />

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
          {clinicGallery.slice(0, 6).map((img, i) => (
            <article class="relative rounded-2xl overflow-hidden group cursor-pointer aspect-[4/3]" data-gallery-item>
              <img
                src={img.src}
                alt={img.alt}
                class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105 group-[.is-active]:scale-105"
                loading={i < 3 ? "eager" : "lazy"}
              />
              <div class="absolute inset-0 bg-gradient-to-t from-navy/80 to-transparent opacity-0 group-hover:opacity-100 group-[.is-active]:opacity-100 transition-opacity duration-300 flex items-end p-4">
                <div>
                  <p class="text-white font-semibold">{img.alt}</p>
                  <p class="text-xs text-primary">{img.location}</p>
                </div>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <script>
      document.querySelectorAll("[data-gallery-item]").forEach((el) => {
        el.addEventListener("click", () => {
          document.querySelectorAll("[data-gallery-item].is-active").forEach((a) => {
            if (a !== el) a.classList.remove("is-active");
          });
          el.classList.toggle("is-active");
        });
        document.addEventListener("click", (e) => {
          if (!el.contains(e.target as Node)) el.classList.remove("is-active");
        });
      });
    </script>

    <!-- CONTACT / APPOINTMENT FORM -->
    <section id="contacts" class="py-24 bg-white">
      <div class="mx-auto max-w-6xl px-5">
        <div class="grid lg:grid-cols-2 gap-12">
          <AppointmentForm locale="tr" branches={branches} turnstileEnabled={true} />

          <div class="space-y-8">
            <BranchMap branch={branches[1].data} />
            <div class="grid sm:grid-cols-2 gap-6">
              {branches.map((b) => <ClinicCard branch={b.data} />)}
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ ACCORDION -->
    <section id="faq" class="py-20 bg-navy text-white">
      <div class="mx-auto max-w-3xl px-5">
        <SectionHeader label="Sık Sorulan Sorular" title="SSS — Lazer Epilasyon Hakkında Her Şey" variant="dark" margin="md" />

        <FaqAccordion items={faqs} tone="dark" />

        <p class="mt-10 text-center text-sm text-white/60">
          Sorunuz listede yok mu? <a href="https://wa.me/905525939890" target="_blank" rel="noopener" class="text-primary hover:underline">WhatsApp'tan sorun</a>
        </p>
      </div>
    </section>

    <BookingCta locale="tr" />
  </main>

  <Footer locale="tr" />
</BaseLayout>
