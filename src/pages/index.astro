---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import VideoGallery from "../components/VideoGallery.astro";
import PressSlider from "../components/PressSlider.astro";
import FaqAccordion from "../components/FaqAccordion.astro";
import ReviewCard from "../components/ReviewCard.astro";
import ClinicCard from "../components/ClinicCard.astro";
import BranchMap from "../components/BranchMap.astro";
import StatGrid from "../components/StatGrid.astro";
import BookingCta from "../components/BookingCta.astro";
import { reviews } from "../data/reviews";
import { getCollection } from "astro:content";
import { trustSignals } from "../data/trustSignals";
import { siteMetrics } from "../data/siteMetrics";
import { processSteps } from "../data/processSteps";
import { falconTechSpecs } from "../data/falconTechSpecs";
import { whyUsItems } from "../data/whyUsItems";
import { clinicGallery } from "../data/clinicGallery";
import { satisfactionVideos, faqVideos, pressVideos } from "../data/videos";

const branches = (await getCollection("branches")).sort((a, b) => a.data.slug.localeCompare(b.data.slug));
const faqEntries = (await getCollection("faq", (e) => e.id.startsWith("tr/"))).sort((a, b) => a.data.order - b.data.order);
const faqs = faqEntries.map((e) => ({ q: e.data.question, a: e.data.answer }));

const laserScience = [
  { icon: "🎯", title: "Seçici Fototermoliz", desc: "Lazer ışığı melanozitler tarafından emilerek kıl kökünü ısıtır, çevre dokuları korur." },
  { icon: "🔬", title: "Anagen Fazı Hedefleme", desc: "Sadece büyüme aşamasındaki (anagen) kıllar etkilendiği için birden fazla seans gerekir." },
  { icon: "🌈", title: "4 Dalga Boyu Avantajı", desc: "755nm (ince/koyu kıl), 808nm (hız), 940nm (derinlik), 1064nm (bronz cilt) - hepsi bir arada." },
  { icon: "🤖", title: "AI Enerji Optimizasyonu", desc: "Cihaz cilt tipini (Fitzpatrick I-VI) tarar, kıl kalınlığını ölçer, joule/ms/Hz'yi otomatik set eder." },
  { icon: "❄️", title: "Safir Kontak Soğutma", desc: "-20°C başlık sıcaklığı ile epiderme korunur, dermis hedeflenir. Ağrı sinyali bloke edilir." },
  { icon: "🛡️", title: "Güvenlik Protokolleri", desc: "Test atışı zorunlu, gözlük zorunlu, UVC dezenfeksiyon, tek kullanımlık kapak, cilt soğutma jeli." },
];
---

<BaseLayout
  title="Mr. Falcon Beauty | Lazer Epilasyon Merkezi Mecidiyeköy & Halkalı & Küçükçekmece"
  description="Falcon 4 Pro teknolojisiyle ağrısız, hızlı ve kalıcı lazer epilasyon. İstanbul Şişli/Mecidiyeköy ve Halkalı/Küçükçekmece şubelerinde uzman kadro. İlk danışmanlık ücretsiz."
  locale="tr"
  path="/"
>
  <Header locale="tr" />

  <main>
    <!-- HERO SECTION - GSAP + Lenis Enhanced -->
    <section id="hero" class="relative overflow-hidden bg-gradient-to-b from-sky-light to-white" data-hero>
      <div class="pointer-events-none absolute inset-0 overflow-hidden" aria-hidden="true">
        <div class="absolute top-1/4 left-1/4 w-[300px] h-[300px] md:w-[600px] md:h-[600px] bg-primary/10 rounded-full blur-3xl animate-blob-slow" style="animation-duration: 20s;"></div>
        <div class="absolute bottom-1/4 right-1/4 w-[250px] h-[250px] md:w-[500px] md:h-[500px] bg-sky/10 rounded-full blur-3xl animate-blob-slow" style="animation-duration: 25s; animation-delay: -5s;"></div>
        <div id="hero-particles" class="absolute inset-0"></div>
      </div>

      <div class="border-b border-black/5 bg-white/50 backdrop-blur sticky top-16 z-40" data-animate="trust-bar" data-gsap-trigger="trust-bar">
        <div class="mx-auto flex max-w-7xl items-center justify-center gap-4 px-5 py-3 text-sm font-medium text-black/70 md:py-2">
          <div class="flex flex-wrap items-center justify-center gap-3 text-xs md:gap-6 md:text-sm" data-gsap="stagger" data-gsap-delay="0.1">
            {trustSignals.tr.map((t) => (
              <span class="flex items-center gap-1.5 text-primary">{t.icon} <strong>{t.text}</strong></span>
            ))}
          </div>
        </div>
      </div>

      <div class="mx-auto max-w-7xl px-5 py-20 md:py-28 lg:py-32 relative z-10">
        <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
          <div class="text-center lg:text-left" data-hero-content>
            <p class="mb-6 text-sm font-semibold uppercase tracking-[0.25em] text-primary" data-gsap="fadeUp" data-gsap-delay="0.1">
              Falcon 4 Pro Technology
            </p>

            <h1 class="mb-8 font-display text-4xl font-semibold leading-tight text-black md:text-6xl lg:text-7xl xl:text-8xl" data-gsap-split="lines" data-gsap="splitLines" data-gsap-delay="0.2">
              Ağrısız Lazer Epilasyonun
              <br />
              <span class="text-primary relative">Yeni Standardı</span>
            </h1>

            <p class="mb-10 max-w-xl text-lg leading-relaxed text-black/70 mx-auto lg:mx-0" data-gsap="fadeUp" data-gsap-delay="0.4">
              Dört dalga boyu, yapay zeka destekli kontrol ve -20°C safir soğutma ile tanışın.
              İstanbul'un iki yakasında Mr. Falcon Beauty farkı.
            </p>

            <div class="flex flex-col sm:flex-row items-stretch sm:items-center justify-center gap-4 lg:justify-start mb-10" data-gsap="stagger" data-gsap-delay="0.5">
              <a
                href="#contacts"
                class="group relative text-center rounded-full bg-navy px-8 py-3.5 font-semibold text-white transition-all duration-300 hover:bg-primary hover:shadow-[0_20px_40px_-12px_rgba(14,116,144,0.4)]"
                data-hover="scale"
                data-gsap="fadeUp"
              >
                <span class="relative z-10">Ücretsiz Analiz & Randevu</span>
                <span class="absolute inset-0 rounded-full bg-primary/20 opacity-0 group-hover:opacity-100 transition-opacity duration-300 blur-xl" aria-hidden="true"></span>
              </a>
              <a
                href="#falcon-4-pro"
                class="group relative text-center rounded-full border-2 border-black/15 px-8 py-3.5 font-semibold text-black transition-all duration-300 hover:border-primary hover:text-primary hover:bg-primary/5"
                data-hover="scale"
                data-gsap="fadeUp"
              >
                <span class="relative z-10">Teknolojiyi Keşfet</span>
                <svg class="absolute left-0 top-1/2 -translate-y-1/2 w-5 h-5 text-black/40 group-hover:translate-x-1 group-hover:text-primary transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
                </svg>
              </a>
            </div>

            <div class="flex flex-wrap items-center justify-center gap-3 md:gap-6 lg:justify-start" data-gsap="stagger" data-gsap-delay="0.6">
              <div class="flex items-center gap-2 text-sm text-black/60" data-gsap="fadeUp">
                <svg class="w-4 h-4 text-primary flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                <span>İlk danışmanlık ücretsiz</span>
              </div>
              <div class="flex items-center gap-2 text-sm text-black/60" data-gsap="fadeUp">
                <svg class="w-4 h-4 text-primary flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                <span>Cilt & kıl analizi dahil</span>
              </div>
              <div class="flex items-center gap-2 text-sm text-black/60" data-gsap="fadeUp">
                <svg class="w-4 h-4 text-primary flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                <span>Test atışı yapılır</span>
              </div>
            </div>

            <div class="mt-16 flex flex-col items-center lg:items-start" data-gsap="fadeUp" data-gsap-delay="0.8">
              <p class="mb-2 text-xs uppercase tracking-wider text-black/40">Keşfetmek için kaydırın</p>
              <div class="relative w-6 h-10 rounded-full border border-black/15 flex items-center justify-center">
                <div class="w-1.5 h-1.5 rounded-full bg-primary animate-bounce" style="animation-duration: 1.5s;"></div>
              </div>
            </div>
          </div>

          <div class="relative" data-hero-visual>
            <div class="relative rounded-3xl overflow-hidden shadow-2xl bg-navy/5" data-gsap="parallax" data-gsap-speed="0.3">
              <img
                src="/images/sliderdoctor.png"
                alt="Falcon 4 Pro cihazı ve Mr. Falcon Beauty klinik ortamı"
                class="w-full object-cover transition-transform duration-1000 ease-out"
                loading="eager"
                data-gsap="reveal"
              />

              <div class="absolute top-6 right-6 hidden lg:flex flex-col gap-3" data-gsap="stagger" data-gsap-delay="0.3">
                {[
                  { icon: "🎯", text: "4 Dalga Boyu" },
                  { icon: "🤖", text: "AI Kontrol" },
                  { icon: "❄️", text: "-20°C Soğutma" },
                  { icon: "🛡️", text: "UVC Hijyen" },
                ].map((badge) => (
                  <div class="group relative px-4 py-3 bg-white/90 backdrop-blur rounded-xl shadow-lg border border-black/5 transition-all duration-300 hover:shadow-xl hover:-translate-x-1 hover:border-primary/30" data-gsap="fadeRight">
                    <div class="flex items-center gap-2">
                      <span class="text-xl">{badge.icon}</span>
                      <span class="font-semibold text-black text-sm">{badge.text}</span>
                    </div>
                    <div class="absolute bottom-0 left-0 right-0 h-0.5 bg-primary origin-left group-hover:origin-right scale-x-0 group-hover:scale-x-100 transition-transform duration-300" aria-hidden="true"></div>
                  </div>
                ))}
              </div>
            </div>

            <div class="absolute -top-12 -right-12 w-32 h-32 border-t-2 border-r-2 border-primary/20 rounded-tr-3xl opacity-50" aria-hidden="true"></div>
            <div class="absolute -bottom-12 -left-12 w-32 h-32 border-b-2 border-l-2 border-primary/20 rounded-bl-3xl opacity-50" aria-hidden="true"></div>

            <div class="absolute -bottom-6 left-1/2 -translate-x-1/2 md:left-auto md:-translate-x-0 md:-bottom-8 md:-left-8 p-4 md:p-8 bg-white/95 backdrop-blur rounded-2xl shadow-2xl max-w-[calc(100%-2rem)] md:max-w-xs border border-black/5 z-20" data-gsap="float" data-gsap-delay="0.5">
              <div class="flex items-center gap-3 text-primary text-2xl font-display font-bold">
                <span class="animate-pulse" style="animation-duration: 2s;">⭐</span>
                <span data-gsap="counter" data-target="5.0" data-decimals="1" data-suffix="" data-prefix="" data-duration="2">5.0</span>
              </div>
              <p class="mt-1 text-sm text-black/70">Google'de 58+ değerlendirmede</p>
              <div class="mt-4 flex flex-wrap items-center gap-3 text-xs text-black/60">
                <span class="flex items-center gap-1 px-2 py-1 bg-green-50 text-green-700 rounded-full">✓ FDA/CE Onaylı</span>
                <span class="flex items-center gap-1 px-2 py-1 bg-blue-50 text-blue-700 rounded-full">✓ %95+ Başarı</span>
                <span class="flex items-center gap-1 px-2 py-1 bg-purple-50 text-purple-700 rounded-full">✓ Garanti Paket</span>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="absolute bottom-0 left-0 right-0 overflow-hidden" aria-hidden="true">
        <svg class="w-full h-16 md:h-24" viewBox="0 0 1440 120" preserveAspectRatio="none">
          <path
            fill="url(#heroWaveGradient)"
            fill-opacity="0.1"
            d="M0,64 C300,120 600,0 900,64 C1200,128 1440,64 1440,64 L1440,120 L0,120 Z"
          />
          <defs>
            <linearGradient id="heroWaveGradient" x1="0%" y1="0%" x2="100%" y2="100%">
              <stop offset="0%" stop-color="#17468A" />
              <stop offset="100%" stop-color="#17468A" stop-opacity="0" />
            </linearGradient>
          </defs>
        </svg>
      </div>
    </section>

    <!-- ABOUT US / MR FALCON BEAUTY -->
    <section id="about-us" class="py-20 bg-white">
      <div class="mx-auto max-w-6xl px-5">
        <div class="grid lg:grid-cols-2 gap-12 items-center">
          <div>
            <p class="mb-2 text-sm font-semibold uppercase tracking-[0.2em] text-primary">Mr. Falcon Beauty</p>
            <h2 class="mb-6 font-display text-3xl font-semibold text-black md:text-4xl lg:text-5xl">
              İstanbul'un Güvendiği Lazer Epilasyon Merkezi
            </h2>
            <p class="mb-6 text-lg leading-relaxed text-black/70">
              2014'ten bu yana Şişli/Mecidiyeköy ve Halkalı/Küçükçekmece şubelerimizde 15.000'den fazla müşterimize
              güvenli, etkili ve hijyenik lazer epilasyon hizmeti verdik. Falcon 4 Pro teknolojisiyle ağrıyı, yan etkileri
              ve belirsizliği ortadan kaldırarak "yapay zeka kontrollü, 4 dalga boyulu, soğutmalı" yeni standartı koyduk.
            </p>
            <div class="mb-8">
              <StatGrid items={siteMetrics.tr} class="grid-cols-2 lg:grid-cols-2 gap-6" />
            </div>
            <a href="#falcon-4-pro" class="inline-flex items-center gap-2 font-semibold text-primary hover:text-black transition-colors">
              Falcon 4 Pro Teknolojisi →
            </a>
          </div>

          <div class="relative rounded-3xl overflow-hidden">
            <img
              src="/images/homeabout.png"
              alt="Mr. Falcon Beauty Şişli şubesi iç görünümü"
              class="w-full"
            />
            <div class="absolute bottom-0 left-0 right-0 p-6 md:p-8 bg-gradient-to-t from-navy/90 to-transparent text-white">
              <div class="flex items-center gap-3 text-primary text-xl font-display font-bold">🏆</div>
              <p class="mt-2 text-lg font-medium">Türkiye'nin İlk Falcon 4 Pro Kliniği</p>
              <p class="mt-1 text-sm text-white/80">2024'ten beri İstanbul'da önderlik ediyoruz</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- LASER HAIR REMOVAL INFO -->
    <section id="lazer-epilasyon" class="py-20 bg-sky-light/30">
      <div class="mx-auto max-w-6xl px-5">
        <div class="text-center max-w-3xl mx-auto mb-16">
          <p class="mb-2 text-sm font-semibold uppercase tracking-[0.2em] text-primary">Lazer Epilasyon Nedir?</p>
          <h2 class="font-display text-3xl font-semibold text-black md:text-4xl">
            Kalıcı Kıl Azaltma Bilimi ve Falcon 4 Pro Farkı
          </h2>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          {laserScience.map((item) => (
            <div class="rounded-2xl bg-white p-6 shadow-sm border border-black/5 hover:shadow-md transition-shadow">
              <div class="text-3xl">{item.icon}</div>
              <h3 class="mt-4 font-display text-xl font-semibold text-black">{item.title}</h3>
              <p class="mt-2 text-sm leading-relaxed text-black/70">{item.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- MÜŞTERİ YORUMLARI -->
    <section id="testimonials" class="py-20 bg-white">
      <div class="mx-auto max-w-6xl px-5">
        <div class="text-center max-w-3xl mx-auto mb-12">
          <p class="mb-2 text-sm font-semibold uppercase tracking-[0.2em] text-primary">Gerçek Müşteriler</p>
          <h2 class="font-display text-3xl font-semibold text-black md:text-4xl">Müşterilerimiz Ne Diyor?</h2>
        </div>

        <div class="grid md:grid-cols-3 gap-8">
          {reviews.slice(0, 3).map((r) => (
            <ReviewCard review={r} variant="compact" />
          ))}
        </div>
      </div>
    </section>

    <!-- MEMNUNİYET VİDEOLARI (Danışan Videoları) -->
    <VideoGallery videos={satisfactionVideos.tr} sectionId="satisfaction-videos" class="bg-sky-light/30" />

    <!-- BASINDA HABERLER (Press Videos Slider) -->
    <PressSlider videos={pressVideos} locale="tr" />

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@fancyapps/ui@5.0/dist/fancybox/fancybox.css" />
    <script type="module">
      import { Fancybox } from "https://cdn.jsdelivr.net/npm/@fancyapps/ui@5.0/dist/fancybox/fancybox.esm.js";
      Fancybox.bind('[data-fancybox="press-videos"]', {
        type: "video",
        video: { autoStart: true },
        Toolbar: { display: ["close"] },
        mainClass: "fancybox-press"
      });
    </script>

    <!-- VİDEO GALERİ (SSS Videoları) -->
    <VideoGallery videos={faqVideos.tr} sectionId="video-gallery" />

    <!-- FALCON 4 PRO TECH DEEP DIVE -->
    <section id="falcon-4-pro" class="py-20 bg-navy text-white">
      <div class="mx-auto max-w-6xl px-5">
        <div class="text-center max-w-3xl mx-auto mb-12">
          <p class="mb-2 text-sm font-semibold uppercase tracking-[0.2em] text-primary">Teknoloji</p>
          <h2 class="font-display text-3xl font-semibold md:text-4xl">Falcon 4 Pro — 4 Dalga Boyu, 1 Cihaz</h2>
        </div>

        <div class="grid lg:grid-cols-2 gap-12 items-start">
          <div class="relative rounded-2xl overflow-hidden aspect-[4/3] bg-white/5 flex items-center justify-center">
            <img
              src="/images/falcons.png"
              alt="Falcon 4 Pro cihazı ön görünüm"
              class="w-full h-full object-contain"
            />
          </div>

          <div>
            <h3 class="font-display text-2xl font-semibold text-primary mb-6">Teknoloji Detayları</h3>
            <dl class="space-y-4 text-sm">
              {falconTechSpecs.tr.map((s) => (
                <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between py-3 border-b border-white/10">
                  <dt class="font-medium text-white">{s.label}</dt>
                  <dd class="mt-1 sm:mt-0 text-white font-mono text-xs sm:text-sm">{s.value}</dd>
                </div>
              ))}
            </dl>

            <div class="mt-8 grid sm:grid-cols-2 gap-4">
              {[
                { icon: "🎯", title: "Alexandrite 755nm", desc: "İnce, koyu kıl için altın standardı. Yüksek melanin emilimi." },
                { icon: "⚡", title: "Diode 808nm", desc: "Hız ve derinlik dengesi. Büyük vücut alanlarında verimli." },
                { icon: "🔬", title: "Diode 940nm", desc: "Derin kıl köklerine ulaşım, damarları koruyan uzun dalga boyu." },
                { icon: "☀️", title: "Nd:YAG 1064nm", desc: "Bronz/koyu ciltler (Fitzpatrick IV-VI) için güvenli standart." },
              ].map((w) => (
                <div class="rounded-xl bg-white/5 p-4">
                  <div class="text-2xl">{w.icon}</div>
                  <h4 class="mt-2 font-semibold text-primary">{w.title}</h4>
                  <p class="mt-1 text-xs text-white/80">{w.desc}</p>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- WHY US / ADVANTAGES -->
    <section id="why-us" class="py-20 bg-white">
      <div class="mx-auto max-w-6xl px-5">
        <div class="text-center max-w-3xl mx-auto mb-16">
          <p class="mb-2 text-sm font-semibold uppercase tracking-[0.2em] text-primary">Neden Biz?</p>
          <h2 class="font-display text-3xl font-semibold text-black md:text-4xl">Mr. Falcon Beauty Farkı</h2>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          {whyUsItems.tr.map((item) => (
            <article class="rounded-2xl p-6 border border-black/5 hover:border-primary/30 hover:shadow-lg transition-all">
              <div class="text-3xl">{item.icon}</div>
              <h3 class="mt-4 font-display text-xl font-semibold text-black">{item.title}</h3>
              <p class="mt-2 text-sm leading-relaxed text-black/70">{item.desc}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- 7-STEP PROCESS -->
    <section id="process" class="py-20 bg-sky-light/30">
      <div class="mx-auto max-w-6xl px-5">
        <div class="text-center max-w-3xl mx-auto mb-16">
          <p class="mb-2 text-sm font-semibold uppercase tracking-[0.2em] text-primary">Süreç</p>
          <h2 class="font-display text-3xl font-semibold text-black md:text-4xl">7 Adımda Güvenli Lazer Epilasyon</h2>
        </div>

        <div class="space-y-6">
          {processSteps.home.tr.map((step) => (
            <article class="relative flex gap-6 p-6 bg-white rounded-2xl border border-black/5 hover:shadow-md transition-shadow">
              <div class="flex-shrink-0 w-12 h-12 rounded-full bg-sky-light/50 flex items-center justify-center font-display text-xl font-bold text-primary">
                {step.step}
              </div>
              <div class="flex-1 pt-1">
                <h3 class="font-display text-lg font-semibold text-black">{step.title}</h3>
                <p class="mt-1 text-sm text-black/70">{step.desc}</p>
              </div>
            </article>
          ))}
        </div>

        <div class="mt-12 grid md:grid-cols-3 gap-6 text-center">
          {[
            { value: "6-8", label: "Ortalama Seans" },
            { value: "15-20dk", label: "Vücut Seans Süresi" },
            { value: "%95+", label: "Kıl Azalma Hedefi" },
          ].map((m) => (
            <div class="rounded-2xl bg-white p-6 border border-black/5">
              <div class="font-display text-3xl font-bold text-black md:text-4xl">{m.value}</div>
              <div class="text-sm text-black/60">{m.label}</div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- VERIFIED REVIEWS (9) -->
    <section id="comments" class="py-20 bg-white">
      <div class="mx-auto max-w-6xl px-5">
        <div class="text-center max-w-3xl mx-auto mb-12">
          <p class="mb-2 text-sm font-semibold uppercase tracking-[0.2em] text-primary">Müşteri Yorumları</p>
          <h2 class="font-display text-3xl font-semibold text-black md:text-4xl">9 Doğrulanmış Google Değerlendirmesi</h2>
          <p class="mt-3 text-sm text-black/60">Tüm yorumlar Google Haritalar'dan doğrulanmış gerçek müşterilerimize aittir.</p>
        </div>

        <div class="grid md:grid-cols-3 gap-6">
          {reviews.slice(0, 9).map((r) => (
            <ReviewCard review={r} />
          ))}
        </div>

        <div class="mt-10 text-center">
          <a href="/yorumlar" class="font-semibold text-black underline-offset-4 hover:text-primary hover:underline">
            Tüm Google yorumlarını gör (58+) →
          </a>
        </div>
      </div>
    </section>

    <!-- GALLERY / CLINIC PHOTOS -->
    <section id="gallery" class="py-20 bg-sky-light/30">
      <div class="mx-auto max-w-6xl px-5">
        <div class="text-center max-w-3xl mx-auto mb-12">
          <p class="mb-2 text-sm font-semibold uppercase tracking-[0.2em] text-primary">Merkezlerimiz</p>
          <h2 class="font-display text-3xl font-semibold text-black md:text-4xl">Mr. Falcon Beauty Şubeler</h2>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
          {clinicGallery.slice(0, 6).map((img, i) => (
            <article class="relative rounded-2xl overflow-hidden group">
              <img
                src={img.src}
                alt={img.alt}
                class="w-full transition-transform duration-500 group-hover:scale-105"
                loading={i < 3 ? "eager" : "lazy"}
              />
              <div class="absolute inset-0 bg-gradient-to-t from-navy/80 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end p-4">
                <div>
                  <p class="text-white font-semibold">{img.alt}</p>
                  <p class="text-xs text-primary">{img.location}</p>
                </div>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- CONTACT / APPOINTMENT FORM -->
    <section id="contacts" class="py-20 bg-white">
      <div class="mx-auto max-w-6xl px-5">
        <div class="grid lg:grid-cols-2 gap-12">
          <div>
            <h2 class="font-display text-3xl font-semibold text-black mb-2">Ücretsiz Cilt & Kıl Analizi</h2>
            <p class="text-black/70 mb-8">Formu doldurun, 15 dakika içinde size dönelim. Şube tercihinizi belirtin.</p>

            <form id="appointment-form" class="space-y-5" action="/api/contact" method="POST">
              <input type="hidden" name="form_type" value="appointment" />
              <input type="hidden" name="locale" value="tr" />

              <div class="grid sm:grid-cols-2 gap-5">
                <div>
                  <label for="name" class="block text-sm font-medium text-black/70 mb-1">Ad Soyad *</label>
                  <input type="text" id="name" name="name" required class="w-full rounded-lg border border-black/15 bg-white px-4 py-3 text-sm text-black focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary" placeholder="Adınız Soyadınız" />
                </div>
                <div>
                  <label for="phone" class="block text-sm font-medium text-black/70 mb-1">Telefon *</label>
                  <input type="tel" id="phone" name="phone" required class="w-full rounded-lg border border-black/15 bg-white px-4 py-3 text-sm text-black focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary" placeholder="05XX XXX XX XX" />
                </div>
              </div>

              <div>
                <label for="email" class="block text-sm font-medium text-black/70 mb-1">E-posta</label>
                <input type="email" id="email" name="email" class="w-full rounded-lg border border-black/15 bg-white px-4 py-3 text-sm text-black focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary" placeholder="ornek@email.com" />
              </div>

              <div>
                <label for="clinic" class="block text-sm font-medium text-black/70 mb-1">Şube Tercihi *</label>
                <select id="clinic" name="clinic" required class="w-full rounded-lg border border-black/15 bg-white px-4 py-3 text-sm text-black focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary">
                  <option value="">Şube Seçiniz</option>
                  {branches.map((b) => <option value={b.data.slug}>{b.data.name}</option>)}
                </select>
              </div>

              <div>
                <label for="concern" class="block text-sm font-medium text-black/70 mb-1">İlgi Alanı / Bölge</label>
                <select id="concern" name="concern" class="w-full rounded-lg border border-black/15 bg-white px-4 py-3 text-sm text-black focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary">
                  <option value="">Seçiniz</option>
                  <option value="full-body">Tüm Vücut</option>
                  <option value="face-neck">Yüz & Boyun</option>
                  <option value="underarm">Koltuk Altı</option>
                  <option value="bikini">Bikini / Brezilya</option>
                  <option value="legs">Bacak (Tam)</option>
                  <option value="arms">Kol (Tam)</option>
                  <option value="back-chest">Sırt / Göğüs (Erkek)</option>
                  <option value="other">Diğer</option>
                </select>
              </div>

              <div>
                <label for="message" class="block text-sm font-medium text-black/70 mb-1">Not / Mesaj</label>
                <textarea id="message" name="message" rows="3" class="w-full rounded-lg border border-black/15 bg-white px-4 py-3 text-sm text-black focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary" placeholder="Özel durum, hormon tedavisi, önceki lazer geçmişi vb."></textarea>
              </div>

              <div class="flex items-start gap-2 text-sm text-black/60">
                <input type="checkbox" id="kvkk" name="kvkk" required class="mt-1 w-4 h-4 rounded border-black/30 text-primary focus:ring-primary" />
                <label for="kvkk">KVKK aydınlatma metnini okudum, onaylıyorum. Verilerim randevu için işlensin.</label>
              </div>

              <div class="cf-turnstile" data-sitekey="0x4AAAAAAAe3UYEAyXZ5Iqy4vEMqCLYzNB8" data-theme="light" data-callback="onTurnstileCallback"></div>
              <button type="submit" class="w-full sm:w-auto rounded-full bg-navy px-8 py-3 font-semibold text-white transition-colors hover:bg-primary">
                Ücretsiz Analiz İste & Randevu Al
              </button>

              <p id="form-message" class="hidden text-sm" aria-live="polite"></p>
            </form>
          </div>

          <div class="space-y-8">
            <BranchMap branch={branches[1].data} />
            <div class="grid sm:grid-cols-2 gap-6">
              {branches.map((b) => <ClinicCard branch={b.data} />)}
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ ACCORDION -->
    <section id="faq" class="py-20 bg-navy text-white">
      <div class="mx-auto max-w-3xl px-5">
        <div class="text-center mb-12">
          <p class="mb-2 text-sm font-semibold uppercase tracking-[0.2em] text-primary">Sık Sorulan Sorular</p>
          <h2 class="font-display text-3xl font-semibold md:text-4xl">SSS — Lazer Epilasyon Hakkında Her Şey</h2>
        </div>

        <FaqAccordion items={faqs} tone="dark" />

        <p class="mt-10 text-center text-sm text-white/60">
          Sorunuz listede yok mu? <a href="https://wa.me/905525939890" target="_blank" rel="noopener" class="text-primary hover:underline">WhatsApp'tan sorun</a>
        </p>
      </div>
    </section>

    <BookingCta locale="tr" />
  </main>

  <Footer locale="tr" />

  <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
  <script>
    // Form submit via fetch
    document.getElementById('appointment-form')?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const form = e.target;
      const msgEl = document.getElementById('form-message');
      const btn = form.querySelector('button[type="submit"]');
      const originalText = btn.textContent;
      btn.disabled = true;
      btn.textContent = 'Gönderiliyor...';
      msgEl.classList.add('hidden');

      try {
        const formData = new FormData(form);
        const res = await fetch('/api/contact', {
          method: 'POST',
          body: formData,
        });
        const data = await res.json();
        if (res.ok && data.success) {
          msgEl.textContent = '✅ ' + (data.message || 'Randevu talebiniz alındı! 15 dk içinde size dönüş yapacağız.');
          msgEl.className = 'text-green-700';
          form.reset();
          if (typeof turnstile !== 'undefined') turnstile.reset();
        } else {
          throw new Error(data.message || 'Bir hata oluştu');
        }
      } catch (err) {
        msgEl.textContent = '❌ ' + (err.message || 'Gönderim başarısız, lütfen WhatsApp\'tan yazın.');
        msgEl.className = 'text-red-700';
        if (typeof turnstile !== 'undefined') turnstile.reset();
      } finally {
        msgEl.classList.remove('hidden');
        btn.disabled = false;
        btn.textContent = originalText;
      }
    });

    // Clinic selector from URL
    const urlParams = new URLSearchParams(window.location.search);
    const clinicParam = urlParams.get('clinic');
    if (clinicParam) {
      const select = document.getElementById('clinic');
      if (select) select.value = clinicParam;
    }
  </script>
</BaseLayout>
