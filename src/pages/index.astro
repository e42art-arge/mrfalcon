---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const trustSignals = [
  { icon: "🏆", text: "15.000+" },
  { icon: "⭐", text: "4.9/5" },
  { icon: "🏥", text: "2 Şube" },
  { icon: "⚡", text: "Falcon 4 Pro" },
];

const clinics = [
  { id: "sisli", name: "Şişli / Mecidiyeköy", address: "Mecidiyeköy Mah. Büyükdere Cad. No:123" },
  { id: "halkali", name: "Halkalı / Küçükçekmece", address: "Halkalı Merkez Mah. İstiklal Cad. No:45" },
];

const aboutMetrics = [
  { value: "15.000+", label: "Mutlu Müşteri" },
  { value: "4.9/5", label: "Google Değerlendirme" },
  { value: "2", label: "İstanbul Şubesi" },
  { value: "10+", label: "Yıl Deneyim" },
];

const advantages = [
  { icon: "🎯", title: "4 Dalga Boyu", desc: "755nm Alexandrite, 810nm Diode, 940nm ve 1064nm Nd:YAG tek cihazda. Her cilt tipi ve kıl rengi için optimize edilmiş." },
  { icon: "🤖", title: "AI Cilt Analizi", desc: "Yapay zeka destekli cilt ve kıl analizi ile her müşteriye özel enerji parametreleri belirlenir." },
  { icon: "❄️", title: "Safir Soğutma", desc: "-10°C'a kadar soğutma ile epilasyon sırasında neredeyse sıfır ağrı hissi." },
  { icon: "☀️", title: "4 Mevsim Güvenli", desc: "Nd:YAG 1064nm sayesinde bronz ciltlerde ve yaz aylarında da güvenli uygulama." },
  { icon: "🦠", title: "UVC Hijyen", desc: "Her seans öncesi başlık UVC ışığıyla dezenfekte edilir, tek kullanımlık kapak kullanılır." },
  { icon: "⚡", title: "Hızlı Seans", desc: "4 cm² spot boyu ve 10 Hz frekans ile vücut epilasyonu 15-20 dakikada tamamlanır." },
];

const processSteps = [
  { step: 1, title: "Ücretsiz Analiz", desc: "Uzman ekibimiz cilt tipinizi, kıl kalınlığını ve renkini analiz eder. Kişiye özel protokol hazırlanır." },
  { step: 2, title: "Test Atışı", desc: "Küçük bir test alanı uygulanarak cilt tepkisi ve enerji toleransı ölçülür. Güvenlik önceliklidir." },
  { step: 3, title: "Protokol Belirleme", desc: "Falcon 4 Pro'nun 4 dalga boyu üzerinden cilt tipinize özel parametreler (joules, ms, Hz) set edilir." },
  { step: 4, title: "Uygulama", desc: "Soğutmalı başlıkla ağrısız, hızlı ve hijyenik seans. Her vurışta UVC dezenfeksiyon." },
  { step: 5, title: "Sonrası Bakım", desc: "Soğutucu jel, SPF50+ koruyucu ve takip takvimi verilir. Yan etki riski minimize edilir." },
  { step: 6, title: "Seans Takibi", desc: "Her seans sonrası kıl azalma oranı ölçülür, parametreler güncellenir. Ortalama 6-8 seans." },
  { step: 7, title: "Sonuç & Garanti", desc: "%95+ kıl azalma hedeflenir. Yılın sonuna kadar ücretsiz kontrol seansları dahil." },
];

const reviews = [
  { name: "Elif K.", branch: "Şişli", quote: "Ağrısız ve çok hızlı, sonuçlar harika. 6 seansda %95 kıl kalmadı.", rating: 5, source: "Google" },
  { name: "Merve A.", branch: "Halkalı", quote: "Personel çok ilgili, ortam çok hijyenik. Arkadaşlarıma da tavsiye ettim.", rating: 5, source: "Google" },
  { name: "Zeynep D.", branch: "Şişli", quote: "Falcon 4 Pro farkı gerçekten hissediliyor. Bronz ciltimde bile güvenliydi.", rating: 5, source: "Google" },
  { name: "Ayşe Y.", branch: "Halkalı", quote: "Uzun yıllar denedim, en etkili bu oldu. Randevu sistemi de çok pratik.", rating: 5, source: "Google" },
  { name: "Selin Ö.", branch: "Şişli", quote: "Kusursuz hijyen, uzman kadro. İlk seanstaki test atışı beni çok güvendirdi.", rating: 5, source: "Google" },
  { name: "Buse T.", branch: "Halkalı", quote: "Yazın bronz ciltle bile yaptırdım, yan etki yok. Teknoloji harika.", rating: 5, source: "Google" },
  { name: "Ceren K.", branch: "Şişli", quote: "Randevu hatırlatmaları, takip mesajları... Müşteri odaklılık hissediliyor.", rating: 5, source: "Google" },
  { name: "Derya M.", branch: "Halkalı", quote: "Fiyat/performans çok iyi. Paket aldım, seans başı çok uygun geldi.", rating: 5, source: "Google" },
  { name: "Gizem S.", branch: "Şişli", quote: "Kadın ve erkek için ayrı alanlar, gizlilik harika. Tavsiye ederim.", rating: 5, source: "Google" },
];

const faqs = [
  { q: "Lazer epilasyon ağrılı mı?", a: "Falcon 4 Pro'nun -10°C safir soğutma sistemi sayesinde işlem neredeyse ağrısızdır. Hassas bölgelerde hafif bir ısı hissi olabilir." },
  { q: "Kaç seans gerekir?", a: "Ortalama 6-8 seans.%95+ kıl azalma hedeflenir. Cilt tipi, kıl kalınlığı ve hormon durumu seans sayısını etkiler." },
  { q: "Bronz ciltim var, yaz yapabilir miyim?", a: "Evet. Nd:YAG 1064nm dalga boyu melanozitleri hedef almadığı için bronz ve koyu ciltlerde de güvenle uygulanır." },
  { q: "Seans arası ne kadar süre olmalı?", a: "Yüz ve boyun: 4-6 hafta. Vücut: 6-8 hafta. Kıl döngüsüne (anagen faz) göre planlanır." },
  { q: "Yan etkileri nelerdir?", a: "Geçici kızarıklık, hafif şişlik 1-2 saatte geçer. Yanık, leke riski Falcon 4 Pro ile minimize edilmiştir." },
  { q: "Erkekler de yapabilir mi?", a: "Evet. Sırt, göğüs, boynuz, burnun içi gibi bölgelerde erkekler için de uygulanır. Ayrı bekleme alanlarımız vardır." },
  { q: "Hamilelik/doğum sonrası ne zaman?", a: "Hamilelikte uygulanmaz. Doğum sonrası 3-6 ay ve doktor onayıyla başlanabilir. Emzirme döneminde de güvenlidir." },
  { q: "Randevu nasıl alınır?", a: "Web sitemizden, WhatsApp'tan veya telefonla. Şişli ve Halkalı şubelerimizden tercih edebilirsiniz." },
  { q: "Fiyatlandırma nasıl?", a: "Bölgeye ve pakete göre değişir. İlk danışmanlık ve cilt analizi ücretsizdir. Paket alırsanız seans başı daha uygun." },
];

const galleryImages = [
  { src: "/clinic1.jpg", alt: "Şişli Şubesi Resepsiyon", location: "Şişli" },
  { src: "/clinic2.jpg", alt: "Şişli Şubesi Uygulama Odası", location: "Şişli" },
  { src: "/clinic3.jpg", alt: "Halkalı Şubesi Giriş", location: "Halkalı" },
  { src: "/clinic4.jpg", alt: "Halkalı Şubesi Bekleme Alanı", location: "Halkalı" },
  { src: "/c1.jpg", alt: "Falcon 4 Pro Cihazı", location: "Teknoloji" },
  { src: "/c2.jpg", alt: "Falcon 4 Pro Başlık Detayı", location: "Teknoloji" },
];

const videoTestimonials = [
  { name: "Elif K.", branch: "Şişli", quote: "6 seansda hayatım değişti." },
  { name: "Merve A.", branch: "Halkalı", quote: "Hiç acı hissetmedim." },
  { name: "Zeynep D.", branch: "Şişli", quote: "Bronz ciltimde bile güvenliydi." },
];

const falconTechSpecs = [
  { label: "Dalga Boyları", value: "755nm Alexandrite + 810nm Diode + 940nm + 1064nm Nd:YAG" },
  { label: "Spot Boyutu", value: "4 cm² (büyük vücut alanları için optimize)" },
  { label: "Frekans", value: "1-10 Hz (hızlı vücut epilasyonu)" },
  { label: "Soğutma", value: "Safir kristal, -10°C ile +5°C arası ayarlanabilir" },
  { label: "Enerji", value: "1-120 J/cm² (cilt tipine göre AI ile otomatik)" },
  { label: "Nabız Süresi", value: "5-400 ms (ince/kalın kıl için optimize)" },
  { label: "Hijyen", value: "UVC LED dezenfeksiyon + tek kullanımlık başlık kapağı" },
  { label: "Ekran", value: "15.6\" dokunmatik, AI cilt analizi entegre" },
];

const whyUsItems = [
  { icon: "🎓", title: "Uzman Kadro", desc: "Dermatoloji ve tıbbi estetik uzmanı hekim kontrolünde, sertifikalı lazer teknisyenler uygular." },
  { icon: "🔬", title: "FDA/CE Onaylı", desc: "Falcon 4 Pro cihazı FDA ve CE sertifikalı, tıbbi cihaz sınıfındadır (Class IIb)." },
  { icon: "📊", title: "Şeffaf Süreç", desc: "Her seans öncesi/sonrası fotoğraflı takip, kıl sayım raporu ve enerji parametreleri paylaşılır." },
  { icon: "🛡️", title: "Garanti Paket", desc: "Paket alırsanız yıl sonuna kadar ücretsiz kontrol seansı. Sonuç gelmezse para iadesi garantisi." },
  { icon: "📍", title: "İki Kolay Konum", desc: "Mecidiyeköy (Şişli) ve Halkalı (Küçükçekmece) - Metro, metrobüs, otobüsle erişim kolay." },
  { icon: "💬", title: "7/24 Destek", desc: "WhatsApp hattımızdan seans sonrası takip, randevu değişikliği ve sorularınız için anında yanıt." },
];

---

<BaseLayout
  title="Mr. Falcon Beauty | Lazer Epilasyon Merkezi Mecidiyeköy & Halkalı & Küçükçekmece"
  description="Falcon 4 Pro teknolojisiyle ağrısız, hızlı ve kalıcı lazer epilasyon. İstanbul Şişli/Mecidiyeköy ve Halkalı/Küçükçekmece şubelerinde uzman kadro. İlk danışmanlık ücretsiz."
  locale="tr"
  path="/"
>
  <Header locale="tr" />

  <main>
    <!-- HERO / SLIDER -->
    <section id="slider" class="relative overflow-hidden bg-gradient-to-b from-beige to-white">
      <!-- Trust Signals Bar -->
      <div class="border-b border-black/5 bg-white/50 backdrop-blur sticky top-16 z-40">
        <div class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-5 py-3 text-sm font-medium text-black/70 md:py-2">
          <div class="flex flex-wrap items-center gap-6 text-center md:justify-start">
            {trustSignals.map((t) => (
              <span class="flex items-center gap-1.5 text-primary">{t.icon} <strong>{t.text}</strong></span>
            ))}
          </div>
          <div class="flex items-center gap-2 text-xs text-black/50">
            <span>📍 Şube Seç:</span>
            <select id="hero-clinic-select" class="rounded border border-black/15 bg-white px-2 py-1 text-sm text-black focus:border-primary focus:outline-none">
              <option value="/#contacts" selected>Şube Seçiniz</option>
              {clinics.map((c) => (
                <option value={`/#contacts?clinic=${c.id}`}>{c.name}</option>
              ))}
            </select>
          </div>
        </div>
      </div>

      <div class="mx-auto max-w-6xl px-5 py-24 md:py-32">
        <div class="grid lg:grid-cols-2 gap-12 items-center">
          <div class="text-center lg:text-left">
            <p class="mb-4 text-sm font-semibold uppercase tracking-[0.2em] text-primary">Falcon 4 Pro Technology</p>
            <h1 class="mb-6 font-display text-4xl font-semibold leading-tight text-black md:text-6xl lg:text-7xl">
              Ağrısız Lazer Epilasyonun
              <br />
              <span class="text-primary">Yeni Standardı</span>
            </h1>
            <p class="mb-8 max-w-xl text-lg leading-relaxed text-black/70 mx-auto lg:mx-0">
              Dört dalga boyu, yapay zeka destekli kontrol ve -10°C safir soğutma ile tanışın.
              İstanbul'un iki yakasında Mr. Falcon Beauty farkı.
            </p>
            <div class="flex flex-wrap items-center justify-center gap-4 lg:justify-start">
              <a href="#contacts" class="rounded-full bg-navy px-8 py-3 font-semibold text-white transition-colors hover:bg-primary">
                Ücretsiz Analiz & Randevu
              </a>
              <a href="#falcon-4-pro" class="rounded-full border-2 border-black/15 px-8 py-3 font-semibold text-black transition-colors hover:border-primary hover:text-primary">
                Teknolojiyi Keşfet
              </a>
            </div>
            <p class="mt-6 flex items-center justify-center gap-4 text-sm text-black/60 lg:justify-start">
              <span class="flex items-center gap-1.5">✓ İlk danışmanlık ücretsiz</span>
              <span class="flex items-center gap-1.5">✓ Cilt & kıl analizi dahil</span>
              <span class="flex items-center gap-1.5">✓ Test atışı yapılır</span>
            </p>
          </div>

          <div class="relative">
            <div class="relative rounded-3xl overflow-hidden shadow-2xl bg-navy/5">
              <img
                src="/sliderdoctor.png"
                alt="Falcon 4 Pro cihazı ve Mr. Falcon Beauty klinik ortamı"
                class="w-full aspect-[4/3] object-cover"
                loading="eager"
              />
              <div class="absolute -bottom-6 -left-6 md:-bottom-8 md:-left-8 p-6 md:p-8 bg-white rounded-2xl shadow-xl max-w-xs">
                <div class="flex items-center gap-3 text-primary text-2xl font-display font-bold">⭐ 4.9</div>
                <p class="mt-1 text-sm text-black/70">Google'de 200+ değerlendirmede</p>
                <div class="mt-4 flex items-center gap-4 text-xs text-black/60">
                  <span class="flex items-center gap-1">✓ FDA/CE Onaylı</span>
                  <span class="flex items-center gap-1">✓ %95+ Başarı</span>
                  <span class="flex items-center gap-1">✓ Garanti Paket</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ABOUT US / MR FALCON BEAUTY -->
    <section id="about-us" class="py-20 bg-white">
      <div class="mx-auto max-w-6xl px-5">
        <div class="grid lg:grid-cols-2 gap-12 items-center">
          <div>
            <p class="mb-2 text-sm font-semibold uppercase tracking-[0.2em] text-primary">Mr. Falcon Beauty</p>
            <h2 class="mb-6 font-display text-3xl font-semibold text-black md:text-4xl lg:text-5xl">
              İstanbul'un Güvendiği Lazer Epilasyon Merkezi
            </h2>
            <p class="mb-6 text-lg leading-relaxed text-black/70">
              2014'ten bu yana Şişli/Mecidiyeköy ve Halkalı/Küçükçekmece şubelerimizde 15.000'den fazla müşterimize
              güvenli, etkili ve hijyenik lazer epilasyon hizmeti verdik. Falcon 4 Pro teknolojisiyle ağrıyı, yan etkileri
              ve belirsizliği ortadan kaldırarak "yapay zeka kontrollü, 4 dalga boyulu, soğutmalı" yeni standartı koyduk.
            </p>
            <div class="grid grid-cols-2 gap-6 mb-8">
              {aboutMetrics.map((m) => (
                <div class="p-4 rounded-2xl bg-sky-light/50">
                  <div class="font-display text-3xl font-bold text-black md:text-4xl">{m.value}</div>
                  <div class="text-sm text-black/60">{m.label}</div>
                </div>
              ))}
            </div>
            <a href="#falcon-4-pro" class="inline-flex items-center gap-2 font-semibold text-primary hover:text-black transition-colors">
              Falcon 4 Pro Teknolojisi →
            </a>
          </div>

          <div class="relative rounded-3xl overflow-hidden">
            <img
              src="/homeabout.png"
              alt="Mr. Falcon Beauty Şişli şubesi iç görünümü"
              class="w-full aspect-[4/3] object-cover"
            />
            <div class="absolute bottom-0 left-0 right-0 p-6 md:p-8 bg-gradient-to-t from-ink/90 to-transparent text-white">
              <div class="flex items-center gap-3 text-primary text-xl font-display font-bold">🏆</div>
              <p class="mt-2 text-lg font-medium">Türkiye'nin İlk Falcon 4 Pro Kliniği</p>
              <p class="mt-1 text-sm text-white/80">2024'ten beri İstanbul'da önderlik ediyoruz</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- LASER HAIR REMOVAL INFO -->
    <section id="lazer-epilasyon" class="py-20 bg-sky-light/30">
      <div class="mx-auto max-w-6xl px-5">
        <div class="text-center max-w-3xl mx-auto mb-16">
          <p class="mb-2 text-sm font-semibold uppercase tracking-[0.2em] text-primary">Lazer Epilasyon Nedir?</p>
          <h2 class="font-display text-3xl font-semibold text-black md:text-4xl">
            Kalıcı Kıl Azaltma Bilimi ve Falcon 4 Pro Farkı
          </h2>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          {[
            { icon: "🎯", title: "Seçici Fototermoliz", desc: "Lazer ışığı melanozitler tarafından emilerek kıl kökünü ısırdır, çevre dokuları korur." },
            { icon: "🔬", title: "Anagen Fazı Hedefleme", desc: "Sadece büyüme aşamasındaki (anagen) kıllar etkilendiği için birden fazla seans gerekir." },
            { icon: "🌈", title: "4 Dalga Boyu Avantajı", desc: "755nm (ince/koyu kıl), 810nm (hız), 940nm (derinlik), 1064nm (bronz cilt) - hepsi bir arada." },
            { icon: "🤖", title: "AI Enerji Optimizasyonu", desc: "Cihaz cilt tipini (Fitzpatrick I-VI) tarar, kıl kalınlığını ölçer, joule/ms/Hz'yi otomatik set eder." },
            { icon: "❄️", title: "Safir Kontak Soğutma", desc: "-10°C başlık sıcaklığı ile epiderme korunur, dermis hedeflenir. Ağrı sinyali bloke edilir." },
            { icon: "🛡️", title: "Güvenlik Protokolleri", desc: "Test atışı zorunlu, gözlük Zorunlu, UVC dezenfeksiyon, tek kullanımlık kapak, cilt soğutma jeli." },
          ].map((item) => (
            <div class="rounded-2xl bg-white p-6 shadow-sm border border-black/5 hover:shadow-md transition-shadow">
              <div class="text-3xl">{item.icon}</div>
              <h3 class="mt-4 font-display text-xl font-semibold text-black">{item.title}</h3>
              <p class="mt-2 text-sm leading-relaxed text-black/70">{item.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- VIDEO GALLERY / TESTIMONIALS → replaced with static testimonial cards -->
    <section id="video-gallery" class="py-20 bg-white">
      <div class="mx-auto max-w-6xl px-5">
        <div class="text-center max-w-3xl mx-auto mb-12">
          <p class="mb-2 text-sm font-semibold uppercase tracking-[0.2em] text-primary">Gerçek Müşteriler</p>
          <h2 class="font-display text-3xl font-semibold text-black md:text-4xl">Müşterilerimiz Ne Diyor?</h2>
        </div>

        <div class="grid md:grid-cols-3 gap-8">
          {videoTestimonials.map((v) => (
            <article class="rounded-2xl border border-black/10 bg-white p-6 shadow-sm hover:shadow-md transition-shadow">
              <div class="flex gap-1 text-primary text-sm mb-3">★★★★★</div>
              <blockquote class="text-black/80 text-sm leading-relaxed">"{v.quote}"</blockquote>
              <footer class="mt-4 flex items-center justify-between text-sm">
                <cite class="font-semibold text-primary">{v.name}</cite>
                <span class="text-black/50">{v.branch}</span>
              </footer>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- FALCON 4 PRO TECH DEEP DIVE -->
    <section id="falcon-4-pro" class="py-20 bg-navy text-white">
      <div class="mx-auto max-w-6xl px-5">
        <div class="text-center max-w-3xl mx-auto mb-12">
          <p class="mb-2 text-sm font-semibold uppercase tracking-[0.2em] text-primary">Teknoloji</p>
          <h2 class="font-display text-3xl font-semibold md:text-4xl">Falcon 4 Pro — 4 Dalga Boyu, 1 Cihaz</h2>
        </div>

        <div class="grid lg:grid-cols-2 gap-12 items-start">
          <div class="relative rounded-2xl overflow-hidden aspect-[4/3] bg-white/5">
            <img
              src="/falcons.png"
              alt="Falcon 4 Pro cihazı ön görünüm"
              class="w-full h-full object-cover"
            />
          </div>

          <div>
            <h3 class="font-display text-2xl font-semibold text-primary mb-6">Teknoloji Detayları</h3>
            <dl class="space-y-4 text-sm">
              {falconTechSpecs.map((s) => (
                <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between py-3 border-b border-white/10">
                  <dt class="font-medium text-white">{s.label}</dt>
                  <dd class="mt-1 sm:mt-0 text-white font-mono text-xs sm:text-sm">{s.value}</dd>
                </div>
              ))}
            </dl>

            <div class="mt-8 grid sm:grid-cols-2 gap-4">
              {[
                { icon: "🎯", title: "Alexandrite 755nm", desc: "İnce, koyu kıl için altın standardı. Yüksek melanin emilimi." },
                { icon: "⚡", title: "Diode 810nm", desc: "Hız ve derinlik dengesi. Büyük vücut alanlarında verimli." },
                { icon: "🔬", title: "Nd:YAG 940nm", desc: "Derin kıl köklerine ulaşım, damarları koruyan uzun dalga boyu." },
                { icon: "☀️", title: "Nd:YAG 1064nm", desc: "Bronz/koyu ciltler (Fitzpatrick IV-VI) için güvenli standart." },
              ].map((w) => (
                <div class="rounded-xl bg-white/5 p-4">
                  <div class="text-2xl">{w.icon}</div>
                  <h4 class="mt-2 font-semibold text-primary">{w.title}</h4>
                  <p class="mt-1 text-xs text-white/80">{w.desc}</p>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- WHY US / ADVANTAGES -->
    <section id="why-us" class="py-20 bg-white">
      <div class="mx-auto max-w-6xl px-5">
        <div class="text-center max-w-3xl mx-auto mb-16">
          <p class="mb-2 text-sm font-semibold uppercase tracking-[0.2em] text-primary">Neden Biz?</p>
