  { id: 3, thumbnail: "/images/shorts/shorts3.jpg", videoUrl: "/videos/shorts/shorts3.mp4", title: "Sıkça Sorulan Sorular", description: "Falcon 4 Pro & Lazer Epilasyon", category: "faq" },
  { id: 4, thumbnail: "/images/shorts/shorts4.jpg", videoUrl: "/videos/shorts/shorts4.mp4", title: "Sıkça Sorulan Sorular", description: "Falcon 4 Pro & Lazer Epilasyon", category: "faq" },
  { id: 5, thumbnail: "/images/shorts/shorts5.jpg", videoUrl: "/videos/shorts/shorts5.mp4", title: "Sıkça Sorulan Sorular", description: "Falcon 4 Pro & Lazer Epilasyon", category: "faq" },
  { id: 6, thumbnail: "/images/shorts/shorts6.jpg", videoUrl: "/videos/shorts/shorts6.mp4", title: "Sıkça Sorulan Sorular", description: "Falcon 4 Pro & Lazer Epilasyon", category: "faq" },
  { id: 7, thumbnail: "/images/shorts/shorts7.jpg", videoUrl: "/videos/shorts/shorts7.mp4", title: "Sıkça Sorulan Sorular", description: "Falcon 4 Pro & Lazer Epilasyon", category: "faq" },
  { id: 8, thumbnail: "/images/shorts/shorts8.jpg", videoUrl: "/videos/shorts/shorts8.mp4", title: "Sıkça Sorulan Sorular", description: "Falcon 4 Pro & Lazer Epilasyon", category: "faq" },
