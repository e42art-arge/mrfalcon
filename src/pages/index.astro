                aria-controls={`faq-answer-${i}`}
                onclick={() => {
                  const ans = document.getElementById(`faq-answer-${i}`);
                  const isOpen = !ans.hidden;
                  ans.hidden = isOpen;
                  this.setAttribute('aria-expanded', !isOpen);
                  this.querySelector('svg')?.classList.toggle('rotate-180', !isOpen);
                }}
              >
