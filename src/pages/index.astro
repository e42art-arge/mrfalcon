const videoTestimonials = [
  { name: "Elif K.", branch: "Şişli", quote: "6 seansda hayatım değişti." },
  { name: "Merve A.", branch: "Halkalı", quote: "Hiç acı hissetmedim." },
  { name: "Zeynep D.", branch: "Şişli", quote: "Bronz ciltimde bile güvenliydi." },
