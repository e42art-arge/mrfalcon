---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import ReviewCard from "../components/ReviewCard.astro";
import StatGrid from "../components/StatGrid.astro";
import BookingCta from "../components/BookingCta.astro";
import Icon from "../components/Icon.astro";
import { reviews } from "../data/reviews";
import { benefits } from "../data/benefits";
import { processSteps } from "../data/processSteps";
import { whyUs } from "../data/whyUs";

const heroMetrics = [
  { value: "15.000+", label: "Mutlu Danışan" },
  { value: "%70", label: "İlk Seansta Dökülme" },
  { value: "4", label: "Dalga Boyu" },
  { value: "2", label: "Merkezi Şube" },
];

const falconSpecs = [
  { label: "4 Dalga Boyu", val: "755nm, 808nm, 940nm, 1064nm" },
  { label: "Spot Başlığı", val: "4 cm² — Hızlı Seans" },
  { label: "Soğutma", val: "5 Sistem + -20° Buz" },
  { label: "Atış Hızı", val: "20 atış/sn SHR" },
  { label: "Çıkış Gücü", val: "2400W" },
  { label: "Garanti", val: "100 Milyon Atış" },
];
---

<BaseLayout title="Lazer Epilasyon | Mr. Falcon Beauty" description="Mr. Falcon Beauty Şişli ve Halkalı şubelerinde, FDA onaylı Falcon 4 Pro cihazı ile ağrısız lazer epilasyon. İlk seansta %70 dökülme." locale="tr" path="/lazer-epilasyon">
  <Header locale="tr" />

  <section class="py-20 md:py-28 bg-gradient-to-b from-sky-light to-white">
    <div class="mx-auto max-w-6xl px-5 text-center">
      <p class="mb-4 text-sm font-semibold uppercase tracking-[0.2em] text-primary">Falcon 4 Pro Technology</p>
      <h1 class="font-display text-4xl font-semibold leading-tight md:text-6xl lg:text-7xl">
        Lazer Epilasyonda<br />
        <span class="text-primary">Yeni Standardı</span>
      </h1>
      <p class="mx-auto mb-8 mt-4 max-w-xl text-lg leading-relaxed text-black/70">
        Mr. Falcon Beauty olarak Şişli ve Halkalı şubelerimizde, FDA onaylı 4 dalga boylu hibrit teknolojiye sahip Falcon 4 Pro cihazı ile profesyonel lazer epilasyon hizmeti sunuyoruz.
      </p>
      <div class="flex flex-col sm:flex-row items-stretch sm:items-center justify-center gap-4">
        <a href="/iletisim" class="text-center rounded-full bg-navy px-8 py-3 font-semibold text-white transition-colors hover:bg-primary">Hemen Randevu Oluşturun</a>
        <a href="https://api.whatsapp.com/send?phone=905525939890&text=Merhaba web siteniz üzerinden size ulaşıyorum, Falcon Lazer Epilasyon hakkında bilgi alabilir miyim ?" target="_blank" rel="noopener" class="text-center rounded-full border-2 border-black/15 px-8 py-3 font-semibold text-black transition-colors hover:border-primary hover:text-primary">WhatsApp ile Bilgi Alın</a>
      </div>
      <div class="mx-auto mt-8 flex max-w-3xl flex-wrap items-center justify-center gap-6 text-sm font-medium text-black/70">
        {benefits.tr.map((b) => (
          <span class="flex items-center gap-1.5"><Icon name={b.icon} class="w-4 h-4 text-primary" /> <strong>{b.text}</strong></span>
        ))}
      </div>
    </div>
  </section>

  <section class="py-20">
    <div class="mx-auto max-w-6xl px-5">
      <div class="grid items-center gap-12 md:grid-cols-2">
        <div>
          <p class="mb-2 text-sm font-semibold uppercase tracking-[0.2em] text-primary">Mr. Falcon Beauty</p>
          <h2 class="mb-6 font-display text-3xl font-semibold md:text-4xl lg:text-5xl">Lazer Epilasyon Nedir?</h2>
          <p class="mb-6 text-lg leading-relaxed text-black/70">
            Lazer epilasyon, kıl köklerine lazer enerjisi göndererek kalıcı tüy azaltımı sağlayan tıbbi bir işlemdir. Falcon 4 Pro cihazımız, 4 farklı dalga boyu ile melanin oranına bakılmaksızın tüm cilt tiplerinde güvenle uygulanabilir.
          </p>
          <p class="mb-6 text-lg leading-relaxed text-black/70">
            Mr. Falcon Beauty'de her danışanın cilt ve kıl yapısını ayrı ayrı ele alarak kişiye özel tedavi protokolleri oluşturuyoruz. İlk seansta %70'e ulaşan dökülme oranıyla fark yaratıyoruz.
          </p>
          <StatGrid items={heroMetrics} class="grid-cols-2 gap-4" />
        </div>
        <div class="relative">
          <img src="/images/sliderdoctor.png" alt="Falcon 4 Pro Lazer Epilasyon" class="w-full max-w-md mx-auto rounded-3xl shadow-2xl" />
          <div class="absolute -bottom-4 left-1/2 -translate-x-1/2 md:left-auto md:-translate-x-0 md:-left-4 rounded-2xl bg-navy p-4 text-white shadow-lg whitespace-nowrap">
            <div class="flex items-center gap-3 text-xl font-display font-bold">⭐ 5.0</div>
            <p class="mt-1 text-sm text-white/80">Google'de 58+ değerlendirme</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-20 bg-sky-light/30">
    <div class="mx-auto max-w-6xl px-5">
      <div class="text-center max-w-3xl mx-auto mb-12">
        <p class="mb-2 text-sm font-semibold uppercase tracking-[0.2em] text-primary">Gerçek Danışanlar</p>
        <h2 class="font-display text-3xl font-semibold md:text-4xl">Memnuniyet Yorumları</h2>
        <p class="mt-3 text-black/60">Falcon Lazer Epilasyon sonuçlarından memnun kalan danışanlarımızın yorumları.</p>
      </div>
      <div class="columns-1 gap-6 sm:columns-2 lg:columns-4">
        {reviews.slice(0, 4).map((r) => (
          <ReviewCard review={r} locale="tr" />
        ))}
      </div>
    </div>
  </section>

  <section class="py-20 bg-navy text-white">
    <div class="mx-auto max-w-6xl px-5">
      <div class="grid items-center gap-12 md:grid-cols-2">
        <div>
          <p class="mb-2 text-sm font-semibold uppercase tracking-[0.2em] text-primary">Teknoloji</p>
          <h2 class="mb-6 font-display text-3xl font-semibold md:text-4xl lg:text-5xl">Falcon 4 Pro ile Tanışın</h2>
          <p class="mb-6 text-lg leading-relaxed text-white/80">
            Falcon 4 Pro, FDA 510(k) klinik onayına sahip, 755nm, Diode (808nm), Nd:YAG (1064nm) ve 940nm olmak üzere 4 farklı lazer dalga boyunu tek bir aplikatörde birleştiren yapay zeka destekli hibrit bir lazer epilasyon cihazıdır.
          </p>
          <ul class="space-y-3">
            {falconSpecs.map((s) => (
              <li class="flex items-center gap-3"><span class="text-primary">▸</span> <strong>{s.label}:</strong> {s.val}</li>
            ))}
          </ul>
        </div>
        <div class="flex justify-center">
          <img src="/images/falcons.png" alt="Falcon 4 Pro Cihazı" class="w-full max-w-sm" />
        </div>
      </div>
    </div>
  </section>

  <section class="py-20">
    <div class="mx-auto max-w-6xl px-5">
      <div class="text-center max-w-3xl mx-auto mb-12">
        <p class="mb-2 text-sm font-semibold uppercase tracking-[0.2em] text-primary">Neden Biz?</p>
        <h2 class="font-display text-3xl font-semibold md:text-4xl">Mr. Falcon Beauty Neden Seçilmeli?</h2>
      </div>
      <div class="grid md:grid-cols-2 gap-6">
        {whyUs.tr.map((w) => (
          <article class="rounded-2xl p-6 border border-black/5 hover:shadow-lg transition-shadow bg-white">
            <Icon name={w.icon} class="w-8 h-8 text-primary" />
            <h3 class="mt-3 font-display text-xl font-semibold">{w.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-black/70">{w.desc}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="py-20 bg-sky-light/30">
    <div class="mx-auto max-w-6xl px-5">
      <div class="text-center max-w-3xl mx-auto mb-16">
        <p class="mb-2 text-sm font-semibold uppercase tracking-[0.2em] text-primary">Süreç</p>
        <h2 class="font-display text-3xl font-semibold md:text-4xl">7 Adımda Lazer Epilasyon</h2>
      </div>
      <div class="space-y-6">
        {processSteps.lazer.tr.map((step) => (
          <article class="relative flex gap-6 p-6 bg-white rounded-2xl border border-black/5 hover:shadow-md transition-shadow">
            <div class="flex-shrink-0 w-12 h-12 rounded-full bg-sky-light/50 flex items-center justify-center font-display text-xl font-bold text-primary">{step.step}</div>
            <div class="flex-1 pt-1"><h3 class="font-display text-lg font-semibold">{step.title}</h3><p class="mt-1 text-sm text-black/70">{step.desc}</p></div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <BookingCta locale="tr" />

  <Footer locale="tr" />
</BaseLayout>
