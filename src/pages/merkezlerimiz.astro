---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { getCollection } from "astro:content";

const branches = await getCollection("branches");
const clinicImages = [
  "/images/clinic/clinic1.jpg",
  "/images/clinic/clinic2.jpg",
  "/images/clinic/clinic3.jpg",
  "/images/clinic/clinic4.jpg",
  "/images/clinic/clinic5.jpg",
  "/images/clinic/clinic6.jpg",
  "/images/clinic/clinic7.jpg",
  "/images/clinic/clinic8.jpg",
];
---

<BaseLayout title="Merkezlerimiz | Mr. Falcon Beauty" description="Mr. Falcon Beauty Şişli ve Halkalı şubeleri. Adres, telefon, çalışma saatleri ve yol tarifi." locale="tr" path="/merkezlerimiz">
  <Header locale="tr" />

  <section class="py-20 md:py-28 bg-navy text-white">
    <div class="mx-auto max-w-6xl px-5 text-center">
      <p class="mb-4 text-sm font-semibold uppercase tracking-[0.2em] text-primary">Merkezlerimiz</p>
      <h1 class="font-display text-4xl font-semibold md:text-6xl lg:text-7xl">Şubelerimiz</h1>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-white/80">Mr. Falcon Beauty, İstanbul'un iki merkezi noktasında hizmetinizde.</p>
    </div>
  </section>

  <section class="py-20">
    <div class="mx-auto max-w-6xl px-5">
      <div class="grid md:grid-cols-2 gap-10">
        {branches.sort((a,b) => a.data.slug.localeCompare(b.data.slug)).map((b) => (
          <article class="rounded-2xl overflow-hidden border border-black/5 shadow-lg">
            <div class="aspect-[4/3] bg-sky-light overflow-hidden"><img src={b.data.image || "/images/clinic/clinic1.jpg"} alt={b.data.name} class="w-full h-full object-cover" /></div>
            <div class="p-6">
              <h2 class="font-display text-2xl font-semibold text-primary">{b.data.name}</h2>
              <address class="mt-3 not-italic text-sm text-black/70">{b.data.address}</address>
              <div class="mt-4 space-y-2 text-sm">
                <a href={`tel:${b.data.phone}`} class="flex items-center gap-2 text-black/70 hover:text-primary transition-colors">📞 {b.data.phone}</a>
                <a href={b.data.whatsapp} target="_blank" rel="noopener" class="flex items-center gap-2 text-black/70 hover:text-primary transition-colors">💬 WhatsApp</a>
              </div>
              {b.data.hours && <p class="mt-4 text-xs text-black/50">{b.data.hours}</p>}
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="py-20 bg-sky-light/30">
    <div class="mx-auto max-w-6xl px-5">
      <div class="text-center max-w-3xl mx-auto mb-12">
        <h2 class="font-display text-3xl font-semibold md:text-4xl">Merkez Galerisi</h2>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        {clinicImages.map((img) => (
          <div class="rounded-2xl overflow-hidden aspect-[4/3] shadow-md"><img src={img} alt="Klinik" class="w-full h-full object-cover" /></div>
        ))}
      </div>
    </div>
  </section>

  <Footer locale="tr" />
</BaseLayout>