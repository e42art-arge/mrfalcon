---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import FaqAccordion from "../components/FaqAccordion.astro";
import SectionHeader from "../components/SectionHeader.astro";
import PageHero from "../components/PageHero.astro";
import CtaSection from "../components/CtaSection.astro";
import { getCollection } from "astro:content";

const faqEntries = (await getCollection("faq", ({ id }) => id.startsWith("tr/"))).sort((a, b) => (a.data.order || 0) - (b.data.order || 0));
const faqs = faqEntries.map((e) => ({ q: e.data.question, a: e.data.answer }));
---

<BaseLayout title="SSS | Mr. Falcon Beauty" description="Lazer epilasyon hakkında sıkça sorulan sorular. Falcon 4 Pro, ağrısız epilasyon, seans sayısı ve daha fazlası." locale="tr" path="/sss">
  <Header locale="tr" />

  <PageHero label="SSS" title="Sıkça Sorulan Sorular" description="Falcon 4 Pro ve lazer epilasyon hakkında merak ettiğiniz her şey." />

  <section class="py-20 bg-sky-light/30">
    <div class="mx-auto max-w-3xl px-5">
      <FaqAccordion items={faqs} tone="light" />
      <p class="mt-10 text-center text-sm text-black/60">
        Sorunuz listede yok mu? <a href="https://wa.me/905525939890" target="_blank" rel="noopener" class="text-primary hover:underline">WhatsApp'tan sorun</a>
      </p>
    </div>
  </section>

  <CtaSection title="Başka sorunuz mu var?" description="Ücretsiz danışmanlık ve cilt analizi için randevu alın." buttonText="İletişime Geç" buttonHref="/iletisim" locale="tr" />

  <Footer locale="tr" />
</BaseLayout>
