---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import FaqAccordion from "../components/FaqAccordion.astro";
import { getCollection } from "astro:content";

const faqEntries = (await getCollection("faq", ({ id }) => id.startsWith("tr/"))).sort((a, b) => (a.data.order || 0) - (b.data.order || 0));
const faqs = faqEntries.map((e) => ({ q: e.data.question, a: e.data.answer }));
---

<BaseLayout title="SSS | Mr. Falcon Beauty" description="Lazer epilasyon hakkında sıkça sorulan sorular. Falcon 4 Pro, ağrısız epilasyon, seans sayısı ve daha fazlası." locale="tr" path="/sss">
  <Header locale="tr" />

  <section class="py-20 md:py-28 bg-navy text-white">
    <div class="mx-auto max-w-6xl px-5 text-center">
      <p class="mb-4 text-sm font-semibold uppercase tracking-[0.2em] text-primary">SSS</p>
      <h1 class="font-display text-4xl font-semibold md:text-6xl">Sıkça Sorulan Sorular</h1>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-white/80">Falcon 4 Pro ve lazer epilasyon hakkında merak ettiğiniz her şey.</p>
    </div>
  </section>

  <section class="py-20 bg-sky-light/30">
    <div class="mx-auto max-w-3xl px-5">
      <FaqAccordion items={faqs} tone="light" />
      <p class="mt-10 text-center text-sm text-black/60">
        Sorunuz listede yok mu? <a href="https://wa.me/905525939890" target="_blank" rel="noopener" class="text-primary hover:underline">WhatsApp'tan sorun</a>
      </p>
    </div>
  </section>

  <section class="py-20 bg-sky-light/50">
    <div class="mx-auto max-w-3xl px-5 text-center">
      <h2 class="font-display text-3xl font-semibold md:text-4xl">Başka sorunuz mu var?</h2>
      <p class="mt-4 text-lg text-black/70">Ücretsiz danışmanlık ve cilt analizi için randevu alın.</p>
      <div class="mt-8"><a href="/iletisim" class="rounded-full bg-navy px-8 py-3 font-semibold text-white transition-colors hover:bg-primary">İletişime Geç</a></div>
    </div>
  </section>

  <Footer locale="tr" />
</BaseLayout>
